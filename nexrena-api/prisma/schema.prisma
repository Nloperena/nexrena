datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── CRM Contacts ─────────────────────────────────────────────────────────
model Contact {
  id             String  @id
  name           String
  company        String
  email          String
  phone          String?
  billingAddress String? @map("billing_address")
  industry       String
  stage          String
  value          Float   @default(0)
  notes          String?
  stripeCustomerId String? @unique @map("stripe_customer_id")
  createdAt      String  @map("created_at")
  updatedAt      String  @map("updated_at")

  @@map("contacts")
}

// ── Projects ─────────────────────────────────────────────────────────────
model Project {
  id         String  @id
  name       String
  clientName String  @map("client_name")
  contactId  String? @map("contact_id")
  type       String
  status     String
  startDate  String  @map("start_date")
  endDate    String? @map("end_date")
  value      Float   @default(0)
  phases     Json
  notes      String?
  createdAt  String  @map("created_at")

  @@map("projects")
}

// ── Invoices ─────────────────────────────────────────────────────────────
model Invoice {
  id            String  @id
  number        String  @unique
  clientName    String  @map("client_name")
  clientCompany String? @map("client_company")
  clientEmail   String? @map("client_email")
  clientAddress String? @map("client_address")
  contactId     String? @map("contact_id")
  projectId     String? @map("project_id")
  projectName   String? @map("project_name")
  status        String
  lineItems     Json    @map("line_items")
  issueDate     String  @map("issue_date")
  dueDate       String  @map("due_date")
  netTerms      String? @map("net_terms")
  taxRate       Float?  @map("tax_rate")
  paidDate      String? @map("paid_date")
  notes         String?
  stripeInvoiceId       String? @map("stripe_invoice_id")
  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  paidVia               String? @map("paid_via")
  createdAt     String  @map("created_at")

  @@map("invoices")
}

// ── Client portal accounts ───────────────────────────────────────────────
model PortalAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  company      String?
  contactId    String   @unique @map("contact_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("portal_accounts")
}

// ── Client service requests ───────────────────────────────────────────────
model ServiceRequest {
  id              String   @id @default(cuid())
  contactId       String   @map("contact_id")
  portalAccountId String?  @map("portal_account_id")
  projectType     String   @map("project_type")
  description     String
  budget          String?
  timeline        String?
  status          String   @default("new")
  source          String   @default("portal")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  assets PortalAsset[]

  @@map("service_requests")
}

model PortalFolder {
  id        String   @id @default(cuid())
  contactId String   @map("contact_id")
  name      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  parent   PortalFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children PortalFolder[] @relation("FolderTree")
  assets   PortalAsset[]

  @@map("portal_folders")
}

model PortalAsset {
  id               String   @id @default(cuid())
  contactId        String   @map("contact_id")
  serviceRequestId String?  @map("service_request_id")
  projectId        String?  @map("project_id")
  folderId         String?  @map("folder_id")
  filename         String
  contentType      String   @map("content_type")
  sizeBytes        Int      @map("size_bytes")
  blobUrl          String   @map("blob_url")
  pathname         String
  category         String?
  note             String?
  createdAt        DateTime @default(now()) @map("created_at")

  serviceRequest ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  folder         PortalFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@map("portal_assets")
}

// ── Client portal resources (repos, live sites) ─────────────────────────────
model ClientResource {
  id              String   @id @default(cuid())
  contactId       String   @map("contact_id")
  type            String   // "github" | "live_site" | "staging"
  title           String
  url             String
  description     String?
  relatedInvoiceId String? @map("related_invoice_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("client_resources")
}

// ── Client portal messages ────────────────────────────────────────────────
model ClientMessage {
  id               String   @id @default(cuid())
  portalAccountId  String?  @map("portal_account_id")
  contactId        String?  @map("contact_id")
  clientName       String?  @map("client_name")
  clientEmail      String?  @map("client_email")
  companyName      String?  @map("company_name")
  subject          String
  message          String
  status           String   @default("unread")
  threadId         String?  @map("thread_id")
  replyToMessageId String?  @map("reply_to_message_id")
  direction        String   @default("client")
  readByClient     Boolean  @default(true) @map("read_by_client")
  readByAdmin      Boolean  @default(false) @map("read_by_admin")
  createdAt        DateTime @default(now()) @map("created_at")

  attachments MessageAttachment[]

  @@map("client_messages")
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  blobUrl   String   @map("blob_url")
  pathname  String
  filename  String
  mimeType  String   @map("mime_type")
  sizeBytes Int      @map("size_bytes")
  createdAt DateTime @default(now()) @map("created_at")

  message ClientMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}

// ── Client website form submissions ─────────────────────────────────────
model FormSubmission {
  id             String   @id @default(cuid())
  contactId      String   @map("contact_id")
  siteKey        String   @map("site_key")
  formName       String   @default("contact") @map("form_name")
  submitterName  String   @map("submitter_name")
  submitterEmail String   @map("submitter_email")
  fields         Json
  pageUrl        String?  @map("page_url")
  status         String   @default("new")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([contactId, createdAt(sort: Desc)])
  @@index([siteKey, createdAt(sort: Desc)])
  @@map("form_submissions")
}

// ── Website Leads ────────────────────────────────────────────────────────
model Lead {
  id          String   @id @default(cuid())
  name        String
  company     String?
  email       String
  budget      String?
  projectType String?  @map("project_type")
  message     String
  source      String   @default("website")
  status      String   @default("new")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("leads")
}

// ── Time Entries ─────────────────────────────────────────────────────────
model TimeEntry {
  id          String  @id
  projectId   String? @map("project_id")
  projectName String  @map("project_name")
  description String
  hours       Float
  date        String
  billable    Boolean @default(true)
  billed      Boolean @default(false)
  createdAt   String  @map("created_at")

  @@map("time_entries")
}

// ── Proposals ────────────────────────────────────────────────────────────
model Proposal {
  id            String  @id
  title         String
  contactId     String? @map("contact_id")
  projectId     String? @map("project_id")
  clientName    String  @map("client_name")
  clientCompany String? @map("client_company")
  clientEmail   String? @map("client_email")
  services      Json
  discount      Float   @default(0)
  status        String  @default("draft")
  validUntil    String  @map("valid_until")
  scopeOfWork   String  @map("scope_of_work")
  timeline      String?
  notes         String?
  createdAt     String  @map("created_at")

  @@map("proposals")
}

// ── Subscriptions ────────────────────────────────────────────────────────
model Subscription {
  id              String  @id
  contactId       String  @map("contact_id")
  description     String
  amount          Float
  interval        String           // "monthly" | "quarterly" | "annually"
  status          String  @default("active") // "active" | "paused" | "cancelled"
  billingDay      Int     @default(1)  @map("billing_day")
  nextBillingDate String  @map("next_billing_date")
  skipNext        Boolean @default(false) @map("skip_next")
  netTerms        String? @map("net_terms")
  notes           String?
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  stripePriceId        String? @map("stripe_price_id")
  createdAt       String  @map("created_at")

  @@map("subscriptions")
}

// ── Expenses ─────────────────────────────────────────────────────────────
model Expense {
  id          String  @id
  projectId   String? @map("project_id")
  projectName String? @map("project_name")
  category    String
  description String
  amount      Float
  date        String
  vendor      String?
  notes       String?
  createdAt   String  @map("created_at")

  @@map("expenses")
}
