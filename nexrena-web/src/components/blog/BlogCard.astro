---
interface Props {
  slug: string;
  title: string;
  description: string;
  publishedAt: Date;
  category: string;
}

const { slug, title, description, publishedAt, category } = Astro.props;

import { blogCategories } from '../../data/blog-categories';
const cat = blogCategories.find(c => c.id === category);
---

<a href={`/resources/blog/${slug}/`} class="group block p-6 border border-[var(--slate-800)] hover:border-[var(--gold)] transition-colors reveal">
  <div class="flex items-center gap-3 mb-3">
    <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">
      {publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </span>
    {cat && (
      <span class="font-mono text-[9px] text-[var(--slate-400)] bg-[var(--slate-800)] px-2 py-0.5 uppercase tracking-wider">
        {cat.name}
      </span>
    )}
  </div>
  <h2 class="font-display text-[24px] text-[var(--warm-white)] mb-3 group-hover:text-[var(--gold)] transition-colors line-clamp-2">
    {title}
  </h2>
  <p class="font-body text-[14px] text-[var(--slate-400)] line-clamp-2">
    {description}
  </p>
  <span class="inline-block mt-4 font-mono text-[11px] text-[var(--gold)] group-hover:translate-x-2 transition-transform">Read &rarr;</span>
</a>
