---
<!-- Hidden by default. Only shown by JS on first visit. -->
<div id="app-loader" class="fixed inset-0 z-[1000] bg-[var(--obsidian)] flex items-center justify-center pointer-events-none" style="display:none;" transition:persist="loader">
  <div class="loader-content flex items-center overflow-hidden">
    <div class="loader-text font-display text-[48px] md:text-[72px] text-[var(--warm-white)] flex items-center">
      <span>Nex</span><span class="text-[var(--gold)]">rena</span>
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap';

  function initLoader() {
    const loader = document.getElementById('app-loader');
    if (!loader) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (sessionStorage.getItem('nexrena-loader-seen')) return;

    sessionStorage.setItem('nexrena-loader-seen', 'true');

    // Show the loader (it starts display:none)
    loader.style.display = 'flex';

    gsap.timeline({ onComplete: () => { loader.style.display = 'none'; } })
      .fromTo('.loader-text',
        { y: 100, opacity: 0, skewY: 6, scale: 0.95 },
        { y: 0, opacity: 1, skewY: 0, scale: 1, duration: 0.9, ease: 'expo.out' })
      .to('.loader-text', {
        opacity: 0, scale: 1.05, duration: 0.4, delay: 0.6, ease: 'power2.inOut' })
      .to(loader, {
        yPercent: -100, duration: 0.7, ease: 'expo.inOut' }, '-=0.2');
  }

  initLoader();
</script>

<style>
  .loader-content {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
  }
</style>
