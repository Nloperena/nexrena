---
const { class: className = '' } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" width="100%" viewBox="0 0 1200 690" preserveAspectRatio="xMaxYMin slice" class={className}>
<defs>
<linearGradient id="goldLineH" x1="0" y1="0" x2="1" y2="0">
<stop offset="0%" stop-color="#b89354" stop-opacity="0"/>
<stop offset="15%" stop-color="#b89354" stop-opacity="0.4"/>
<stop offset="50%" stop-color="#f5d796" stop-opacity="0.25"/>
<stop offset="85%" stop-color="#c9a050" stop-opacity="0.35"/>
<stop offset="100%" stop-color="#c9a050" stop-opacity="0"/>
</linearGradient>
<linearGradient id="goldLineV" x1="0" y1="0" x2="0" y2="1">
<stop offset="0%" stop-color="#b89354" stop-opacity="0"/>
<stop offset="15%" stop-color="#b89354" stop-opacity="0.35"/>
<stop offset="50%" stop-color="#f5d796" stop-opacity="0.2"/>
<stop offset="85%" stop-color="#c9a050" stop-opacity="0.3"/>
<stop offset="100%" stop-color="#c9a050" stop-opacity="0"/>
</linearGradient>
<linearGradient id="goldLineDiag" x1="0" y1="0" x2="1" y2="1">
<stop offset="0%" stop-color="#b89354" stop-opacity="0"/>
<stop offset="20%" stop-color="#b89354" stop-opacity="0.2"/>
<stop offset="50%" stop-color="#f5d796" stop-opacity="0.15"/>
<stop offset="80%" stop-color="#c9a050" stop-opacity="0.2"/>
<stop offset="100%" stop-color="#c9a050" stop-opacity="0"/>
</linearGradient>
<radialGradient id="nodeGlow" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#f5d796" stop-opacity="0.6"/>
<stop offset="50%" stop-color="#b89354" stop-opacity="0.2"/>
<stop offset="100%" stop-color="#b89354" stop-opacity="0"/>
</radialGradient>
<radialGradient id="ambientGold" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#b89354" stop-opacity="0.06"/>
<stop offset="70%" stop-color="#b89354" stop-opacity="0.02"/>
<stop offset="100%" stop-color="#050507" stop-opacity="0"/>
</radialGradient>

</defs>

<rect width="1200" height="680" fill="#050507"/>
<ellipse cx="880" cy="280" rx="280" ry="240" fill="url(#ambientGold)"/>

<g>
<line x1="680" y1="140" x2="1120" y2="140" stroke="url(#goldLineH)" stroke-width="0.6" opacity="0.21"/>
<line x1="720" y1="240" x2="1100" y2="240" stroke="url(#goldLineH)" stroke-width="0.8" opacity="0.12"/>
<line x1="700" y1="340" x2="1080" y2="340" stroke="url(#goldLineH)" stroke-width="0.6" opacity="0.08"/>
<line x1="740" y1="440" x2="1060" y2="440" stroke="url(#goldLineH)" stroke-width="0.5" opacity="0.08"/>
<line x1="780" y1="80" x2="780" y2="500" stroke="url(#goldLineV)" stroke-width="0.6" opacity="0.18"/>
<line x1="880" y1="60" x2="880" y2="520" stroke="url(#goldLineV)" stroke-width="0.8" opacity="0.12"/>
<line x1="980" y1="80" x2="980" y2="500" stroke="url(#goldLineV)" stroke-width="0.6" opacity="0.08"/>
<line x1="1060" y1="100" x2="1060" y2="480" stroke="url(#goldLineV)" stroke-width="0.5" opacity="0.1"/>
<line x1="780" y1="140" x2="880" y2="240" stroke="url(#goldLineDiag)" stroke-width="0.4" opacity="0.14"/>
<line x1="880" y1="240" x2="980" y2="340" stroke="url(#goldLineDiag)" stroke-width="0.4" opacity="0.09"/>
<line x1="980" y1="140" x2="880" y2="240" stroke="url(#goldLineDiag)" stroke-width="0.35" opacity="0.08"/>
<line x1="880" y1="340" x2="980" y2="440" stroke="url(#goldLineDiag)" stroke-width="0.3" opacity="0.1"/>
</g>

<g>
<circle cx="880" cy="240" r="3" fill="url(#nodeGlow)"/>
<circle cx="880" cy="240" r="1.5" fill="#f5d796" opacity="0.7"/>
<circle cx="980" cy="340" r="2.5" fill="url(#nodeGlow)"/>
<circle cx="980" cy="340" r="1.2" fill="#f5d796" opacity="0.55"/>
<circle cx="780" cy="140" r="2.5" fill="url(#nodeGlow)"/>
<circle cx="780" cy="140" r="1.2" fill="#f5d796" opacity="0.5"/>
</g>

<rect x="620" y="0" width="200" height="680" fill="#050507" opacity="0.85"/>
<rect x="620" y="0" width="120" height="680" fill="#050507"/>
<rect x="0" y="0" width="1200" height="60" fill="#050507" opacity="0.7"/>
<rect x="0" y="0" width="1200" height="25" fill="#050507"/>
<rect x="0" y="560" width="1200" height="120" fill="#050507" opacity="0.7"/>
<rect x="0" y="600" width="1200" height="80" fill="#050507"/>
<rect x="1080" y="0" width="120" height="680" fill="#050507" opacity="0.6"/>
<rect x="1140" y="0" width="60" height="680" fill="#050507" opacity="0.9"/>
</svg>
