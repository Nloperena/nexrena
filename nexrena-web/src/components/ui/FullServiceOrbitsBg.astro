---
const { class: className = '' } = Astro.props;
---

<div class={`fullservice-orbits-bg ${className}`} aria-hidden="true">
  <canvas id="fullservice-orbits-canvas" width="1200" height="675"></canvas>
</div>

<script>
  let cleanupOrbits: (() => void) | null = null;

  function initFullServiceOrbits() {
    cleanupOrbits?.();
    cleanupOrbits = null;

    const canvas = document.getElementById('fullservice-orbits-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const G = canvas.getContext('2d');
    if (!G) return;

    const W = 1200, H = 675, bg = '#050507', gold = '#b89354', lt = '#f5d796';
    let t = 0;
    let raf = 0;

    const camDist = 800;
    const centerX = 600, centerY = 338;
    let globalRotY = 0;
    const tiltX = -0.25, tiltZ = 0.12;

    function rotY3(x: number, y: number, z: number, a: number) {
      const c = Math.cos(a), s = Math.sin(a);
      return [x * c + z * s, y, -x * s + z * c];
    }
    function rotX3(x: number, y: number, z: number, a: number) {
      const c = Math.cos(a), s = Math.sin(a);
      return [x, y * c - z * s, y * s + z * c];
    }
    function rotZ3(x: number, y: number, z: number, a: number) {
      const c = Math.cos(a), s = Math.sin(a);
      return [x * c - y * s, x * s + y * c, z];
    }

    function project(x: number, y: number, z: number) {
      let p = rotY3(x, y, z, globalRotY);
      p = rotX3(p[0], p[1], p[2], tiltX);
      p = rotZ3(p[0], p[1], p[2], tiltZ);
      const scale = camDist / (camDist + p[2]);
      return { x: centerX + p[0] * scale, y: centerY + p[1] * scale, z: p[2], s: scale };
    }

    const lp = (a: number, b: number, t: number) => a + (b - a) * t;
    const cl = (x: number) => Math.max(0, Math.min(1, x));

    function depthLine(p1: { x: number; y: number; z: number }, p2: { x: number; y: number; z: number }, color: string, width: number, alpha: number) {
      const midZ = (p1.z + p2.z) / 2;
      const df = cl((midZ + 350) / 700);
      const a = alpha * (0.06 + 0.94 * df);
      if (a < 0.008) return;
      G.beginPath(); G.moveTo(p1.x, p1.y); G.lineTo(p2.x, p2.y);
      G.strokeStyle = color; G.globalAlpha = a;
      G.lineWidth = width * (0.35 + 0.65 * df); G.stroke();
    }

    function drawNode(x: number, y: number, z: number, r: number, glowing: boolean, alpha: number) {
      const p = project(x, y, z);
      const df = cl((p.z + 350) / 700);
      const a = alpha * (0.08 + 0.92 * df);
      if (a < 0.008) return;
      const sz = r * (0.5 + 0.5 * df) * p.s;
      if (glowing) {
        const gr = G.createRadialGradient(p.x, p.y, 0, p.x, p.y, sz * 5);
        gr.addColorStop(0, `rgba(245,215,150,${0.5 * a})`);
        gr.addColorStop(1, 'rgba(245,215,150,0)');
        G.globalAlpha = 1; G.fillStyle = gr;
        G.beginPath(); G.arc(p.x, p.y, sz * 5, 0, Math.PI * 2); G.fill();
        G.beginPath(); G.arc(p.x, p.y, sz * 2.8, 0, Math.PI * 2);
        G.strokeStyle = lt; G.lineWidth = 0.3; G.globalAlpha = a * 0.3; G.stroke();
      }
      G.beginPath(); G.arc(p.x, p.y, sz, 0, Math.PI * 2);
      G.fillStyle = glowing ? '#fff' : lt; G.globalAlpha = a; G.fill();
    }

    const orbits = [
      { baseR: 220, baseTiltX: 0.9, baseTiltZ: 0, phase: 0, convR: 180, convTiltX: 0.15, convTiltZ: 0, color: '#f5d796', speed: 0.6, satR: 5, satGlow: true },
      { baseR: 200, baseTiltX: 0.2, baseTiltZ: 1.2, phase: 1.57, convR: 180, convTiltX: 0.15, convTiltZ: 0, color: '#f5d796', speed: 0.6, satR: 4.5, satGlow: true },
      { baseR: 190, baseTiltX: -0.7, baseTiltZ: 0.4, phase: 3.14, convR: 180, convTiltX: 0.15, convTiltZ: 0, color: '#f5d796', speed: 0.6, satR: 4, satGlow: true },
      { baseR: 210, baseTiltX: 0.4, baseTiltZ: -0.9, phase: 4.71, convR: 180, convTiltX: 0.15, convTiltZ: 0, color: '#f5d796', speed: 0.6, satR: 4.5, satGlow: true }
    ];

    const CYCLE = 24;
    const eio = (x: number) => x < 0.5 ? 2 * x * x : 1 - Math.pow(-2 * x + 2, 2) / 2;

    function convergence() {
      const cyc = t % CYCLE;
      if (cyc < 3) return 0;
      if (cyc < 9) return eio((cyc - 3) / 6);
      if (cyc < 15) return 1;
      if (cyc < 21) return 1 - eio((cyc - 15) / 6);
      return 0;
    }

    function orbitPoint(orb: typeof orbits[0], angle: number, conv: number): [number, number, number] {
      const r = lp(orb.baseR, orb.convR, conv);
      const tx = lp(orb.baseTiltX, orb.convTiltX, conv);
      const tz = lp(orb.baseTiltZ, orb.convTiltZ, conv);
      let x = r * Math.cos(angle), y = 0, z = r * Math.sin(angle);
      const cx = Math.cos(tx), sx = Math.sin(tx);
      const y2 = y * cx - z * sx, z2 = y * sx + z * cx;
      y = y2; z = z2;
      const cz = Math.cos(tz), sz = Math.sin(tz);
      const x2 = x * cz - y * sz, y3 = x * sz + y * cz;
      x = x2; y = y3;
      return [x, y, z];
    }

    const nodes: { x: number; y: number; z: number; r: number; glow: boolean; ph: number; sp: number }[] = [];
    for (let i = 0; i < 14; i++) {
      nodes.push({
        x: (Math.random() - 0.5) * 800, y: (Math.random() - 0.5) * 500, z: (Math.random() - 0.5) * 300,
        r: 1.2 + Math.random() * 2, glow: Math.random() < 0.3,
        ph: Math.random() * Math.PI * 2, sp: 0.2 + Math.random() * 0.25
      });
    }

    const nedges: [number, number][] = [];
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[i].x - nodes[j].x, dy = nodes[i].y - nodes[j].y, dz = nodes[i].z - nodes[j].z;
        if (Math.sqrt(dx * dx + dy * dy + dz * dz) < 320 && nedges.length < 22) nedges.push([i, j]);
      }
    }

    const nparts: { f: number; o: number; t: number; sp: number; sz: number; br: number }[] = [];
    for (let i = 0; i < 14; i++) {
      const e = nedges[Math.floor(Math.random() * nedges.length)];
      nparts.push({ f: e[0], o: e[1], t: Math.random(), sp: 0.001 + Math.random() * 0.0025, sz: 0.6 + Math.random() * 1, br: 0.25 + Math.random() * 0.4 });
    }

    const octR = 35;
    const octVerts: [number, number, number][] = [
      [0, -octR, 0], [0, octR, 0],
      [octR, 0, 0], [-octR, 0, 0],
      [0, 0, octR], [0, 0, -octR]
    ];
    const octEdges: [number, number][] = [
      [0, 2], [0, 3], [0, 4], [0, 5], [1, 2], [1, 3], [1, 4], [1, 5],
      [2, 4], [4, 3], [3, 5], [5, 2]
    ];

    const orbitTrails: { offset: number; sz: number; br: number }[][] = [[], [], [], []];
    for (let i = 0; i < 4; i++) {
      for (let j = 0; j < 6; j++) {
        orbitTrails[i].push({ offset: j * 0.18 + Math.random() * 0.08, sz: 0.6 + Math.random() * 0.8, br: 0.15 + Math.random() * 0.25 });
      }
    }

    function drawSatConnections(satPositions: [number, number, number][], conv: number) {
      if (conv < 0.3) return;
      const a = ((conv - 0.3) / 0.7) * 0.12;
      for (let i = 0; i < satPositions.length; i++) {
        for (let j = i + 1; j < satPositions.length; j++) {
          const s1 = satPositions[i], s2 = satPositions[j];
          for (let k = 0; k < 12; k++) {
            const t1 = k / 12, t2 = (k + 1) / 12;
            const p1 = project(lp(s1[0], s2[0], t1), lp(s1[1], s2[1], t1), lp(s1[2], s2[2], t1));
            const p2 = project(lp(s1[0], s2[0], t2), lp(s1[1], s2[1], t2), lp(s1[2], s2[2], t2));
            depthLine(p1, p2, lt, 0.4, a);
          }
        }
      }
    }

    function draw() {
      globalRotY = t * 0.08;
      const conv = convergence();

      G.clearRect(0, 0, W, H);

      const ag = G.createRadialGradient(centerX, centerY, 15, centerX, centerY, 420);
      ag.addColorStop(0, `rgba(184,147,84,${lp(0.08, 0.15, conv)})`);
      ag.addColorStop(0.5, `rgba(184,147,84,${lp(0.02, 0.05, conv)})`);
      ag.addColorStop(1, 'rgba(5,5,7,0)');
      G.globalAlpha = 1; G.fillStyle = ag; G.fillRect(0, 0, W, H);

      for (let i = 0; i < nedges.length; i++) {
        const a = nodes[nedges[i][0]], b = nodes[nedges[i][1]];
        const pa = project(a.x, a.y, a.z), pb = project(b.x, b.y, b.z);
        depthLine(pa, pb, gold, 0.5, 0.06);
      }
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i], pulse = 0.7 + 0.3 * Math.sin(t * n.sp + n.ph);
        drawNode(n.x, n.y, n.z, n.r * pulse, n.glow, 0.4 * pulse);
      }
      for (let i = 0; i < nparts.length; i++) {
        const p = nparts[i];
        p.t += p.sp;
        if (p.t >= 1) { const e2 = nedges[Math.floor(Math.random() * nedges.length)]; p.f = e2[0]; p.o = e2[1]; p.t = 0; }
        const na = nodes[p.f], nb = nodes[p.o];
        const al = p.br * Math.sin(p.t * Math.PI);
        if (al < 0.006) continue;
        for (let k = 4; k >= 0; k--) {
          const tt = Math.max(0, p.t - k * 0.012);
          const tp = project(lp(na.x, nb.x, tt), lp(na.y, nb.y, tt), lp(na.z, nb.z, tt));
          const s2 = (4 - k) / 4;
          G.beginPath(); G.arc(tp.x, tp.y, p.sz * s2 * 0.5 * tp.s, 0, Math.PI * 2);
          G.fillStyle = lt; G.globalAlpha = al * s2 * 0.3; G.fill();
        }
        const hp = project(lp(na.x, nb.x, p.t), lp(na.y, nb.y, p.t), lp(na.z, nb.z, p.t));
        G.beginPath(); G.arc(hp.x, hp.y, p.sz * 0.6 * hp.s, 0, Math.PI * 2); G.fillStyle = '#fff'; G.globalAlpha = al * 0.7; G.fill();
      }

      const RING_PTS = 90;
      const satPositions: [number, number, number][] = [];

      for (let i = 0; i < 4; i++) {
        const orb = orbits[i];
        const satAngle = t * orb.speed + orb.phase;

        for (let j = 0; j < RING_PTS; j++) {
          const a1 = j / RING_PTS * Math.PI * 2;
          const a2 = (j + 1) / RING_PTS * Math.PI * 2;
          const pt1 = orbitPoint(orb, a1, conv);
          const pt2 = orbitPoint(orb, a2, conv);
          const p1 = project(pt1[0], pt1[1], pt1[2]);
          const p2 = project(pt2[0], pt2[1], pt2[2]);
          const distToSat = Math.abs(((a1 % (Math.PI * 2)) - (satAngle % (Math.PI * 2)) + Math.PI * 2 * 1.5) % (Math.PI * 2) - Math.PI);
          const wake = cl(1 - distToSat / 1.5) * 0.15;
          const baseA = lp(0.25, 0.4, conv) + wake;
          depthLine(p1, p2, orb.color, 0.8 + wake * 2, baseA);
        }

        const sp = orbitPoint(orb, satAngle, conv);
        satPositions.push(sp);
        drawNode(sp[0], sp[1], sp[2], orb.satR, orb.satGlow, 0.9);

        for (let j = 0; j < orbitTrails[i].length; j++) {
          const tr = orbitTrails[i][j];
          const trAngle = satAngle - tr.offset - 0.05;
          const trPt = orbitPoint(orb, trAngle, conv);
          const trP = project(trPt[0], trPt[1], trPt[2]);
          const trDf = cl((trP.z + 350) / 700);
          const trA = tr.br * (0.15 + 0.85 * trDf);
          G.beginPath(); G.arc(trP.x, trP.y, tr.sz * (0.4 + 0.6 * trDf) * trP.s, 0, Math.PI * 2);
          G.fillStyle = lt; G.globalAlpha = trA; G.fill();
        }
      }

      drawSatConnections(satPositions, conv);

      if (conv > 0.1) {
        const octA = cl((conv - 0.1) / 0.5) * 0.35;
        const octSpin = t * 0.4;
        const cs = Math.cos(octSpin), ss = Math.sin(octSpin);
        for (let i = 0; i < octEdges.length; i++) {
          const v1 = octVerts[octEdges[i][0]], v2 = octVerts[octEdges[i][1]];
          const ax = v1[0] * cs + v1[2] * ss, az = -v1[0] * ss + v1[2] * cs;
          const bxx = v2[0] * cs + v2[2] * ss, bz = -v2[0] * ss + v2[2] * cs;
          for (let j = 0; j < 10; j++) {
            const t1 = j / 10, t2 = (j + 1) / 10;
            const p1 = project(lp(ax, bxx, t1), lp(v1[1], v2[1], t1), lp(az, bz, t1));
            const p2 = project(lp(ax, bxx, t2), lp(v1[1], v2[1], t2), lp(az, bz, t2));
            depthLine(p1, p2, lt, 0.7, octA);
          }
        }
        for (let i = 0; i < octVerts.length; i++) {
          const v = octVerts[i];
          const vx = v[0] * cs + v[2] * ss, vz = -v[0] * ss + v[2] * cs;
          drawNode(vx, v[1], vz, 2.5, true, octA * 0.8);
        }
      }

      const outerR = 280;
      for (let i = 0; i < 60; i++) {
        if (i % 3 === 2) continue;
        const a1 = i / 60 * Math.PI * 2, a2 = (i + 1) / 60 * Math.PI * 2;
        const ox1 = outerR * Math.cos(a1), oz1 = outerR * Math.sin(a1);
        const ox2 = outerR * Math.cos(a2), oz2 = outerR * Math.sin(a2);
        const op1 = project(ox1, 0, oz1), op2 = project(ox2, 0, oz2);
        depthLine(op1, op2, gold, 0.6, 0.25);
      }

      t += 1 / 60;
      raf = requestAnimationFrame(draw);
    }

    draw();
    cleanupOrbits = () => cancelAnimationFrame(raf);
  }

  document.addEventListener('astro:page-load', initFullServiceOrbits);
  document.addEventListener('astro:before-swap', () => { cleanupOrbits?.(); cleanupOrbits = null; });
</script>

<style>
  .fullservice-orbits-bg {
    position: absolute;
    pointer-events: none;
    overflow: hidden;
  }

  .fullservice-orbits-bg canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
