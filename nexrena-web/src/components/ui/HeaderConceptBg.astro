---
import { getSvgForRoute } from '@/lib/svgPacks';

interface Props {
  routeKey?: string;
  class?: string;
}

const { routeKey, class: className = '' } = Astro.props;

// Use current path if routeKey is not provided
const currentPath = Astro.url.pathname;
const effectiveRouteKey = routeKey ?? currentPath;

// Get the raw SVG string for this specific route section
const svgContent = getSvgForRoute(effectiveRouteKey);
---

<div class={`header-concept-bg ${className}`} aria-hidden="true" set:html={svgContent} />

<style>
  .header-concept-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* Force the injected SVG to stretch appropriately */
  .header-concept-bg :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.8; /* Keep it subtle so text remains readable */
  }
</style>
