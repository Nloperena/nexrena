---
interface Props {
  class?: string;
  /** @deprecated Tagline removed — kept for call-site compatibility */
  showTagline?: boolean;
}

const { class: className = '' } = Astro.props;
---

<span
  class:list={['logo-mark', className]}
  role="img"
  aria-label="Nexrena"
>
  N
</span>

<style>
  .logo-mark {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 2.5rem;
    line-height: 1;
    color: #e8d5b0;
    letter-spacing: -0.02em;
    user-select: none;
  }

  .logo-mark--compact {
    font-size: 1.75rem;
  }

  @media (min-width: 768px) {
    .logo-mark--compact {
      font-size: 2rem;
    }
  }
</style>
