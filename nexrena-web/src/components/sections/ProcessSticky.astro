---
/*
  Process — Horizontal Scroll via GSAP
  Intro: full-bleed video fading through cream.
  Steps: full-bleed media behind gradient frost that bleeds left→transparent.
*/
import Eyebrow from '../ui/Eyebrow.astro';
import { processDiscoverySvg, processStrategySvg, processExecutionSvg, processDeliverySvg } from '../../lib/processSvgs';

const steps = [
  {
    num: '01',
    title: 'Discovery',
    body: 'We audit your existing digital presence, research your competitors, and map the exact gaps between where you are and where buyers expect you to be.',
    proof: 'Week 1: you know exactly where you stand.',
    media: { type: 'svg', content: processDiscoverySvg },
  },
  {
    num: '02',
    title: 'Strategy',
    body: "Every engagement starts with a clear roadmap. We define what we're building, why, and exactly what success looks like — before a single pixel moves.",
    proof: 'Scope locked before a single pixel moves.',
    media: { type: 'svg', content: processStrategySvg },
  },
  {
    num: '03',
    title: 'Execution',
    body: 'We build fast and iterate in the open. You see progress weekly. No surprises, no handoff delays.',
    proof: 'Weekly progress. No status calls unless you want one.',
    media: { type: 'svg', content: processExecutionSvg },
  },
  {
    num: '04',
    title: 'Delivery',
    body: "Launch isn't the finish line — it's the starting gun. We measure, optimize, and compound from day one.",
    proof: 'Launch day is day one, not the finish line.',
    media: { type: 'svg', content: processDeliverySvg },
  },
];
---

<section id="process-wrapper" class="process-desktop bg-[var(--cream)] overflow-hidden relative hidden md:block">
  <div id="process-scroll-container" class="flex h-screen items-stretch w-max">

    <!-- Intro Panel — subtle video texture behind cream -->
    <div class="w-screen h-full shrink-0 relative overflow-hidden">
      <video
        class="process-bg-video absolute inset-0 w-full h-full object-cover opacity-30"
        muted loop playsinline preload="none"
        poster="/images/showreel-industrial.webp"
      >
        <source src="/videos/showreel-brutalist.webm" type="video/webm" />
      </video>
      <!-- Cream wash over video -->
      <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(135deg, var(--cream) 30%, rgba(245,240,232,0.6) 100%);"></div>
      <div class="relative z-10 h-full flex flex-col justify-center px-[5vw]">
        <div class="max-w-3xl">
          <Eyebrow class="mb-8">HOW WE WORK //</Eyebrow>
          <h2 class="font-display text-[clamp(64px,8vw,120px)] leading-[0.9] tracking-tight text-[var(--obsidian)] mb-8">
            Structured.<br/>
            Transparent.<br/>
            <span class="italic text-[var(--gold-dim)]">Delivered.</span>
          </h2>
          <p class="font-body text-[var(--slate-600)] text-xl max-w-xl">
            No black boxes. No endless planning. A process that ships real work, every week.
          </p>
        </div>
      </div>
    </div>

    <!-- Step Panels -->
    {steps.map((step) => (
      <div class="w-screen h-full shrink-0 relative overflow-hidden process-panel bg-[var(--cream)]">

        <!-- Full-bleed background media — kept subtle -->
        {step.media.type === 'video' ? (
          <video
            class="process-bg-video process-visual absolute inset-0 w-full h-full object-cover opacity-50"
            muted loop playsinline preload="none"
            poster={step.media.poster}
          >
            <source src={step.media.src} type="video/webm" />
          </video>
        ) : step.media.type === 'svg' ? (
          <div 
            class="process-visual absolute inset-0 w-full h-full opacity-60 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:object-cover" 
            set:html={step.media.content} 
            aria-hidden="true"
          />
        ) : (
          <img
            class="process-visual absolute inset-0 w-full h-full object-cover opacity-50"
            src={step.media.src}
            alt={step.title}
            loading="lazy"
          />
        )}

        <!-- Ghost step number — texture only -->
        <div class="absolute right-[4vw] bottom-[-4vh] font-display text-[46vh] leading-none text-[var(--obsidian)] opacity-[0.035] pointer-events-none select-none z-10">
          {step.num}
        </div>

        <!-- Gradient frost layer — solid cream left, fades to transparent right -->
        <div class="process-frost absolute inset-0 z-10 pointer-events-none"></div>

        <!-- Text content — sits above frost -->
        <div class="absolute inset-y-0 left-0 w-[52%] flex items-center pl-[5vw] pr-8 z-20">
          <div>
            <div class="process-num font-mono text-[16px] text-[var(--gold)] border border-[var(--gold)]/70 rounded-full w-[60px] h-[60px] flex items-center justify-center mb-9">
              {step.num}
            </div>
            <h3 class="process-title font-display text-[clamp(44px,4.8vw,72px)] text-[var(--obsidian)] mb-5 leading-none tracking-tight">
              {step.title}
            </h3>
            <p class="process-body font-body text-[clamp(15px,1.2vw,18px)] text-[var(--slate-600)] leading-relaxed mb-8 max-w-sm">
              {step.body}
            </p>
            <p class="font-mono text-[11px] text-[var(--gold-dim)] tracking-wider">
              → {step.proof}
            </p>
          </div>
        </div>

      </div>
    ))}

    <!-- Outro spacer -->
    <div class="w-[15vw] h-full shrink-0 bg-[var(--cream)]"></div>

  </div>
</section>

<!-- Mobile Fallback (Vertical) -->
<section class="process-mobile bg-[var(--cream)] py-24 md:hidden" style="color: var(--obsidian);">
  <div class="section-container">
    <Eyebrow class="mb-6">HOW WE WORK //</Eyebrow>
    <h2 class="font-display text-[48px] leading-[1] text-[var(--obsidian)] mb-8">
      Structured.<br/>Transparent.<br/><span class="italic text-[var(--gold-dim)]">Delivered.</span>
    </h2>
    <p class="font-body text-[var(--slate-600)] text-lg max-w-xl mb-16">
      No black boxes. No endless planning. A process that ships real work, every week.
    </p>

    <div class="flex flex-col gap-0">
      {steps.map((step) => (
        <div class="relative overflow-hidden border-t border-[var(--gold)]/20">
          <div class="aspect-[16/9] w-full relative">
            {step.media.type === 'video' ? (
              <video class="process-bg-video w-full h-full object-cover opacity-60" muted loop playsinline preload="none" poster={step.media.poster}>
                <source src={step.media.src} type="video/webm" />
              </video>
            ) : step.media.type === 'svg' ? (
              <div 
                class="w-full h-full opacity-70 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:object-cover" 
                set:html={step.media.content} 
                aria-hidden="true"
              />
            ) : (
              <img class="w-full h-full object-cover opacity-60" src={step.media.src} alt={step.title} loading="lazy" />
            )}
            <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 40%, var(--cream) 100%);"></div>
          </div>
          <div class="px-5 pb-10 -mt-6 relative z-10">
            <div class="font-mono text-[13px] text-[var(--gold)] mb-3">{step.num}</div>
            <h3 class="font-display text-[32px] text-[var(--obsidian)] mb-3 leading-none">{step.title}</h3>
            <p class="font-body text-[15px] text-[var(--slate-600)] leading-relaxed mb-3">{step.body}</p>
            <p class="font-mono text-[11px] text-[var(--gold-dim)] tracking-wider">→ {step.proof}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initHorizontalScroll() {
    gsap.registerPlugin(ScrollTrigger);

    if (window.innerWidth < 768 || window.innerHeight <= 600) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const wrapper = document.getElementById('process-wrapper');
    const container = document.getElementById('process-scroll-container');
    if (!wrapper || !container) return;

    gsap.set(container, { x: 0 });

    const horizontalTween = gsap.to(container, {
      x: () => -(container.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: wrapper,
        pin: true,
        scrub: 1,
        end: () => '+=' + (container.scrollWidth - window.innerWidth),
        invalidateOnRefresh: true,
        anticipatePin: 1,
      },
    });

    const panels = gsap.utils.toArray<HTMLElement>('.process-panel');

    panels.forEach((panel) => {
      const num    = panel.querySelector('.process-num');
      const title  = panel.querySelector('.process-title');
      const body   = panel.querySelector('.process-body');
      const visual = panel.querySelector<HTMLElement>('.process-visual');

      gsap.set([num, title, body], { opacity: 0, y: 20 });

      gsap.timeline({
        scrollTrigger: {
          trigger: panel,
          containerAnimation: horizontalTween,
          start: 'left 65%',
          toggleActions: 'play none none reverse',
        },
      })
        .to(num,   { opacity: 1, y: 0, duration: 0.4,  ease: 'power2.out' })
        .to(title, { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out' }, '-=0.25')
        .to(body,  { opacity: 1, y: 0, duration: 0.5,  ease: 'power2.out' }, '-=0.3');

      if (visual) {
        gsap.fromTo(visual,
          { scale: 1.08, xPercent: 4 },
          {
            xPercent: -4,
            ease: 'none',
            scrollTrigger: {
              trigger: panel,
              containerAnimation: horizontalTween,
              start: 'left right',
              end: 'right left',
              scrub: true,
            },
          }
        );
      }
    });
  }

  document.addEventListener('astro:page-load', initHorizontalScroll);

  // Play videos only when the process section enters the viewport
  document.addEventListener('astro:page-load', () => {
    const wrapper = document.getElementById('process-wrapper') ?? document.querySelector('.process-mobile');
    if (!wrapper) return;

    const videoObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const videos = entry.target.querySelectorAll<HTMLVideoElement>('video.process-bg-video');
        videos.forEach(v => {
          if (entry.isIntersecting) {
            v.play().catch(() => {});
          } else {
            v.pause();
          }
        });
      });
    }, { threshold: 0.1 });

    // Observe both desktop and mobile sections
    document.querySelectorAll('#process-wrapper, .process-mobile').forEach(el => videoObserver.observe(el));
  });

  // Play SVGs based on scroll velocity through GSAP ScrollTrigger
  document.addEventListener('astro:page-load', () => {
    gsap.registerPlugin(ScrollTrigger);
    const wrapper = document.getElementById('process-wrapper') ?? document.querySelector('.process-mobile');
    if (!wrapper) return;

    let timeout: number;
    
    ScrollTrigger.create({
      trigger: wrapper,
      start: "top bottom",
      end: "bottom top",
      onUpdate: (self) => {
        if (Math.abs(self.getVelocity()) > 50) {
          document.body.classList.add('is-scrolling');
          clearTimeout(timeout);
          timeout = window.setTimeout(() => {
            document.body.classList.remove('is-scrolling');
          }, 150);
        }
      }
    });
  });
</script>

<style>
  .process-visual :global(svg *) {
    animation-play-state: paused !important;
  }
  
  :global(body.is-scrolling) .process-visual :global(svg *) {
    animation-play-state: running !important;
  }

  .process-frost {
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    background: linear-gradient(
      to right,
      rgba(245, 240, 232, 0.97) 0%,
      rgba(245, 240, 232, 0.90) 30%,
      rgba(245, 240, 232, 0.55) 58%,
      rgba(245, 240, 232, 0.10) 78%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(to right, black 45%, transparent 85%);
    mask-image: linear-gradient(to right, black 45%, transparent 85%);
  }

  @media (max-height: 600px) {
    .process-desktop { display: none; }
    .process-mobile  { display: block; }
  }
</style>
