---
/*
  Process — Horizontal Scroll via GSAP
  Provides a cinematic, award-winning feel by converting vertical scroll into horizontal motion.
*/
import Eyebrow from '../ui/Eyebrow.astro';

const steps = [
  { num: '01', title: 'Discovery', body: 'We audit your existing digital presence, research your competitors, and map the exact gaps between where you are and where buyers expect you to be.' },
  { num: '02', title: 'Strategy', body: "Every engagement starts with a clear roadmap. We define what we're building, why, and exactly what success looks like — before a single pixel moves." },
  { num: '03', title: 'Execution', body: 'We build fast and iterate in the open. You see progress weekly. No surprises, no handoff delays.' },
  { num: '04', title: 'Delivery', body: "Launch isn't the finish line — it's the starting gun. We measure, optimize, and compound from day one." },
];
---

<section id="process-wrapper" class="process-desktop bg-[var(--cream)] overflow-hidden relative hidden md:block" style="color: var(--obsidian);">
  <div id="process-scroll-container" class="flex h-screen items-center w-max">
    
    <!-- Intro Panel -->
    <div class="w-screen h-full flex flex-col justify-center px-[5vw] shrink-0">
      <div class="max-w-3xl">
        <Eyebrow class="mb-8">HOW WE WORK //</Eyebrow>
        <h2 class="font-display text-[clamp(64px,8vw,120px)] leading-[0.9] tracking-tight text-[var(--obsidian)] mb-8">
          Structured.<br/>
          Transparent.<br/>
          <span class="italic text-[var(--gold-dim)]">Delivered.</span>
        </h2>
        <p class="font-body text-[var(--slate-600)] text-xl max-w-xl mb-4">
          No black boxes. No endless planning. A process that ships real work, every week.
        </p>
      </div>
    </div>

    <!-- Step Panels -->
    {steps.map((step, i) => (
      <div class="w-screen h-full flex flex-col justify-center px-[5vw] shrink-0 border-l border-[var(--gold)]/20 relative overflow-hidden group process-panel">
        
        <!-- Large background number -->
        <div class="absolute -right-20 -bottom-10 font-display text-[40vh] leading-none text-[var(--gold)] opacity-5 pointer-events-none select-none transition-transform duration-1000 group-hover:scale-110">
          {step.num}
        </div>

        <div class="max-w-4xl relative z-10 flex flex-col md:flex-row gap-12 md:gap-24 items-start md:items-center">
          <div class="font-mono text-[24px] text-[var(--gold)] border border-[var(--gold)] rounded-full w-24 h-24 flex items-center justify-center shrink-0">
            {step.num}
          </div>
          <div>
            <h3 class="font-display text-[48px] md:text-[80px] text-[var(--obsidian)] mb-8 leading-none tracking-tight">
              {step.title}
            </h3>
            <p class="font-body text-[20px] md:text-[24px] text-[var(--slate-600)] leading-relaxed max-w-2xl">
              {step.body}
            </p>
          </div>
        </div>
      </div>
    ))}
    
    <!-- Outro Spacer to allow smooth exit -->
    <div class="w-[20vw] h-full shrink-0"></div>

  </div>
</section>

<!-- Mobile Fallback (Vertical) -->
<section class="process-mobile bg-[var(--cream)] py-24 md:hidden" style="color: var(--obsidian);">
  <div class="section-container">
    <Eyebrow class="mb-6">HOW WE WORK //</Eyebrow>
    <h2 class="font-display text-[48px] leading-[1] text-[var(--obsidian)] mb-8">
      Structured.<br/>Transparent.<br/><span class="italic text-[var(--gold-dim)]">Delivered.</span>
    </h2>
    <p class="font-body text-[var(--slate-600)] text-lg max-w-xl mb-16">
      No black boxes. No endless planning. A process that ships real work, every week.
    </p>
    
    <div class="flex flex-col gap-16">
      {steps.map((step) => (
        <div class="relative border-l-2 border-[var(--gold)]/30 pl-8 pb-8">
          <div class="font-mono text-[14px] text-[var(--gold)] mb-4">{step.num}</div>
          <h3 class="font-display text-[36px] text-[var(--obsidian)] mb-4 leading-none">{step.title}</h3>
          <p class="font-body text-[16px] text-[var(--slate-600)] leading-relaxed">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initHorizontalScroll() {
    gsap.registerPlugin(ScrollTrigger);

    if (window.innerWidth < 768 || window.innerHeight <= 600) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const wrapper = document.getElementById('process-wrapper');
    const container = document.getElementById('process-scroll-container');
    if (!wrapper || !container) return;

    gsap.set(container, { x: 0 });

    gsap.to(container, {
      x: () => -(container.scrollWidth - window.innerWidth),
      ease: "none",
      scrollTrigger: {
        trigger: wrapper,
        pin: true,
        scrub: 1,
        end: () => "+=" + (container.scrollWidth - window.innerWidth),
        invalidateOnRefresh: true,
        anticipatePin: 1
      }
    });
  }

  document.addEventListener('astro:page-load', initHorizontalScroll);
</script>

<style>
  @media (max-height: 600px) {
    .process-desktop {
      display: none;
    }

    .process-mobile {
      display: block;
    }
  }
</style>
