---
/*
  CTA Takeover — Dramatic curtain effect
  Creates a massive sticky footer experience that pulls up from the bottom.
*/
---

<section id="cta-takeover" class="relative w-full bg-[var(--gold)] flex flex-col justify-between" style="min-height: 100vh; color: var(--obsidian);">
  
  <div class="cta-shell relative w-full max-w-[1320px] mx-auto px-[5vw] flex-grow flex flex-col justify-center">
    
    <div class="reveal max-w-5xl">
      <p class="font-mono text-[11px] text-[var(--obsidian)] opacity-50 uppercase tracking-[0.2em] mb-8">Ready to grow?</p>
      <h2 class="cta-headline font-display text-[clamp(56px,10vw,140px)] leading-[0.9] tracking-tight mb-6">
        <span class="cta-scramble-line" data-text="Tell us where">Tell us where</span><br/>
        <span class="cta-scramble-line italic opacity-80" data-text="you are today.">you are today.</span><br/>
        <span class="cta-scramble-line" data-text="We'll map the next 90.">We'll map the next 90.</span>
      </h2>
      <p class="font-body text-[var(--obsidian)] text-lg md:text-xl opacity-70 max-w-2xl mb-10 md:mb-12">
        Audit, roadmap, and first sprint — scoped to your business. Reply within one business day.
      </p>
      
      <div class="flex flex-col md:flex-row items-start md:items-center gap-8 md:gap-12 mt-12 md:mt-16">
        <a href="/contact/" class="group relative inline-flex items-center gap-6 font-display text-[28px] md:text-[44px] text-[var(--obsidian)] hover:opacity-70 transition-opacity" data-cta-zone="footer-cta" data-cta-role="primary">
          Get Your 90-Day Growth Plan
          <div class="w-14 h-14 md:w-16 md:h-16 rounded-full border-2 border-[var(--obsidian)] flex items-center justify-center group-hover:bg-[var(--obsidian)] group-hover:text-[var(--gold)] transition-colors duration-300">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>

        <div class="w-px h-16 bg-[var(--obsidian)] opacity-20 hidden md:block"></div>

        <a href="/work/" class="font-mono text-[13px] uppercase tracking-widest hover:opacity-70 transition-opacity" data-cta-zone="footer-cta" data-cta-role="secondary">
          See Case Studies
        </a>
      </div>
    </div>
    
  </div>

  <!-- Marquee -->
  <div class="w-full overflow-hidden border-t border-[var(--obsidian)]/10 py-5 mt-auto">
    <div class="flex items-center gap-12 animate-marquee-fast">
      {[1,2,3,4,5,6,7,8].map(() => (
        <span class="font-display italic text-[60px] md:text-[80px] leading-none opacity-[0.12] whitespace-nowrap select-none">Nexrena</span>
      ))}
    </div>
  </div>

</section>

<style>
  /* Optional: Make the section right above this have a z-index and shadow so the CTA looks like it's sliding underneath or pulling over */
  #cta-takeover {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
  }

  .cta-shell {
    padding-top: clamp(104px, 14vh, 144px);
    padding-bottom: clamp(64px, 9vh, 96px);
  }

  @media (max-height: 760px) {
    .cta-shell {
      padding-top: 88px;
      padding-bottom: 48px;
    }
  }

  @keyframes marquee-fast {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee-fast {
    animation: marquee-fast 20s linear infinite;
    width: max-content;
  }
</style>

<script>
  const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';

  function scrambleText(el: HTMLElement, finalText: string) {
    const len = finalText.length;
    let iteration = 0;
    const totalIterations = len * 3;
    const interval = setInterval(() => {
      el.textContent = finalText
        .split('')
        .map((char, i) => {
          if (i < iteration / 3) return finalText[i];
          return CHARS[Math.floor(Math.random() * CHARS.length)];
        })
        .join('');
      iteration++;
      if (iteration >= totalIterations) {
        el.textContent = finalText;
        clearInterval(interval);
      }
    }, 30);
  }

  function initCtaScramble() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const lines = document.querySelectorAll('.cta-scramble-line');
    if (!lines.length) return;

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const text = el.dataset.text || el.textContent || '';
          setTimeout(() => scrambleText(el, text), 200);
          obs.unobserve(el);
        }
      });
    }, { threshold: 0.5 });

    lines.forEach((line) => observer.observe(line));
  }

  document.addEventListener('astro:page-load', initCtaScramble);
</script>
