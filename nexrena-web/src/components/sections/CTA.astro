---
/*
  CTA Takeover — Dramatic curtain effect
  Creates a massive sticky footer experience that pulls up from the bottom.
*/
---

<section id="cta-takeover" class="relative w-full bg-[var(--gold)] flex flex-col justify-between" style="min-height: 100vh; color: var(--obsidian);">
  
  <div class="relative w-full max-w-[1320px] mx-auto px-[5vw] pt-32 pb-16 flex-grow flex flex-col justify-center">
    
    <div class="reveal max-w-5xl">
      <h2 class="font-display text-[clamp(64px,12vw,160px)] leading-[0.9] tracking-tight mb-12">
        Let's build<br/>
        <span class="italic text-[var(--obsidian)] opacity-80">something</span><br/>
        extraordinary.
      </h2>
      
      <div class="flex flex-col md:flex-row items-start md:items-center gap-12 mt-16">
        <a href="/contact" class="group relative inline-flex items-center gap-6 font-display text-[32px] md:text-[48px] text-[var(--obsidian)] hover:opacity-70 transition-opacity">
          Start a project
          <div class="w-16 h-16 rounded-full border border-[var(--obsidian)] flex items-center justify-center group-hover:bg-[var(--obsidian)] group-hover:text-[var(--gold)] transition-colors duration-300">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>

        <div class="w-px h-16 bg-[var(--obsidian)] opacity-20 hidden md:block"></div>

        <a href="mailto:hello@nexrena.com" class="font-mono text-[14px] uppercase tracking-widest hover:opacity-70 transition-opacity">
          hello@nexrena.com
        </a>
      </div>
    </div>
    
  </div>

  <!-- Massive Marquee at bottom -->
  <div class="w-full overflow-hidden border-t border-[var(--obsidian)]/10 py-6 mt-auto">
    <div class="flex items-center gap-16 animate-marquee-fast">
      {[1,2,3,4,5,6].map(() => (
        <span class="font-display italic text-[80px] leading-none opacity-20 whitespace-nowrap">Nexrena Digital Growth</span>
      ))}
    </div>
  </div>

</section>

<style>
  /* Optional: Make the section right above this have a z-index and shadow so the CTA looks like it's sliding underneath or pulling over */
  #cta-takeover {
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
  }

  @keyframes marquee-fast {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee-fast {
    animation: marquee-fast 20s linear infinite;
    width: max-content;
  }
</style>
