---
/* 8sleep-style trust badges — low-risk, clear value */
const badges = [
  'Free discovery call',
  'Weekly delivery',
  '100% retention',
];
---

<div class="trust-badges w-full py-5 md:py-6 bg-[var(--obsidian)] border-y border-[var(--slate-800)]">
  <div class="section-container flex flex-wrap justify-center md:justify-between items-center gap-8 md:gap-12">
    {badges.map((badge) => (
      <div class="flex items-center gap-3">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--gold)] shrink-0" aria-hidden="true"></span>
        <span class="font-mono text-[11px] text-[var(--slate-200)] uppercase tracking-widest">{badge}</span>
      </div>
    ))}
  </div>
</div>
