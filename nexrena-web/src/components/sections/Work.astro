---
import Eyebrow from '../ui/Eyebrow.astro';
import { projects } from '../../data/projects';
import { heroImages } from '../../data/hero-images';
---

<section id="work" class="bg-[var(--slate-900)] relative">
  <!-- Full-viewport intro moment (sticky feel) -->
  <div class="section-full section-container relative z-10 flex flex-col justify-center scroll-scale-up">
    <div class="reveal" style="--i: 0;">
      <Eyebrow class="mb-6">SELECTED WORK //</Eyebrow>
      <h2 class="text-h2 font-display text-[var(--warm-white)] max-w-2xl">
        Projects built to perform.
      </h2>
      <p class="mt-6 font-body text-[var(--slate-400)] text-lg max-w-xl">
        Growth infrastructure for companies that mean business.
      </p>
    </div>
  </div>

  <div class="section-container relative z-10">
    <!-- Horizontal scroll on desktop, grid on mobile -->
    <div class="work-scroll-container">
      {projects.map((project, i) => {
        const isLarge = i < 2;
        return (
          <a href={`/work/${project.id}`} class={`work-card group relative bg-[var(--slate-800)] p-8 md:p-12 flex flex-col justify-between overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl hover:shadow-black/30 reveal ${isLarge ? "work-card--large" : "work-card--small"}`} style={`--i: ${i};`}>
            
            <!-- Shimmer effect -->
            <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-[var(--slate-700)]/20 to-transparent group-hover:animate-[shimmer_1.5s_infinite] z-20 pointer-events-none"></div>
            
            <!-- Inner border overlay -->
            <div class="absolute inset-0 border border-transparent transition-colors duration-300 group-hover:border-[var(--gold)]/30 pointer-events-none z-20"></div>

            <!-- Hero object: singular focus per project field (factory, kitchen, house, cleaning) -->
            <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
              <img src={heroImages[`project/${project.id}` as keyof typeof heroImages] ?? heroImages.work} alt="" class="absolute inset-0 w-full h-full object-cover object-center opacity-60" aria-hidden="true" loading="lazy" />
            </div>

            <!-- Top Meta -->
            <div class="flex justify-between items-center relative z-10 w-full">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">
                0{i + 1} &nbsp;&nbsp; {project.category}
              </span>
              <span class="font-mono text-[10px] text-[var(--slate-400)]">{project.year}</span>
            </div>

            <!-- Middle Content -->
            <div class="relative z-10 my-auto">
              <h3 class="font-display text-[32px] md:text-[48px] text-[var(--warm-white)] mb-4 leading-none">
                {project.name}
              </h3>
              <p class="font-body text-[15px] text-[var(--slate-400)] max-w-sm">
                {project.tagline}
              </p>
            </div>

            <!-- Bottom Row -->
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative z-10 w-full">
              <div class="flex flex-wrap gap-2">
                {project.stack.slice(0, 3).map(tech => (
                  <span class="font-mono text-[10px] text-[var(--slate-400)] bg-[var(--obsidian)]/50 px-2 py-1 uppercase">
                    [{tech}]
                  </span>
                ))}
              </div>
              <span class="font-mono text-[11px] text-[var(--gold)] uppercase tracking-widest flex items-center gap-2 whitespace-nowrap">
                View project 
                <span class="transform transition-transform duration-300 group-hover:translate-x-2">&rarr;</span>
              </span>
            </div>

          </a>
        );
      })}
    </div>
    
    <div class="mt-16 text-center reveal" style="--i: 4;">
      <a href="/work" class="inline-block font-mono text-[11px] text-[var(--warm-white)] uppercase tracking-widest border border-[var(--slate-700)] px-8 py-4 hover:border-[var(--gold)] hover:text-[var(--gold)] transition-colors">
        View All Projects
      </a>
    </div>
  </div>
</section>

<style>
  .work-scroll-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .work-scroll-container {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 1.5rem;
      padding-bottom: 2rem;
      margin: 0 -5vw;
      padding-left: 5vw;
      padding-right: 5vw;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .work-scroll-container::-webkit-scrollbar {
      display: none;
    }
    .work-card {
      flex-shrink: 0;
      scroll-snap-align: start;
    }
    .work-card--large {
      min-width: min(420px, 38vw);
      height: 480px;
    }
    .work-card--small {
      min-width: min(360px, 32vw);
      height: 360px;
    }
  }
  .work-card {
    min-height: 400px;
  }
  @keyframes shimmer {
    100% { transform: translateX(100%); }
  }
</style>
