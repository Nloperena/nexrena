---
import Eyebrow from '../ui/Eyebrow.astro';
import WorkHeadingAccent from '../ui/WorkHeadingAccent.astro';
import { projects } from '../../data/projects';
import { heroImages } from '../../data/hero-images';
---

<section id="work" class="work-section bg-[var(--obsidian)] relative pt-32 pb-0 overflow-hidden">
  <WorkHeadingAccent class="work-heading-overlay absolute inset-0 w-full h-full pointer-events-none" />
  <div class="section-container relative z-10 flex flex-col justify-center mb-16 scroll-scale-up">
    <div class="reveal" style="--i: 0;">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 mb-6">
        <div>
          <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-4">Selected Work</p>
          <h2 class="font-display text-[clamp(64px,12vw,160px)] text-[var(--warm-white)] leading-[0.9] tracking-tight">
            Growth infrastructure for companies that mean business.
          </h2>
        </div>
        <a href="/work" class="font-mono text-[11px] text-[var(--warm-white)] uppercase tracking-widest border border-[var(--slate-700)] px-8 py-4 hover:border-[var(--gold)] hover:text-[var(--gold)] transition-colors rounded-full">
          View All Projects
        </a>
      </div>
    </div>
  </div>

  <!-- Full Bleed Grid -->
  <div class="w-full relative z-10">
    <div class="work-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0">
      {projects.map((project, i) => {
        // Vary heights to create a masonry-like feel
        const heightClass = i % 4 === 0 || i % 4 === 3 ? 'h-[56vh] md:h-[72vh]' : 'h-[46vh] md:h-[60vh]';
        // Some cards span 2 columns on desktop
        const colSpan = i === 0 || i === 3 ? 'md:col-span-2 lg:col-span-2' : 'col-span-1';

        return (
          <a href={`/work/${project.id}`} class={`work-card block relative bg-[var(--obsidian)] overflow-hidden group ${colSpan} ${heightClass}`}>
            
            <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
              <img src={heroImages[`project/${project.id}` as keyof typeof heroImages] ?? heroImages.work} alt="" class="work-image absolute inset-0 w-full h-full object-cover object-center opacity-60 group-hover:opacity-90 group-hover:scale-[1.03] transition-all duration-[1.4s] ease-[cubic-bezier(0.16,1,0.3,1)] filter grayscale-[20%] group-hover:grayscale-0" aria-hidden="true" loading="lazy" decoding="async" />
              <!-- Dark overlay that fades out on hover -->
              <div class="absolute inset-0 bg-[var(--obsidian)]/40 group-hover:bg-[var(--obsidian)]/10 transition-colors duration-700"></div>
              <!-- Gradient for text readability -->
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--obsidian)]/90 via-transparent to-transparent opacity-100 group-hover:opacity-80 transition-opacity duration-700"></div>
            </div>

            <!-- Content Container (Slides up on hover) -->
            <div class="absolute inset-0 p-8 md:p-12 flex flex-col justify-end z-10">
              <div class="transform translate-y-8 group-hover:translate-y-0 transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]">
                
                <div class="flex items-center gap-4 mb-4">
                  <span class="font-mono text-[10px] text-[var(--gold)] uppercase tracking-widest">
                    0{i + 1}
                  </span>
                  <span class="w-8 h-[1px] bg-[var(--slate-600)]"></span>
                  <span class="font-mono text-[10px] text-[var(--warm-white)] uppercase tracking-widest">
                    {project.category}
                  </span>
                </div>

                <h3 class="font-display text-[48px] md:text-[64px] lg:text-[80px] text-[var(--warm-white)] mb-4 leading-none tracking-tight">
                  {project.name}
                </h3>
                
                <div class="overflow-hidden">
                  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 transform translate-y-full opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-700 delay-100 ease-[cubic-bezier(0.16,1,0.3,1)]">
                    <p class="font-body text-[16px] md:text-[18px] text-[var(--slate-300)] max-w-md">
                      {project.tagline}
                    </p>
                    
                    <div class="w-12 h-12 rounded-full border border-[var(--gold)]/50 flex items-center justify-center text-[var(--gold)] group-hover:bg-[var(--gold)] group-hover:text-[var(--obsidian)] transition-colors duration-300 shrink-0">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                      </svg>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initWorkCards() {
    // Check if user prefers reduced motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion || window.innerWidth < 768) return;

    const cards = document.querySelectorAll('.work-card');
    
    cards.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        // Extreme rack focus effect for full-bleed grid
        gsap.to(cards, {
          opacity: (i, el) => el === card ? 1 : 0.3,
          filter: (i, el) => el === card ? 'blur(0px) grayscale(0%)' : 'blur(4px) grayscale(80%)',
          duration: 0.8,
          ease: 'power3.out',
          overwrite: 'auto'
        });
      });
      
      card.addEventListener('mouseleave', () => {
        // Restore all cards
        gsap.to(cards, {
          opacity: 1,
          filter: 'blur(0px) grayscale(0%)',
          duration: 0.8,
          ease: 'power3.out',
          overwrite: 'auto'
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initWorkCards);
</script>

<style>
  .work-heading-overlay {
    z-index: 5;
    object-fit: cover;
    object-position: right top;
    mix-blend-mode: normal;
    opacity: 0.9;
  }

  @media (max-height: 760px) {
    .work-section {
      padding-top: 96px;
    }
  }

  @media (max-width: 767px) {
    .work-heading-overlay {
      opacity: 0.82;
    }
  }
</style>
