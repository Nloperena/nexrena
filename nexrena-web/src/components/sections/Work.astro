---
import Eyebrow from '../ui/Eyebrow.astro';
import { projects } from '../../data/projects';
import { heroImages } from '../../data/hero-images';
---

<section id="work" class="bg-[var(--slate-900)] relative py-24 md:py-32 overflow-hidden">
  <div class="section-container relative z-10 flex flex-col justify-center mb-16 scroll-scale-up">
    <div class="reveal" style="--i: 0;">
      <Eyebrow class="mb-6">SELECTED WORK //</Eyebrow>
      <h2 class="text-h2 font-display text-[var(--warm-white)] max-w-2xl">
        Projects built to perform.
      </h2>
      <p class="mt-6 font-body text-[var(--slate-400)] text-lg max-w-xl">
        Growth infrastructure for companies that mean business.
      </p>
    </div>
  </div>

  <div class="section-container relative z-10">
    <div class="work-grid grid grid-cols-1 md:grid-cols-12 gap-6">
      {projects.map((project, i) => {
        // First project full width, next two 50%, next full width...
        const colSpan = i === 0 ? 'md:col-span-12' : i % 3 === 0 ? 'md:col-span-12' : 'md:col-span-6';
        const heightClass = i === 0 || i % 3 === 0 ? 'h-[500px] md:h-[600px]' : 'h-[400px] md:h-[500px]';
        const metric = project.proofPoints?.[0]?.metric;

        return (
          <a href={`/work/${project.id}`} class={`work-card block relative bg-[var(--slate-800)] overflow-hidden group reveal ${colSpan} ${heightClass}`} style={`--i: ${i};`}>
            
            <div class="absolute inset-0 pointer-events-none overflow-hidden z-0">
              <img src={heroImages[`project/${project.id}` as keyof typeof heroImages] ?? heroImages.work} alt="" class="work-image absolute inset-0 w-full h-full object-cover object-center opacity-50 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]" aria-hidden="true" loading={i < 2 ? "eager" : "lazy"} />
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--obsidian)]/90 via-[var(--obsidian)]/30 to-transparent"></div>
            </div>

            <!-- Content Container -->
            <div class="absolute inset-0 p-8 md:p-12 flex flex-col justify-between z-10">
              <!-- Top -->
              <div class="flex justify-between items-start">
                <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest bg-[var(--obsidian)]/50 backdrop-blur-md px-3 py-1 border border-[var(--slate-700)]">
                  0{i + 1} &nbsp; {project.category}
                </span>
                
                {metric && (
                  <span class="font-mono text-[11px] text-[var(--warm-white)] bg-[var(--gold)]/20 backdrop-blur-md border border-[var(--gold)]/50 px-3 py-1">
                    {metric}
                  </span>
                )}
              </div>

              <!-- Bottom -->
              <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
                <h3 class="font-display text-[40px] md:text-[56px] text-[var(--warm-white)] mb-4 leading-none">
                  {project.name}
                </h3>
                
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6">
                  <p class="font-body text-[16px] text-[var(--slate-300)] max-w-md opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                    {project.tagline}
                  </p>
                  
                  <span class="font-mono text-[11px] text-[var(--gold)] uppercase tracking-widest flex items-center gap-2 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-all duration-500 delay-200">
                    View project <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
                  </span>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
    
    <div class="mt-20 text-center reveal" style="--i: 4;">
      <a href="/work" class="inline-block font-mono text-[11px] text-[var(--warm-white)] uppercase tracking-widest border border-[var(--slate-700)] px-8 py-4 hover:border-[var(--gold)] hover:text-[var(--gold)] transition-colors">
        View All Projects
      </a>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initWorkCards() {
    // Check if user prefers reduced motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion || window.innerWidth < 768) return;

    const cards = document.querySelectorAll('.work-card');
    
    cards.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        // Rack focus effect: dim and shrink other cards slightly
        gsap.to(cards, {
          scale: (i, el) => el === card ? 1 : 0.98,
          opacity: (i, el) => el === card ? 1 : 0.6,
          filter: (i, el) => el === card ? 'blur(0px)' : 'blur(2px)',
          duration: 0.5,
          ease: 'power2.out',
          overwrite: 'auto'
        });
      });
      
      card.addEventListener('mouseleave', () => {
        // Restore all cards
        gsap.to(cards, {
          scale: 1,
          opacity: 1,
          filter: 'blur(0px)',
          duration: 0.5,
          ease: 'power2.out',
          overwrite: 'auto'
        });
      });
    });
  }

  initWorkCards();
  document.addEventListener('astro:page-load', initWorkCards);
</script>
