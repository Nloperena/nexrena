---
import Button from '../ui/Button.astro';
import Eyebrow from '../ui/Eyebrow.astro';
---

<section class="relative min-h-screen bg-[var(--obsidian)] grain flex flex-col justify-center overflow-hidden">
  
    <!-- Architectural Grid Background -->
  <div class="absolute inset-0 pointer-events-none z-0 opacity-40 flex items-center justify-center overflow-hidden">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="var(--color-slate-800)" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" style="transform: perspective(500px) rotateX(60deg) scale(2); transform-origin: top;" />
    </svg>
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--obsidian)] via-transparent to-[var(--obsidian)]"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--obsidian)] via-transparent to-[var(--obsidian)]"></div>
  </div>

  <div class="section-container relative z-10 w-full">
    <!-- Top Left Label -->
    <div class="absolute top-8 left-[5vw]">
      <Eyebrow>NEXRENA DIGITAL GROWTH AGENCY — EST. 2025 — ORLANDO, FL</Eyebrow>
    </div>

    <!-- Headline -->
    <div class="max-w-[1000px] mb-8 relative">
      <h1 class="font-display text-[var(--warm-white)] flex flex-col font-light text-[clamp(72px,10vw,140px)] leading-[0.9]">
        <span class="hero-line block" style="clip-path: inset(0 0 100% 0);">Growth</span>
        <span class="hero-line block relative pb-4" style="clip-path: inset(0 0 100% 0);">
          infrastructure.
          <span class="absolute bottom-0 left-0 w-32 md:w-48 h-[2px] bg-[var(--gold)]"></span>
        </span>
      </h1>
    </div>

    <!-- Subheadline -->
    <p class="hero-sub text-[var(--slate-200)] text-[18px] max-w-[580px] font-body font-light mb-12 opacity-0 translate-y-4">
      We build the digital engines for companies that mean business. Precision engineering meets strategic growth.
    </p>

    <!-- CTA Row -->
    <div class="hero-cta flex flex-wrap items-center gap-6 opacity-0 translate-y-4">
      <Button href="/contact" variant="primary">Start a Project &rarr;</Button>
      <a href="/work" class="group flex items-center gap-2 font-mono text-[11px] text-[var(--gold)] tracking-widest uppercase hover:text-[var(--gold-light)] transition-colors">
        View Our Work
        <span class="transform transition-transform group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>

    <!-- Bottom Right Stat Block -->
    <div class="absolute bottom-24 right-[5vw] hidden md:flex flex-col border-l border-[var(--slate-700)] pl-4 gap-4">
      <div class="flex flex-col">
        <span class="font-mono text-[var(--gold)] text-[14px]">04</span>
        <span class="font-mono text-[var(--slate-400)] text-[10px] uppercase tracking-widest">Projects Delivered</span>
      </div>
      <div class="w-8 h-[1px] bg-[var(--slate-700)]"></div>
      <div class="flex flex-col">
        <span class="font-mono text-[var(--gold)] text-[14px]">3</span>
        <span class="font-mono text-[var(--slate-400)] text-[10px] uppercase tracking-widest">Industry Verticals</span>
      </div>
      <div class="w-8 h-[1px] bg-[var(--slate-700)]"></div>
      <div class="flex flex-col">
        <span class="font-mono text-[var(--gold)] text-[14px]">100%</span>
        <span class="font-mono text-[var(--slate-400)] text-[10px] uppercase tracking-widest">Client Retention</span>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3">
      <span class="font-mono text-[9px] text-[var(--gold-dim)] tracking-widest uppercase">Scroll</span>
      <div class="w-[1px] h-12 bg-[var(--slate-800)] relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1/2 bg-[var(--gold)] animate-scroll-indicator"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-line {
    animation: clipUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-line:nth-child(1) { animation-delay: 0.1s; }
  .hero-line:nth-child(2) { animation-delay: 0.22s; }

  .hero-sub {
    animation: fadeUpHero 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.42s;
  }
  
  .hero-cta {
    animation: fadeUpHero 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.62s;
  }

  @keyframes clipUp {
    0% { clip-path: inset(0 0 100% 0); transform: translateY(20px); }
    100% { clip-path: inset(0 0 0% 0); transform: translateY(0); }
  }

  @keyframes fadeUpHero {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  @keyframes scrollIndicator {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
  .animate-scroll-indicator {
    animation: scrollIndicator 1.5s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }
</style>
