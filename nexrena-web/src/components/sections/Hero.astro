---
import Button from '../ui/Button.astro';
---

<section class="hero relative isolate min-h-[100svh] overflow-hidden">
  <img
    src="/images/hero-growth-bar.svg"
    alt=""
    class="hero-bg absolute inset-0 z-0 h-full w-full object-cover object-center"
    aria-hidden="true"
    loading="eager"
    fetchpriority="high"
  />

  <div class="hero-overlay absolute inset-0 z-10" aria-hidden="true"></div>

  <div class="hero-inner section-container relative z-20 flex min-h-[100svh] items-center py-28">
    <div class="hero-content max-w-[880px]">
      <p class="hero-kicker font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--gold)]">
        Orlando web design + SEO
      </p>

      <h1 class="hero-title mt-4 font-display leading-[0.92] text-[var(--warm-white)]">
        Websites that turn traffic into booked calls.
      </h1>

      <p class="hero-subtitle mt-6 max-w-[760px] font-body text-[clamp(19px,2.15vw,28px)] leading-[1.35] text-[var(--slate-100)]">
        We build conversion-focused websites for growth-minded teams. Clear messaging, cleaner UX, and strong SEO from day one.
      </p>

      <p class="hero-proof mt-6 max-w-[660px] font-body text-[16px] leading-[1.65] text-[var(--slate-300)]">
        Built by an operator with 7+ years in-house experience across manufacturing, ecommerce, and real estate.
      </p>

      <div class="hero-cta mt-10 flex flex-wrap items-center gap-4">
        <Button href="/contact/" variant="primary" class="!h-14 !px-10 !text-[12px]" data-cta-zone="hero" data-cta-role="primary">
          Get Your 90-Day Growth Plan
        </Button>
        <a
          href="/work/"
          class="inline-flex h-14 items-center justify-center rounded-full border border-[var(--slate-500)] px-8 font-mono text-[12px] uppercase tracking-widest text-[var(--warm-white)] transition-colors hover:border-[var(--gold)] hover:text-[var(--gold)] focus-visible:ring-2 focus-visible:ring-[var(--gold)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--obsidian)]"
          data-cta-zone="hero"
          data-cta-role="secondary"
        >
          See Case Studies
        </a>
      </div>

      <ul class="hero-signals mt-10 flex flex-wrap gap-x-8 gap-y-3">
        <li class="font-mono text-[10px] uppercase tracking-widest text-[var(--slate-300)]">No templates</li>
        <li class="font-mono text-[10px] uppercase tracking-widest text-[var(--slate-300)]">No fluff copy</li>
        <li class="font-mono text-[10px] uppercase tracking-widest text-[var(--slate-300)]">Built to convert</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--obsidian);
  }

  .hero-bg {
    opacity: 0.58;
  }

  .hero-overlay {
    background:
      radial-gradient(circle at 72% 34%, rgba(201, 169, 110, 0.12), transparent 42%),
      linear-gradient(180deg, rgba(12, 15, 18, 0.34) 0%, rgba(12, 15, 18, 0.74) 56%, rgba(12, 15, 18, 0.92) 100%);
  }

  .hero-title {
    font-size: clamp(52px, 8vw, 126px);
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .hero-content {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .hero-content.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 767px) {
    .hero-inner {
      padding-top: 120px;
      padding-bottom: 72px;
      align-items: flex-end;
    }

    .hero-bg {
      opacity: 0.5;
    }

    .hero-title {
      font-size: clamp(44px, 15vw, 70px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-content {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initHero() {
    const content = document.querySelector('.hero-content');
    if (!content) return;
    requestAnimationFrame(() => content.classList.add('is-active'));
  }

  document.addEventListener('astro:page-load', initHero);
</script>
