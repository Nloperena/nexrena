---
/*
  Hero — Premium app-style (Netflix-inspired)
  Full-bleed cinematic background, bottom gradient overlay,
  lower-third content, minimal UI.
*/
import Button from '../ui/Button.astro';
---

<section class="hero-app relative min-h-screen flex flex-col justify-end overflow-hidden">
  <!-- Full-bleed background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero-home.webp"
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-center"
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Netflix-style bottom gradient overlay -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-[var(--obsidian)] via-[var(--obsidian)]/60 via-40% to-transparent"
      aria-hidden="true"
    ></div>
    <!-- Subtle vignette -->
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(12,15,18,0.4)_100%)]"
      aria-hidden="true"
    ></div>
  </div>

  <!-- Content: lower-third layout -->
  <div class="relative z-10 w-full max-w-[1320px] mx-auto px-5vw pb-[12vh] md:pb-[14vh] pt-32">
    <!-- Eyebrow -->
    <p class="hero-eyebrow font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6 opacity-0">
      Digital Growth Agency · Orlando, FL
    </p>

    <!-- Headline -->
    <h1 class="hero-title font-display text-[var(--warm-white)] font-light leading-[0.95] tracking-tight opacity-0 max-w-4xl">
      <span class="block text-[clamp(48px,8vw,96px)] md:text-[clamp(64px,10vw,120px)]">Growth</span>
      <span class="block text-[clamp(48px,8vw,96px)] md:text-[clamp(64px,10vw,120px)] text-[var(--gold)]">infrastructure.</span>
    </h1>

    <!-- Tagline -->
    <p class="hero-tagline text-[var(--slate-200)] text-base md:text-lg font-light max-w-md mt-6 mb-10 opacity-0">
      We build the digital engine. You run the business.
    </p>

    <!-- CTA row -->
    <div class="hero-cta flex flex-wrap items-center gap-4 opacity-0">
      <Button href="/contact" variant="primary" class="!rounded-full !h-12 !px-8">
        Start a Project
      </Button>
      <a
        href="/work"
        class="hero-cta-secondary group inline-flex items-center gap-2 font-mono text-[11px] text-[var(--slate-200)] tracking-widest uppercase py-3 px-6 rounded-full border border-[var(--slate-600)] hover:border-[var(--gold)] hover:text-[var(--gold)] transition-all duration-300"
      >
        View Our Work
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>

    <!-- Stats bar (subtle, app-style) -->
    <div class="hero-stats flex items-center gap-8 mt-14 pt-8 border-t border-[var(--slate-800)]/60 opacity-0">
      <div class="flex items-baseline gap-2">
        <span class="font-display text-[28px] text-[var(--gold)] font-light">04</span>
        <span class="font-mono text-[10px] text-[var(--slate-500)] uppercase tracking-wider">Projects</span>
      </div>
      <div class="w-px h-6 bg-[var(--slate-700)]"></div>
      <div class="flex items-baseline gap-2">
        <span class="font-display text-[28px] text-[var(--gold)] font-light">3</span>
        <span class="font-mono text-[10px] text-[var(--slate-500)] uppercase tracking-wider">Verticals</span>
      </div>
      <div class="w-px h-6 bg-[var(--slate-700)]"></div>
      <div class="flex items-baseline gap-2">
        <span class="font-display text-[28px] text-[var(--gold)] font-light">100%</span>
        <span class="font-mono text-[10px] text-[var(--slate-500)] uppercase tracking-wider">Retention</span>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-60">
    <span class="font-mono text-[9px] text-[var(--slate-400)] tracking-widest uppercase">Scroll</span>
    <div class="w-px h-8 bg-[var(--slate-600)] rounded-full overflow-hidden">
      <div class="w-full h-1/2 bg-[var(--gold)]/60 animate-scroll-pulse rounded-full"></div>
    </div>
  </div>
</section>

<style>
  .hero-app {
    background-color: var(--obsidian);
  }

  .hero-eyebrow {
    animation: heroFadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }
  .hero-title {
    animation: heroFadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }
  .hero-tagline {
    animation: heroFadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }
  .hero-cta {
    animation: heroFadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }
  .hero-stats {
    animation: heroFadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.65s forwards;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scrollPulse {
    0%, 100% {
      transform: translateY(-100%);
      opacity: 0.5;
    }
    50% {
      transform: translateY(100%);
      opacity: 1;
    }
  }
  .animate-scroll-pulse {
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .hero-title,
    .hero-tagline,
    .hero-cta,
    .hero-stats {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .animate-scroll-pulse {
      animation: none;
    }
  }
</style>
