---
/*
  Testimonials — Scroll-driven massive typography
  Replaces the generic slider with a pinned sequence.
*/
const testimonials = [
  {
    quote: "Literally the best single website contact in the history of the company.",
    author: "Forzabuilt Leadership",
    role: "Industrial Adhesives · B2B Manufacturing"
  },
  {
    quote: "Nexrena didn't just build us a website — they built us a lead generation machine.",
    author: "VITO Fryfilter Team",
    role: "Global Commercial Equipment · E-Commerce"
  },
  {
    quote: "The new procurement flow removed constant back-and-forth and accelerated quote velocity.",
    author: "Furniture Packages USA",
    role: "Real Estate Procurement · B2B Platform"
  }
];
---

<section id="testimonials-scroll" class="relative w-full bg-[var(--obsidian)]" style="height: 400vh;">
  <div class="sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden">
    
    <!-- Background element -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(201,169,110,0.03)_0%,transparent_70%)] pointer-events-none"></div>

    <div class="absolute top-24 left-[5vw]">
      <span class="font-mono text-[11px] text-[var(--gold)] uppercase tracking-widest">CLIENT VOICES //</span>
    </div>

    <!-- Massive Quote Mark -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-display text-[60vh] text-[var(--slate-800)] opacity-30 leading-none select-none pointer-events-none z-0">
      "
    </div>

    <div class="relative z-10 w-full max-w-[1320px] mx-auto px-[5vw] h-full flex items-center justify-center">
      {testimonials.map((test, i) => (
        <div class={`testimonial-item absolute w-full max-w-5xl text-center px-4 ${i !== 0 ? 'opacity-0 translate-y-24' : ''}`}>
          <h3 class="font-display italic text-[clamp(32px,6vw,80px)] leading-[1.1] text-[var(--warm-white)] tracking-tight mb-12">
            {test.quote}
          </h3>
          <div class="flex flex-col items-center justify-center gap-2 transform translate-y-8 opacity-0 test-author">
            <div class="w-px h-12 bg-[var(--gold)] mb-4"></div>
            <span class="font-mono text-[12px] text-[var(--gold)] uppercase tracking-[0.2em]">{test.author}</span>
            <span class="font-body text-[14px] text-[var(--slate-400)]">{test.role}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Progress dots -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-20 flex items-center gap-3" aria-label="Testimonial progress">
      {testimonials.map((_, i) => (
        <div class={`test-dot w-2 h-2 rounded-full transition-all duration-500 ${i === 0 ? 'bg-[var(--gold)] w-8' : 'bg-[var(--slate-600)]'}`} data-index={i}></div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initTestimonials() {
    gsap.registerPlugin(ScrollTrigger);

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const wrapper = document.getElementById('testimonials-scroll');
    if (!wrapper) return;

    const items = gsap.utils.toArray('.testimonial-item') as HTMLElement[];
    
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: wrapper,
        start: "top top",
        end: "bottom bottom",
        scrub: 1,
      }
    });

    const dots = gsap.utils.toArray('.test-dot') as HTMLElement[];

    function setActiveDot(activeIndex: number) {
      dots.forEach((dot, i) => {
        if (i === activeIndex) {
          dot.style.backgroundColor = 'var(--gold)';
          dot.style.width = '2rem';
        } else {
          dot.style.backgroundColor = 'var(--slate-600)';
          dot.style.width = '0.5rem';
        }
      });
    }

    items.forEach((item, i) => {
      const author = item.querySelector('.test-author');

      if (i !== 0) {
        tl.to(item, {
          y: 0,
          opacity: 1,
          duration: 1,
          ease: "power2.out",
          onStart: () => setActiveDot(i),
        });
      }

      tl.to(author, {
        y: 0,
        opacity: 1,
        duration: 0.5
      });

      tl.to({}, { duration: 1.5 });

      if (i !== items.length - 1) {
        tl.to(item, {
          y: -50,
          opacity: 0,
          filter: "blur(10px)",
          duration: 1,
          ease: "power2.in"
        });
      }
    });
  }

  document.addEventListener('astro:page-load', initTestimonials);
</script>