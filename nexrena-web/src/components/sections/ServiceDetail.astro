---
import Eyebrow from '../ui/Eyebrow.astro';
import Button from '../ui/Button.astro';
import type { Service } from '../../data/services';

interface Props {
  service: Service;
  variant: 'dark' | 'light';
  index: number;
}

const { service, variant, index } = Astro.props;
const isDark = variant === 'dark';

---

<section id={service.id} class={`py-24 md:py-32 relative overflow-hidden scroll-mt-20 ${isDark ? 'bg-[var(--obsidian)]' : 'bg-[var(--cream)]'}`}>
  <!-- Background numeral -->
  <div class={`absolute right-4 md:right-12 bottom-0 font-display text-[180px] md:text-[280px] font-light leading-none select-none pointer-events-none ${isDark ? 'text-[var(--gold-dim)] opacity-[0.06]' : 'text-[var(--obsidian)] opacity-[0.04]'}`} aria-hidden="true">
    {service.number}
  </div>

  <div class="section-container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <!-- Left: Title + Intro -->
      <div class="lg:col-span-5">
        <Eyebrow class={`mb-6 ${isDark ? 'text-[var(--gold-dim)]' : 'text-[var(--gold-dim)]'}`}>
          {service.number} / {service.id.replace(/-/g, ' ')}
        </Eyebrow>
        
        <h2 class={`font-display text-[40px] md:text-[56px] leading-[1.1] font-light mb-8 reveal ${isDark ? 'text-[var(--warm-white)]' : 'text-[var(--obsidian)]'}`} style="--i: 1;">
          <span class="whitespace-pre-line">{service.title}</span>
        </h2>
        
        <p class={`font-body text-[17px] leading-relaxed mb-12 reveal ${isDark ? 'text-[var(--slate-300)]' : 'text-[var(--slate-600)]'}`} style="--i: 2;">
          {service.intro}
        </p>

        <!-- Ideal for -->
        <div class="mb-12 reveal" style="--i: 3;">
          <h4 class={`font-mono text-[10px] tracking-widest uppercase mb-4 ${isDark ? 'text-[var(--gold-dim)]' : 'text-[var(--gold-dim)]'}`}>
            Ideal for
          </h4>
          <ul class="space-y-3">
            {service.idealFor.map((item, i) => (
              <li class={`flex items-start gap-3 font-body text-[15px] ${isDark ? 'text-[var(--slate-300)]' : 'text-[var(--slate-600)]'}`}>
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--gold)] shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Process hook -->
        <div class={`p-4 border-l-2 border-[var(--gold)] reveal ${isDark ? 'border-[var(--gold)]' : ''}`} style="--i: 4;">
          <p class={`font-mono text-[12px] tracking-wide ${isDark ? 'text-[var(--gold-light)]' : 'text-[var(--gold-dim)]'}`}>
            {service.processHook}
          </p>
        </div>

        <div class="mt-10 reveal" style="--i: 5;">
          <Button href="/contact" variant={isDark ? 'outline' : 'primary'} class="w-full sm:w-auto">
            {service.cta.label} &rarr;
          </Button>
          <p class={`mt-3 font-mono text-[10px] tracking-wider ${isDark ? 'text-[var(--slate-500)]' : 'text-[var(--slate-600)]'}`}>
            {service.cta.helper}
          </p>
        </div>
      </div>

      <!-- Right: Deliverables + Outcomes -->
      <div class={`lg:col-span-7 lg:pl-12 border-t lg:border-t-0 lg:border-l pt-12 lg:pt-0 lg:pl-12 ${isDark ? 'border-[var(--slate-700)]' : 'border-[var(--slate-200)]'}`}>
        
        <!-- Deliverables -->
        <div class="mb-16 reveal" style="--i: 2;">
          <h4 class={`font-mono text-[10px] tracking-widest uppercase mb-6 ${isDark ? 'text-[var(--gold)]' : 'text-[var(--gold-dim)]'}`}>
            What you get
          </h4>
          <ul class="space-y-4">
            {service.deliverables.map((item) => (
              <li class={`flex gap-4 font-body text-[16px] leading-relaxed ${isDark ? 'text-[var(--slate-200)]' : 'text-[var(--slate-600)]'}`}>
                <svg class="mt-1 shrink-0 w-5 h-5 text-[var(--gold)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Outcomes -->
        <div class="reveal" style="--i: 3;">
          <h4 class={`font-mono text-[10px] tracking-widest uppercase mb-6 ${isDark ? 'text-[var(--gold)]' : 'text-[var(--gold-dim)]'}`}>
            Typical outcomes
          </h4>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            {service.outcomes.map((outcome) => (
              <div class={`p-6 rounded-sm border ${isDark ? 'border-[var(--slate-700)] bg-[var(--slate-900)]' : 'border-[var(--slate-200)] bg-[var(--warm-white)]'}`}>
                <p class="font-display text-[28px] md:text-[32px] font-light text-[var(--gold)] mb-2">
                  {outcome.metric}
                </p>
                <p class={`font-body text-[13px] ${isDark ? 'text-[var(--slate-400)]' : 'text-[var(--slate-600)]'}`}>
                  {outcome.detail}
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mt-12 reveal" style="--i: 4;">
          {service.tags.map((tag) => (
            <span class={`font-mono text-[10px] px-2.5 py-1 uppercase tracking-wider border ${isDark ? 'text-[var(--slate-400)] border-[var(--slate-700)]' : 'text-[var(--slate-600)] border-[var(--slate-200)]'}`}>
              {tag}
            </span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
