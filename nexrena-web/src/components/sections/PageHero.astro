---
import Eyebrow from '../ui/Eyebrow.astro';

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  image?: string;
  variant?: 'full' | 'short';
}

const { eyebrow, title, subtitle, image = '/images/hero-home.webp', variant = 'short' } = Astro.props;
const isFull = variant === 'full';
---

<section class={`page-hero relative bg-[var(--obsidian)] overflow-hidden flex flex-col justify-center ${isFull ? 'min-h-[85vh] py-24 md:py-32' : 'py-24 md:py-32'} grain`}>
  <!-- Background with parallax -->
  <div class="absolute inset-0 pointer-events-none z-0">
    <img 
      src={image} 
      alt="" 
      class="page-hero-bg absolute inset-0 w-full h-full object-cover object-center opacity-40 will-change-transform" 
      aria-hidden="true" 
      loading="eager" 
    />
    <div class="absolute inset-0 opacity-[0.12]" style="background-image: radial-gradient(var(--gold) 0.5px, transparent 0.5px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--obsidian)] via-transparent to-[var(--obsidian)]"></div>
  </div>

  <div class="section-container relative z-10 ph-content">
    <div class="page-hero-eyebrow">
      <Eyebrow class="mb-8">{eyebrow}</Eyebrow>
    </div>
    <h1 class="page-hero-title font-display text-[48px] md:text-[72px] text-[var(--warm-white)] leading-[1.1] font-light max-w-3xl mb-8">
      {title}
    </h1>
    {subtitle && (
      <p class="page-hero-sub font-body text-[18px] text-[var(--slate-300)] max-w-2xl">
        {subtitle}
      </p>
    )}
    <slot />
  </div>
</section>

<style>
  /* Elements start hidden; .is-active triggers animations after view transition */
  .page-hero-eyebrow {
    opacity: 0;
    transform: translateY(12px);
  }
  .page-hero-title {
    opacity: 0;
    clip-path: inset(0 0 100% 0);
    transform: translateY(30px);
  }
  .page-hero-sub {
    opacity: 0;
    transform: translateY(16px);
  }

  .ph-content.is-active .page-hero-eyebrow {
    animation: phEyebrow 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .ph-content.is-active .page-hero-title {
    animation: phTitleReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.12s forwards;
  }
  .ph-content.is-active .page-hero-sub {
    animation: phSubtitle 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.35s forwards;
  }

  @keyframes phEyebrow {
    from { opacity: 0; transform: translateY(12px); letter-spacing: 0.3em; }
    to   { opacity: 1; transform: translateY(0); letter-spacing: 0.1em; }
  }

  @keyframes phTitleReveal {
    from { opacity: 0; clip-path: inset(0 0 100% 0); transform: translateY(30px); }
    to   { opacity: 1; clip-path: inset(0 0 0% 0); transform: translateY(0); }
  }

  @keyframes phSubtitle {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-hero-eyebrow, .page-hero-title, .page-hero-sub {
      animation: none !important;
      opacity: 1 !important;
      clip-path: none !important;
      transform: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initPageHero() {
    gsap.registerPlugin(ScrollTrigger);

    const content = document.querySelector('.ph-content');
    if (content) {
      requestAnimationFrame(() => content.classList.add('is-active'));
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const hero = document.querySelector('.page-hero');
    const bg = document.querySelector('.page-hero-bg');
    if (!hero || !bg) return;

    gsap.to(bg, {
      yPercent: 20,
      ease: 'none',
      scrollTrigger: {
        trigger: hero,
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
    });
  }

  document.addEventListener('astro:page-load', initPageHero);
</script>
