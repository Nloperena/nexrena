---
/*
  StorySequence — Merges Manifesto, About, and TrustSignals into a single cinematic scroll journey.
  Background transitions from dark to light, typography scales and shifts.
*/
import Eyebrow from '../ui/Eyebrow.astro';

const stats = [
  { value: 4, suffix: '', label: 'Projects Delivered' },
  { value: 3, suffix: '', label: 'Industry Verticals' },
  { value: 100, suffix: '%', label: 'Client Retention' },
];
---

<section id="story-sequence" class="relative w-full h-[400vh] bg-[var(--obsidian)]" style="color: var(--warm-white);">
  <div class="story-pin sticky top-0 h-screen w-full overflow-hidden flex flex-col justify-center">
    
    <!-- Background Layer (Animates to Cream) -->
    <div class="story-bg absolute inset-0 bg-[var(--obsidian)] z-0"></div>

    <!-- Central Interactive Element (e.g. a rotating orb or "engine") -->
    <div class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none overflow-hidden">
      <div class="story-engine w-[40vw] h-[40vw] max-w-[600px] max-h-[600px] border border-[var(--gold)]/20 rounded-full flex items-center justify-center opacity-0 scale-50">
        <div class="w-[70%] h-[70%] border border-[var(--gold)]/40 rounded-full flex items-center justify-center story-engine-inner">
          <div class="w-[40%] h-[40%] bg-[var(--gold)]/10 rounded-full blur-xl"></div>
        </div>
      </div>
    </div>

    <div class="relative z-10 w-full max-w-[1320px] mx-auto px-[5vw]">
      
      <!-- Scene 1: The Engine -->
      <div class="scene scene-1 absolute top-1/2 left-[5vw] -translate-y-1/2 w-[90vw] max-w-5xl">
        <Eyebrow class="mb-8 text-[var(--gold)]">PHILOSOPHY //</Eyebrow>
        <h2 class="font-display text-[clamp(48px,8vw,120px)] leading-[0.9] tracking-tight">
          We build the<br/>
          <span class="italic text-[var(--gold)]">digital engine.</span>
        </h2>
      </div>

      <!-- Scene 2: The Business (Dark text, background will be cream) -->
      <div class="scene scene-2 absolute top-1/2 right-[5vw] -translate-y-1/2 w-[90vw] max-w-5xl text-right opacity-0 translate-y-12">
        <h2 class="font-display text-[clamp(48px,8vw,120px)] leading-[0.9] tracking-tight text-[var(--obsidian)]">
          You run the<br/>
          <span class="italic text-[var(--gold-dim)]">business.</span>
        </h2>
        <p class="font-body text-[18px] md:text-[24px] text-[var(--slate-600)] mt-8 max-w-xl ml-auto">
          Nexrena partners with mid-size companies to build digital infrastructure that performs — websites that convert, search strategies that compound.
        </p>
      </div>

      <!-- Scene 3: The Proof (Stats) -->
      <div class="scene scene-3 absolute top-1/2 left-[5vw] right-[5vw] -translate-y-1/2 opacity-0 scale-95">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-0 text-center">
          {stats.map((stat, i) => (
            <div class="md:border-r md:border-[var(--slate-300)] md:last:border-r-0">
              <div class="font-display text-[clamp(80px,15vw,200px)] font-light text-[var(--obsidian)] leading-none tracking-tighter mb-4">
                {stat.value}{stat.suffix}
              </div>
              <p class="font-mono text-[11px] text-[var(--slate-500)] uppercase tracking-[0.2em]">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initStorySequence() {
    gsap.registerPlugin(ScrollTrigger);

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const sequence = document.getElementById('story-sequence');
    if (!sequence) return;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: sequence,
        start: "top top",
        end: "bottom bottom",
        scrub: 1,
      }
    });

    // Animate Scene 1 out
    tl.to('.scene-1', {
      yPercent: -50,
      opacity: 0,
      filter: "blur(10px)",
      duration: 1
    })

    // Bring in the "Engine" graphic
    .to('.story-engine', {
      opacity: 1,
      scale: 1,
      rotate: 180,
      duration: 1.5,
      ease: "power2.out"
    }, "-=0.5")
    
    // Transition Background to Cream
    .to('.story-bg', {
      backgroundColor: 'var(--cream)',
      duration: 1
    }, "-=1")

    // Shift engine style for light background
    .to('.story-engine', {
      borderColor: 'rgba(12, 15, 18, 0.1)',
      duration: 1
    }, "-=1")
    .to('.story-engine-inner', {
      borderColor: 'rgba(12, 15, 18, 0.2)',
      duration: 1
    }, "-=1")

    // Animate Scene 2 in
    .to('.scene-2', {
      y: 0,
      opacity: 1,
      duration: 1
    }, "-=0.5")

    // Hold Scene 2 & rotate engine
    .to('.story-engine', {
      rotate: 360,
      duration: 1.5,
      ease: "none"
    }, "-=1")

    // Animate Scene 2 out
    .to('.scene-2', {
      yPercent: -50,
      opacity: 0,
      filter: "blur(10px)",
      duration: 1
    })

    // Fade out engine
    .to('.story-engine', {
      opacity: 0,
      scale: 1.5,
      duration: 1
    }, "-=1")

    // Animate Scene 3 in
    .to('.scene-3', {
      scale: 1,
      opacity: 1,
      duration: 1,
      ease: "back.out(1.7)"
    })

    // Hold Scene 3
    .to({}, { duration: 1 });
  }

  document.addEventListener('astro:page-load', () => {
    import('gsap/ScrollTrigger').then(({ ScrollTrigger }) => {
      ScrollTrigger.getAll().forEach(t => {
        if(t.vars.trigger === '#story-sequence') t.kill();
      });
      initStorySequence();
    });
  });
</script>
