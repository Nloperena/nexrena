---
/*
  StorySequence — A cinematic "scale-to-fill" scroll journey.
  Text gives way to a massive expanding visual, which then reveals the core stats.
*/
import Eyebrow from '../ui/Eyebrow.astro';

const stats = [
  { value: 4, suffix: '', label: 'Projects Delivered' },
  { value: 3, suffix: '', label: 'Industry Verticals' },
  { value: 100, suffix: '%', label: 'Client Retention' },
];
---

<section id="story-sequence" class="relative w-full h-[400vh] bg-[var(--obsidian)]" style="color: var(--warm-white);">
  <div class="story-pin sticky top-0 h-screen w-full overflow-hidden flex flex-col justify-center items-center">
    
    <!-- Background Layer -->
    <div class="story-bg absolute inset-0 bg-[var(--obsidian)] z-0"></div>

    <!-- The Expanding Image -->
    <div class="story-image-wrapper absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[30vw] aspect-[3/4] z-10 overflow-hidden will-change-transform">
      <img src="/images/hero-services-full.webp" alt="Digital Engine" class="story-image absolute inset-0 w-full h-full object-cover scale-[1.5]" />
      <div class="story-image-overlay absolute inset-0 bg-[var(--obsidian)]/0 transition-colors"></div>
    </div>

    <!-- Scene 1: The Engine -->
    <div class="scene scene-1 relative z-20 w-full px-[5vw] pointer-events-none mix-blend-difference flex justify-between items-center text-[var(--warm-white)]">
      <h2 class="font-display text-[clamp(48px,12vw,200px)] leading-[0.8] tracking-tighter uppercase scene-1-text-l w-1/2 text-right pr-8">
        WE BUILD
      </h2>
      <h2 class="font-display text-[clamp(48px,12vw,200px)] leading-[0.8] tracking-tighter uppercase scene-1-text-r w-1/2 pl-8">
        THE ENGINE.
      </h2>
    </div>

    <!-- Scene 2: The Business -->
    <div class="scene scene-2 absolute inset-0 z-30 flex flex-col items-center justify-center text-center opacity-0 pointer-events-none px-[5vw]">
      <h2 class="font-display text-[clamp(48px,12vw,200px)] leading-[0.85] tracking-tighter uppercase text-[var(--warm-white)] drop-shadow-2xl">
        YOU RUN <br/>
        <span class="italic font-light text-[var(--gold)]">THE BUSINESS.</span>
      </h2>
    </div>

    <!-- Scene 3: The Proof (Stats) -->
    <div class="scene scene-3 absolute inset-0 z-40 flex flex-col justify-end pb-32 opacity-0 pointer-events-none px-[5vw] bg-gradient-to-t from-[var(--obsidian)] via-[var(--obsidian)]/80 to-transparent">
      <div class="w-full max-w-[1320px] mx-auto flex justify-between items-end border-b border-[var(--slate-800)] pb-12">
        {stats.map((stat, i) => (
          <div class="stat-item translate-y-12 opacity-0 flex flex-col items-start">
            <p class="font-mono text-[11px] md:text-[13px] text-[var(--gold)] uppercase tracking-[0.2em] mb-4">{stat.label}</p>
            <div class="font-display text-[clamp(60px,10vw,140px)] font-light text-[var(--warm-white)] leading-none tracking-tighter">
              {stat.value}<span class="text-[var(--gold-dim)]">{stat.suffix}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initStorySequence() {
    gsap.registerPlugin(ScrollTrigger);

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const sequence = document.getElementById('story-sequence');
    if (!sequence) return;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: sequence,
        start: "top top",
        end: "bottom bottom",
        scrub: 1,
      }
    });

    // Phase 1: Text splits apart, image scales up to fill screen
    tl.to('.scene-1-text-l', { xPercent: -100, opacity: 0, duration: 1.5, ease: 'power2.inOut' }, 0)
      .to('.scene-1-text-r', { xPercent: 100, opacity: 0, duration: 1.5, ease: 'power2.inOut' }, 0)
      .to('.story-image-wrapper', {
        width: '100vw',
        height: '100vh',
        duration: 1.5,
        ease: 'power2.inOut'
      }, 0)
      .to('.story-image', {
        scale: 1, // Reset scale as wrapper grows
        duration: 1.5,
        ease: 'power2.inOut'
      }, 0);

    // Phase 2: Darken image slightly, bring in "You run the business"
    tl.to('.story-image-overlay', { backgroundColor: 'rgba(12, 15, 18, 0.4)', duration: 0.5 }, "-=0.2")
      .fromTo('.scene-2', 
        { scale: 1.1, opacity: 0 },
        { scale: 1, opacity: 1, duration: 1, ease: 'power2.out' }
      )
      .to({}, { duration: 0.5 }); // hold

    // Phase 3: Fade out Scene 2, Blur background, bring in Stats
    tl.to('.scene-2', { yPercent: -10, opacity: 0, duration: 0.8 })
      .to('.story-image', { filter: 'blur(8px)', duration: 0.8 }, "-=0.8")
      .to('.scene-3', { opacity: 1, duration: 0.5 }, "-=0.4")
      .to('.stat-item', {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.15,
        ease: 'power3.out'
      }, "-=0.2")
      .to({}, { duration: 1 }); // hold at end
  }

  document.addEventListener('astro:page-load', initStorySequence);
</script>
