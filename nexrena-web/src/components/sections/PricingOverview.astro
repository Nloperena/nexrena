---
import { projectBuildTiers, waasTiers } from '../../data/pricing';
import { projectIntakeCta } from '../../data/cta';

interface Props {
  showCta?: boolean;
}

const { showCta = true } = Astro.props;
---

<section id="pricing" class="relative w-full bg-[var(--obsidian)] border-t border-[var(--slate-800)]">
  <div class="section-container py-24 md:py-32">
    <div class="max-w-3xl mb-16 reveal">
      <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6">Pricing</p>
      <h2 class="font-display text-[clamp(40px,6vw,72px)] text-[var(--warm-white)] leading-[1.05] tracking-tight">
        Clear ranges. <span class="italic text-[var(--gold)]">No surprise invoices.</span>
      </h2>
      <p class="mt-6 font-body text-lg text-[var(--slate-400)] max-w-2xl leading-relaxed">
        Choose a one-time build or a monthly Website as a Service (WaaS) partnership. Every engagement starts with a scoped roadmap before work begins.
      </p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-10 xl:gap-12">
      <div class="reveal" style="--i: 1;">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6">One-time projects</p>
        <div class="flex flex-col gap-4">
          {projectBuildTiers.map((tier) => (
            <article class="border border-[var(--slate-800)] bg-[var(--slate-900)]/40 p-6 md:p-8">
              <div class="flex items-baseline justify-between gap-4 mb-3">
                <h3 class="font-display text-2xl text-[var(--warm-white)]">{tier.name}</h3>
                <p class="font-mono text-sm text-[var(--gold)] shrink-0">{tier.price}</p>
              </div>
              <p class="font-body text-[15px] text-[var(--slate-400)] leading-relaxed">{tier.scope}</p>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-widest text-[var(--slate-500)]">{tier.timeline}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="reveal" style="--i: 2;">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6">Website as a Service (WaaS)</p>
        <div class="flex flex-col gap-4">
          {waasTiers.map((tier) => (
            <article class="border border-[var(--slate-800)] bg-[var(--slate-900)]/40 p-6 md:p-8">
              <div class="flex items-baseline justify-between gap-4 mb-3">
                <h3 class="font-display text-2xl text-[var(--warm-white)]">{tier.name}</h3>
                <p class="font-mono text-sm text-[var(--gold)] shrink-0">{tier.priceLabel}</p>
              </div>
              <p class="font-body text-[15px] text-[var(--slate-400)] leading-relaxed">{tier.includes}</p>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-widest text-[var(--slate-500)]">{tier.minimum}</p>
            </article>
          ))}
        </div>
      </div>
    </div>

    {showCta && (
      <div class="mt-16 pt-10 border-t border-[var(--slate-800)] flex flex-col md:flex-row items-start md:items-center justify-between gap-6 reveal" style="--i: 3;">
        <p class="font-body text-[17px] text-[var(--slate-300)] max-w-xl leading-relaxed">
          Not sure which model fits? Tell us where you are — we'll recommend project vs WaaS and send a scoped plan.
        </p>
        <button
          type="button"
          data-growth-plan-portal
          class="inline-flex h-14 items-center justify-center rounded-full bg-[var(--gold)] px-10 font-mono text-[12px] uppercase tracking-widest text-[var(--obsidian)] hover:bg-[var(--gold-light)] transition-colors border-0 cursor-pointer"
          data-cta-zone="pricing"
          data-cta-role="primary"
        >
          {projectIntakeCta.button}
        </button>
      </div>
    )}
  </div>
</section>
