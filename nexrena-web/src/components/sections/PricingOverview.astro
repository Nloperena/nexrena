---
import {
  projectBuildTiers,
  waasTiers,
  waasPageCopy,
  waasPricingFaq,
  pricingTransparency,
  websiteBuyTiers,
  seoContentBundles,
  extensionAddOns,
} from '../../data/pricing';
import { projectIntakeCta } from '../../data/cta';
import { portalCopy, clientPortalUrl, clientPortalShopUrl } from '../../data/portal';

interface Props {
  showCta?: boolean;
  compactProjects?: boolean;
  layout?: 'embed' | 'full';
}

const { showCta = true, compactProjects = false, layout = 'embed' } = Astro.props;
const isFull = layout === 'full';
const copy = waasPageCopy;
---

{isFull && (
  <>
    <section class="relative w-full bg-[var(--obsidian)] border-t border-[var(--slate-800)]">
      <div class="section-container py-20 md:py-28 max-w-3xl reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6">{copy.pain.eyebrow}</p>
        <h2 class="font-display text-[clamp(32px,5vw,56px)] text-[var(--warm-white)] leading-[1.08] tracking-tight">
          {copy.pain.headline}
        </h2>
        {copy.pain.body.map((paragraph) => (
          <p class="mt-6 font-body text-lg text-[var(--slate-400)] leading-relaxed">{paragraph}</p>
        ))}
      </div>
    </section>

    <section class="relative w-full bg-[var(--slate-900)]/30 border-t border-[var(--slate-800)]">
      <div class="section-container py-20 md:py-28 max-w-3xl reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6">{copy.positioning.eyebrow}</p>
        <h2 class="font-display text-[clamp(32px,5vw,52px)] text-[var(--warm-white)] leading-[1.08] tracking-tight">
          {copy.positioning.headline}
        </h2>
        <p class="mt-6 font-body text-lg text-[var(--slate-300)] leading-relaxed">{copy.positioning.body}</p>
      </div>
    </section>

    <section class="relative w-full bg-[var(--obsidian)] border-t border-[var(--slate-800)]">
      <div class="section-container py-20 md:py-28 reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-4">{copy.included.eyebrow}</p>
        <h2 class="font-display text-[clamp(28px,4vw,44px)] text-[var(--warm-white)] leading-tight max-w-2xl mb-10">
          {copy.included.headline}
        </h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl">
          {copy.included.items.map((item) => (
            <li class="flex gap-3 font-body text-[15px] text-[var(--slate-300)] border border-[var(--slate-800)] bg-[var(--slate-900)]/40 px-4 py-3">
              <span class="text-[var(--gold)] shrink-0" aria-hidden="true">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="relative w-full bg-[var(--slate-900)]/20 border-t border-[var(--slate-800)]">
      <div class="section-container py-20 md:py-28 reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-4">{copy.audience.eyebrow}</p>
        <h2 class="font-display text-[clamp(28px,4vw,44px)] text-[var(--warm-white)] leading-tight max-w-2xl mb-10">
          {copy.audience.headline}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {copy.audience.items.map((item) => (
            <article class="border border-[var(--slate-800)] bg-[var(--slate-900)]/40 p-6">
              <h3 class="font-display text-xl text-[var(--warm-white)]">{item.title}</h3>
              <p class="mt-3 font-body text-sm text-[var(--slate-400)] leading-relaxed">{item.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </>
)}

<section id="pricing" class="relative w-full bg-[var(--obsidian)] border-t border-[var(--slate-800)]">
  <div class="section-container py-24 md:py-32">
    <div class="max-w-3xl mb-12 reveal">
      {!isFull && (
        <>
          <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6">Pricing</p>
          <h2 class="font-display text-[clamp(40px,6vw,72px)] text-[var(--warm-white)] leading-[1.05] tracking-tight">
            {pricingTransparency.headline}
          </h2>
        </>
      )}
      {isFull && (
        <>
          <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6">Plans</p>
          <h2 class="font-display text-[clamp(32px,5vw,52px)] text-[var(--warm-white)] leading-[1.05] tracking-tight">
            {copy.valueAnchor.headline}
          </h2>
        </>
      )}
      <p class="mt-6 font-body text-lg text-[var(--slate-400)] max-w-2xl leading-relaxed">
        {isFull ? copy.valueAnchor.body : pricingTransparency.subhead}
      </p>
      <p class="mt-4 font-mono text-[11px] uppercase tracking-wider text-[var(--slate-500)]">
        {pricingTransparency.billingNote}
      </p>
    </div>

    <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-6 reveal">Website as a Service</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
      {waasTiers.map((tier, i) => (
        <article
          class={`relative flex flex-col border p-6 md:p-8 reveal ${tier.recommended ? 'border-[var(--gold)] bg-[var(--slate-900)]/80 shadow-[0_0_40px_rgba(201,169,110,0.08)]' : 'border-[var(--slate-800)] bg-[var(--slate-900)]/40'}`}
          style={`--i: ${i + 1};`}
        >
          {tier.recommended && (
            <span class="absolute -top-3 left-6 bg-[var(--gold)] px-3 py-1 font-mono text-[9px] uppercase tracking-widest text-[var(--obsidian)]">
              Recommended
            </span>
          )}
          <h3 class="font-display text-2xl text-[var(--warm-white)]">{tier.name}</h3>
          <p class="mt-2 font-body text-sm text-[var(--slate-400)] leading-relaxed min-h-[2.5rem]">{tier.tagline}</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="font-display text-[clamp(2.5rem,5vw,3.25rem)] text-[var(--warm-white)] leading-none">{tier.priceLabel}</span>
            <span class="font-mono text-sm text-[var(--slate-400)]">{tier.priceSuffix}</span>
          </div>
          <p class="mt-2 font-mono text-[10px] uppercase tracking-widest text-[var(--slate-500)]">{tier.minimum}</p>

          <ul class="mt-8 flex flex-col gap-3 flex-1 border-t border-[var(--slate-800)] pt-8">
            {tier.features.map((feature) => (
              <li class="flex gap-3 font-body text-[14px] text-[var(--slate-300)] leading-snug">
                <span class="text-[var(--gold)] shrink-0 mt-0.5" aria-hidden="true">✓</span>
                {feature}
              </li>
            ))}
          </ul>

          <button
            type="button"
            data-growth-plan-portal
            data-cta-zone="pricing"
            data-cta-role={`waas-${tier.id}`}
            class={`mt-8 inline-flex h-12 w-full items-center justify-center font-mono text-[11px] uppercase tracking-widest transition-colors cursor-pointer border-0 ${tier.recommended ? 'bg-[var(--gold)] text-[var(--obsidian)] hover:bg-[var(--gold-light)]' : 'border border-[var(--slate-600)] bg-transparent text-[var(--warm-white)] hover:border-[var(--gold)] hover:text-[var(--gold)]'}`}
          >
            Start your website plan
          </button>
        </article>
      ))}
    </div>

    {isFull && (
      <div class="mb-20 border-t border-[var(--slate-800)] pt-16 reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-4">Buy outright</p>
        <h2 class="font-display text-[clamp(28px,4vw,40px)] text-[var(--warm-white)] mb-3">Own your website — one payment</h2>
        <p class="font-body text-sm text-[var(--slate-400)] mb-8 max-w-2xl">Prefer to buy instead of subscribe? Purchase a fixed-scope website in the client portal and checkout online.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
          {websiteBuyTiers.map((tier) => (
            <article class={`relative flex flex-col border p-6 md:p-8 ${tier.recommended ? 'border-[var(--gold)] bg-[var(--slate-900)]/80' : 'border-[var(--slate-800)] bg-[var(--slate-900)]/40'}`}>
              {tier.recommended && (
                <span class="absolute -top-3 left-6 bg-[var(--gold)] px-3 py-1 font-mono text-[9px] uppercase tracking-widest text-[var(--obsidian)]">Popular</span>
              )}
              <h3 class="font-display text-2xl text-[var(--warm-white)]">{tier.name}</h3>
              <p class="mt-2 font-body text-sm text-[var(--slate-400)]">{tier.tagline}</p>
              <p class="mt-6 font-display text-4xl text-[var(--warm-white)]">{tier.priceLabel}</p>
              <ul class="mt-6 flex flex-col gap-2 flex-1 border-t border-[var(--slate-800)] pt-6">
                {tier.features.map((f) => (
                  <li class="flex gap-2 font-body text-sm text-[var(--slate-300)]">
                    <span class="text-[var(--gold)] shrink-0">✓</span>{f}
                  </li>
                ))}
              </ul>
              <a href={clientPortalShopUrl(tier.sku)} class="mt-8 inline-flex h-12 w-full items-center justify-center font-mono text-[11px] uppercase tracking-widest bg-[var(--gold)] text-[var(--obsidian)] hover:bg-[var(--gold-light)] transition-colors">
                Buy now
              </a>
            </article>
          ))}
        </div>
      </div>
    )}

    {isFull && (
      <div class="mb-20 border-t border-[var(--slate-800)] pt-16 reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-4">SEO content</p>
        <h2 class="font-display text-[clamp(28px,4vw,40px)] text-[var(--warm-white)] mb-3">Monthly content bundles</h2>
        <p class="font-body text-sm text-[var(--slate-400)] mb-8 max-w-2xl">Blog posts, on-page SEO, and reporting — billed monthly. Subscribe in the client portal.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {seoContentBundles.map((tier) => (
            <article class={`flex flex-col border p-6 ${tier.recommended ? 'border-[var(--gold)]/60 bg-[var(--slate-900)]/60' : 'border-[var(--slate-800)] bg-[var(--slate-900)]/30'}`}>
              <h3 class="font-display text-xl text-[var(--warm-white)]">{tier.name}</h3>
              <p class="mt-2 font-body text-sm text-[var(--slate-400)]">{tier.tagline}</p>
              <p class="mt-4 font-display text-3xl text-[var(--warm-white)]">{tier.priceLabel}</p>
              <ul class="mt-4 space-y-2 flex-1">
                {tier.features.map((f) => (
                  <li class="font-body text-sm text-[var(--slate-300)] flex gap-2"><span class="text-[var(--gold)]">✓</span>{f}</li>
                ))}
              </ul>
              <a href={clientPortalShopUrl(tier.sku)} class="mt-6 inline-flex h-11 items-center justify-center font-mono text-[10px] uppercase tracking-widest border border-[var(--slate-600)] text-[var(--warm-white)] hover:border-[var(--gold)] hover:text-[var(--gold)] transition-colors">
                Subscribe
              </a>
            </article>
          ))}
        </div>
      </div>
    )}

    {isFull && (
      <div class="mb-20 border-t border-[var(--slate-800)] pt-16 reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-4">Extensions</p>
        <h2 class="font-display text-[clamp(28px,4vw,40px)] text-[var(--warm-white)] mb-3">Renewable add-ons</h2>
        <p class="font-body text-sm text-[var(--slate-400)] mb-8 max-w-2xl">Stack extra pages or content on your plan — renews monthly, cancel anytime after 3 months.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {extensionAddOns.map((ext) => (
            <article class="border border-[var(--slate-800)] bg-[var(--slate-900)]/30 p-5 flex flex-col">
              <h3 class="font-display text-lg text-[var(--warm-white)]">{ext.name}</h3>
              <p class="mt-2 font-body text-sm text-[var(--slate-400)] flex-1">{ext.description}</p>
              <p class="mt-4 font-mono text-sm text-[var(--gold)]">{ext.priceLabel}</p>
              <a href={clientPortalShopUrl(ext.sku)} class="mt-4 font-mono text-[10px] uppercase tracking-widest text-[var(--gold)] hover:text-[var(--gold-light)]">Add in portal →</a>
            </article>
          ))}
        </div>
      </div>
    )}

    {isFull && (
      <div class="mb-20 reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-4">{copy.comparison.eyebrow}</p>
        <h2 class="font-display text-[clamp(28px,4vw,40px)] text-[var(--warm-white)] mb-8">{copy.comparison.headline}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <article class="border border-[var(--slate-800)] bg-[var(--slate-900)]/30 p-6 md:p-8">
            <h3 class="font-mono text-[10px] uppercase tracking-widest text-[var(--slate-500)] mb-4">Traditional website</h3>
            <ul class="space-y-3">
              {copy.comparison.traditional.map((line) => (
                <li class="flex gap-3 font-body text-sm text-[var(--slate-400)]">
                  <span class="text-[var(--slate-600)] shrink-0">—</span>
                  {line}
                </li>
              ))}
            </ul>
          </article>
          <article class="border border-[var(--gold)]/40 bg-[var(--slate-900)]/60 p-6 md:p-8">
            <h3 class="font-mono text-[10px] uppercase tracking-widest text-[var(--gold)] mb-4">Nexrena monthly plan</h3>
            <ul class="space-y-3">
              {copy.comparison.nexrena.map((line) => (
                <li class="flex gap-3 font-body text-sm text-[var(--slate-300)]">
                  <span class="text-[var(--gold)] shrink-0">✓</span>
                  {line}
                </li>
              ))}
            </ul>
          </article>
        </div>
      </div>
    )}

    {isFull && (
      <div class="mb-20 border-t border-[var(--slate-800)] pt-16 reveal">
        <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-8">FAQ</p>
        <div class="max-w-3xl space-y-6">
          {waasPricingFaq.map((item) => (
            <details class="group border border-[var(--slate-800)] bg-[var(--slate-900)]/30 px-5 py-4">
              <summary class="font-display text-lg text-[var(--warm-white)] cursor-pointer list-none flex justify-between gap-4">
                {item.question}
                <span class="text-[var(--gold)] group-open:rotate-45 transition-transform">+</span>
              </summary>
              <p class="mt-4 font-body text-sm text-[var(--slate-400)] leading-relaxed pb-2">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    )}

    <div class={`reveal ${compactProjects ? 'opacity-90' : ''}`} style="--i: 4;">
      <p class="font-mono text-[10px] text-[var(--gold)] tracking-[0.2em] uppercase mb-2">Custom projects</p>
      <p class="font-body text-sm text-[var(--slate-500)] mb-6">{pricingTransparency.projectNote}</p>
      <div class={`grid gap-4 ${compactProjects ? 'grid-cols-1 md:grid-cols-3' : 'grid-cols-1 xl:grid-cols-3'}`}>
        {projectBuildTiers.map((tier) => (
          <article class="border border-[var(--slate-800)] bg-[var(--slate-900)]/30 p-5 md:p-6">
            <div class="flex items-baseline justify-between gap-4 mb-2">
              <h3 class="font-display text-xl text-[var(--warm-white)]">{tier.name}</h3>
              <p class="font-mono text-xs text-[var(--gold)] shrink-0">{tier.price}</p>
            </div>
            <p class="font-body text-[14px] text-[var(--slate-400)] leading-relaxed">{tier.scope}</p>
            <p class="mt-2 font-mono text-[10px] uppercase tracking-widest text-[var(--slate-500)]">{tier.timeline}</p>
          </article>
        ))}
      </div>
    </div>

    {showCta && (
      <div class="mt-16 pt-10 border-t border-[var(--slate-800)] flex flex-col md:flex-row items-start md:items-center justify-between gap-6 reveal" style="--i: 5;">
        <p class="font-body text-[17px] text-[var(--slate-300)] max-w-xl leading-relaxed">
          {isFull
            ? 'Ready for a website that stays maintained? Start your plan — or create a client account to track everything in one place.'
            : 'Not sure which plan fits? Start a project request or create a client account to track everything in one place.'}
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={clientPortalUrl}
            class="inline-flex h-14 items-center justify-center rounded-full border border-[var(--gold)] px-8 font-mono text-[12px] uppercase tracking-widest text-[var(--gold)] hover:bg-[var(--gold)] hover:text-[var(--obsidian)] transition-colors"
          >
            {portalCopy.navLabel}
          </a>
          <button
            type="button"
            data-growth-plan-portal
            class="inline-flex h-14 items-center justify-center rounded-full bg-[var(--gold)] px-10 font-mono text-[12px] uppercase tracking-widest text-[var(--obsidian)] hover:bg-[var(--gold-light)] transition-colors border-0 cursor-pointer"
            data-cta-zone="pricing"
            data-cta-role="primary"
          >
            {isFull ? 'Start your website plan' : projectIntakeCta.button}
          </button>
        </div>
      </div>
    )}
  </div>
</section>
