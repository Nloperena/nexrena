---
/*
  ServiceStack — Ultra-modern sticky scroll spectacle
  Header: "Three ways we grow your business" — words come up on scroll.
  Each service: massive editorial title, word-by-word reveal, sticky cards.
*/
import { services as servicesData } from '../../data/services';
import Eyebrow from '../ui/Eyebrow.astro';

const headerWords = "Three ways we grow your business.".split(' ');
const headerWordCount = headerWords.length;

const stackServices = servicesData.map((svc) => ({
  ...svc,
  titleWords: svc.title.replace(/\n/g, ' ').split(' ').filter(Boolean),
}));
---

<section class="service-stack layer-3 bg-[var(--obsidian)]" id="services" aria-label="Services">
  <!-- Header: word-by-word scroll reveal -->
  <div class="service-stack__header-wrap scroll-travel-2x">
    <div class="service-stack__header sticky-pin">
      <div class="section-container flex flex-col justify-center min-h-screen py-24">
        <Eyebrow class="mb-12">WHAT WE BUILD //</Eyebrow>
        <div class="service-stack__headline" role="text" aria-label="Three ways we grow your business">
          <p class="service-stack__headline-text">
            {headerWords.map((word, i) => (
              <span
                class="service-stack__headline-word"
                style={`--word-index: ${i}; --total-words: ${headerWordCount};`}
              >
                {word}{' '}
              </span>
            ))}
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Service cards: each with editorial title reveal -->
  {stackServices.map((svc, i) => (
    <div class="service-card-track scroll-travel-2x">
      <div class="service-card sticky-pin">
        <div class="section-container flex flex-col justify-center min-h-screen py-24">
          <div class="service-card__num font-display text-[clamp(80px,12vw,160px)] font-light text-[var(--gold)] leading-none opacity-[0.08] mb-[-0.15em]">
            {svc.number}
          </div>

          <!-- Editorial title: words come up on scroll -->
          <h3 class="service-card__title" role="text" aria-label={svc.title.replace(/\n/g, ' ')}>
            {svc.titleWords.map((word, j) => (
              <span
                class="service-card__title-word"
                style={`--word-index: ${j}; --total-words: ${svc.titleWords.length};`}
              >
                {word}{' '}
              </span>
            ))}
          </h3>

          <p class="service-card__body font-body text-[18px] md:text-[20px] text-[var(--slate-400)] leading-relaxed max-w-xl mt-10 mb-8">
            {svc.body}
          </p>

          <ul class="flex flex-wrap gap-2 mb-10" aria-label="Technologies">
            {svc.tags.map((tag) => (
              <li>
                <span class="font-mono text-[11px] text-[var(--slate-500)] border border-[var(--slate-700)] px-4 py-2 uppercase tracking-wider">
                  {tag}
                </span>
              </li>
            ))}
          </ul>

          <a
            href={`/services/${svc.id}`}
            class="service-card__cta group/cta inline-flex items-center gap-3 font-mono text-[11px] text-[var(--gold)] uppercase tracking-[0.2em] hover:text-[var(--gold-light)] transition-colors"
          >
            Explore this service
            <span class="transition-transform group-hover/cta:translate-x-2" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  ))}
</section>

<style>
  .service-stack {
    background-color: var(--obsidian);
  }

  /* Header headline: editorial, words come up */
  .service-stack__headline-text {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--warm-white);
    display: flex;
    flex-wrap: wrap;
    gap: 0.05em 0.15em;
  }

  .service-stack__headline-word {
    display: inline-block;
    opacity: 0.12;
    transform: translateY(1.5em);
    animation: service-word-up linear both;
    animation-timeline: view(block);
    animation-range:
      calc(entry 5% + (var(--word-index) / var(--total-words)) * 65%)
      calc(entry 8% + ((var(--word-index) + 1) / var(--total-words)) * 65% + 6%);
  }

  /* Service card title: editorial, balanced scale */
  .service-card__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.025em;
    color: var(--warm-white);
    display: flex;
    flex-wrap: wrap;
    gap: 0.05em 0.2em;
    margin-top: -0.05em;
  }

  .service-card__title-word {
    display: inline-block;
    opacity: 0.12;
    transform: translateY(1.2em);
    animation: service-word-up linear both;
    animation-timeline: view(block);
    animation-range:
      calc(entry 5% + (var(--word-index) / var(--total-words)) * 70%)
      calc(entry 10% + ((var(--word-index) + 1) / var(--total-words)) * 70% + 8%);
  }

  @keyframes service-word-up {
    from {
      opacity: 0.12;
      transform: translateY(1.2em);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .service-card-track {
    position: relative;
  }

  .service-card {
    position: sticky;
    top: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: var(--obsidian);
    padding: 0;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .service-stack__headline-text {
      font-size: clamp(2rem, 8vw, 3rem);
    }
    .service-card__title {
      font-size: clamp(1.75rem, 8vw, 2.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-stack__headline-word,
    .service-card__title-word {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
