---
/*
  ServiceStack — GSAP Card Stacking Effect
  Cards pin and stack cleanly on top of one another with a 3D scaling effect.
*/
import { services as servicesData } from '../../data/services';
import Eyebrow from '../ui/Eyebrow.astro';
import FullServiceOrbitsBg from '../ui/FullServiceOrbitsBg.astro';
import RotatingNetworkSphereBg from '../ui/RotatingNetworkSphereBg.astro';
import WebDesignCinematicBg from '../ui/WebDesignCinematicBg.astro';
---

<section id="services-stack-wrapper" class="bg-[var(--obsidian)] relative w-full pb-32">
  
  <!-- Intro Header -->
  <div class="section-container py-32 md:py-48 flex flex-col justify-center min-h-[80vh]">
    <Eyebrow class="mb-8">WHAT WE BUILD //</Eyebrow>
    <h2 class="font-display text-[clamp(56px,10vw,140px)] leading-[0.9] text-[var(--warm-white)] tracking-tight max-w-5xl">
      Three ways we <span class="italic text-[var(--gold)]">grow</span> your business.
    </h2>
  </div>

  <!-- Stacking Cards Container -->
  <div class="relative w-full px-[5vw] mx-auto max-w-[1320px] service-cards-container">
    {servicesData.map((svc, i) => (
      <div class="service-stack-card sticky top-[10vh] w-full min-h-[80vh] bg-[var(--slate-900)] rounded-3xl border border-[var(--slate-800)] p-8 md:p-16 flex flex-col justify-between overflow-hidden shadow-2xl origin-top mb-12" style={`z-index: ${i + 10};`}>
        {i === 0 && (
          <WebDesignCinematicBg class="service-cinematic-bg right-[-20%] left-auto w-[120%] md:w-[100%] z-0 opacity-100 mix-blend-screen scale-[1.3] md:scale-[1.5] transform-gpu" />
        )}
        {i === 1 && (
          <RotatingNetworkSphereBg class="service-sphere-bg right-[-20%] left-auto w-[120%] md:w-[100%] z-0 opacity-100 mix-blend-screen scale-[1.3] md:scale-[1.5] transform-gpu" />
        )}
        {i === 2 && (
          <FullServiceOrbitsBg class="service-orbits-bg right-[-20%] left-auto w-[120%] md:w-[100%] z-0 opacity-100 mix-blend-screen scale-[1.3] md:scale-[1.5] transform-gpu" />
        )}

        <!-- Large background number -->
        <div class="absolute right-8 -bottom-16 font-display text-[30vh] text-[var(--gold)] opacity-5 pointer-events-none select-none z-10">
          {svc.number}
        </div>

        <div class="relative z-10 flex flex-col h-full justify-between gap-12">
          <!-- Top Row -->
          <div class="flex justify-between items-start">
            <span class="font-mono text-[14px] text-[var(--gold)] py-2 px-4 border border-[var(--gold)]/30 rounded-full bg-[var(--obsidian)]/50 backdrop-blur-md">
              {svc.number}
            </span>
          </div>

          <!-- Middle Content -->
          <div class="max-w-5xl">
            <h3 class="service-stack-card__title font-display text-[48px] md:text-[80px] lg:text-[100px] text-[var(--warm-white)] mb-8 leading-[0.95] tracking-tight whitespace-pre-line">
              {svc.title}
            </h3>

            <div class="service-stack-card__meta-grid">
              <p class="service-stack-card__body font-body text-[18px] md:text-[24px] text-[var(--slate-400)] leading-relaxed max-w-2xl">
                {svc.body}
              </p>

              <aside class="service-stack-card__meta">
                <ul class="flex flex-wrap gap-3">
                  {svc.tags.map((tag) => (
                    <li>
                      <span class="font-mono text-[11px] text-[var(--slate-300)] bg-[var(--obsidian)] px-4 py-2 uppercase tracking-wider rounded-md border border-[var(--slate-800)]">
                        {tag}
                      </span>
                    </li>
                  ))}
                </ul>

                <a href={`/services/${svc.id}`} class="group inline-flex items-center gap-4 font-mono text-[13px] text-[var(--gold)] uppercase tracking-[0.2em] hover:text-[var(--warm-white)] transition-colors">
                  <div class="w-12 h-12 rounded-full border border-[var(--gold)] group-hover:bg-[var(--gold)] flex items-center justify-center transition-all duration-300">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="group-hover:text-[var(--obsidian)]">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                  → Explore this service
                </a>
              </aside>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { getMotionTier } from '@/lib/perf';

  function initServiceStack() {
    gsap.registerPlugin(ScrollTrigger);

    if (window.innerHeight <= 600) return;
    const tier = getMotionTier();
    if (tier === 'minimal') return;

    const cards = gsap.utils.toArray('.service-stack-card') as HTMLElement[];

    cards.forEach((card, i) => {
      if (i === cards.length - 1) return;

      // Skip blur on reduced-tier devices — filter animations are GPU-expensive
      const useBlur = tier === 'full';

      ScrollTrigger.create({
        trigger: card,
        start: 'top 10%',
        endTrigger: '.service-cards-container',
        end: 'bottom bottom',
        scrub: true,
        animation: gsap.to(card, {
          scale: 0.9 - (cards.length - i) * 0.02,
          opacity: 0.3,
          ...(useBlur ? { filter: 'blur(2px)' } : {}),
          ease: 'none',
        }),
      });
    });
  }

  document.addEventListener('astro:page-load', initServiceStack);
</script>

<style>
  /* Fallback if JS fails - CSS sticky handles the actual stacking natively */
  .service-stack-card {
    position: sticky;
  }

  .service-stack-card__meta-grid {
    display: grid;
    gap: 2.5rem;
  }

  .service-stack-card__meta {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .service-sphere-bg {
    top: 0;
    bottom: 0;
  }

  .service-cinematic-bg {
    top: 0;
    bottom: 0;
  }

  .service-orbits-bg {
    top: 0;
    bottom: 0;
  }

  @media (min-width: 1024px) {
    .service-stack-card__meta-grid {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 360px);
      align-items: start;
      column-gap: 3.5rem;
    }

    .service-stack-card__meta {
      align-items: flex-start;
    }
  }

  @media (max-width: 767px) {
    /* Backgrounds are handled via Tailwind classes now for consistent heroic scaling */
  }

  @media (max-height: 600px) {
    #services-stack-wrapper {
      padding-bottom: 80px;
    }

    #services-stack-wrapper .section-container {
      min-height: auto;
      padding-top: 96px;
      padding-bottom: 72px;
    }

    .service-stack-card {
      position: relative;
      top: auto;
      min-height: auto;
      margin-bottom: 24px;
      padding: 24px;
    }
  }

  @media (max-height: 560px) {
    .service-stack-card {
      padding: 24px 20px;
    }

    .service-stack-card__title {
      font-size: clamp(36px, 7vw, 64px);
    }

    .service-stack-card__body {
      font-size: 18px;
    }
  }
</style>
