---
/* 
  Showreel Placeholder
  30-60s compilation of project highlights
*/
import Eyebrow from '../ui/Eyebrow.astro';
---

<section class="showreel bg-[var(--obsidian)] relative w-full h-screen overflow-hidden group">
  <!-- Poster Image / Video Element -->
  <img src="/images/hero-work.webp" alt="Showreel Poster" class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-60 transition-opacity duration-1000 scale-105 group-hover:scale-100 ease-[cubic-bezier(0.16,1,0.3,1)]" />
  
  <!-- Subtle Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-[var(--obsidian)]/80 via-transparent to-[var(--obsidian)]/80"></div>

  <!-- Play Button Centered -->
  <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none z-10">
    <div class="w-24 h-24 md:w-32 md:h-32 rounded-full border border-[var(--warm-white)]/30 backdrop-blur-md flex items-center justify-center text-[var(--warm-white)] group-hover:scale-110 group-hover:bg-[var(--warm-white)] group-hover:text-[var(--obsidian)] transition-all duration-700 pointer-events-auto cursor-pointer mb-6">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="ml-2">
        <path d="M8 5v14l11-7z" />
      </svg>
    </div>
    <span class="font-mono text-[11px] text-[var(--warm-white)] uppercase tracking-[0.3em] opacity-80 group-hover:opacity-100 transition-opacity">
      Watch Showreel
    </span>
  </div>
  
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest px-4 py-2 bg-[var(--obsidian)]/80 backdrop-blur-sm border border-[var(--slate-800)] z-10">
    Coming Soon
  </div>
</section>
