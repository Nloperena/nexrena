---
import { services } from '../../data/services';
import { industries } from '../../data/industries';
---
<footer class="bg-[var(--obsidian)] border-t border-[var(--slate-800)] relative overflow-hidden mt-20" role="contentinfo">
  <div class="max-w-[1320px] mx-auto px-[5vw] py-20">
    <!-- ROW 1 -->
    <div class="footer-row flex flex-col md:flex-row justify-between items-start gap-12 mb-24">
      <div class="footer-col easter-egg-wordmark">
        <a href="/" class="font-display text-[64px] md:text-[80px] italic text-[var(--warm-white)] flex">
          {['N','e','x','r','e','n','a'].map((letter) => (
            <span class="inline-block transition-transform duration-300 hover:rotate-[15deg] hover:-translate-y-2 hover:text-[var(--gold)]">
              {letter}
            </span>
          ))}
        </a>
      </div>
      
      <!-- Right: Navigation Grids -->
      <div class="flex flex-wrap gap-16 md:gap-32 w-full md:w-auto">
        <div class="footer-col flex flex-col gap-6">
          <p class="font-mono text-[11px] text-[var(--slate-500)] tracking-widest uppercase mb-2">Pages</p>
          <a href="/work" class="font-display text-[24px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">Work</a>
          <a href="/services" class="font-display text-[24px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">Services</a>
          <a href="/industries" class="font-display text-[24px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">Industries</a>
          <a href="/resources" class="font-display text-[24px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">Resources</a>
          <a href="/about" class="font-display text-[24px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">About</a>
          <a href="/contact" class="font-display text-[24px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">Contact</a>
        </div>
        <div class="footer-col flex flex-col gap-6">
          <p class="font-mono text-[11px] text-[var(--slate-500)] tracking-widest uppercase mb-2">Services</p>
          {services.map((s) => (
            <a href={`/services/${s.id}`} class="font-body text-[15px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">{s.title.replace(/\n/g, ' ')}</a>
          ))}
        </div>
        <div class="footer-col flex flex-col gap-6">
          <p class="font-mono text-[11px] text-[var(--slate-500)] tracking-widest uppercase mb-2">Connect</p>
          <a href="https://www.linkedin.com/company/nexrena" target="_blank" rel="noopener noreferrer" class="font-body text-[15px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">LinkedIn</a>
          <a href="mailto:hello@nexrena.com" class="font-body text-[15px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">Email</a>
        </div>
      </div>
    </div>

    <!-- ROW 2: Massive Brand Mark -->
    <div class="w-full border-t border-[var(--slate-800)] pt-12 pb-24 overflow-hidden flex justify-center">
      <div class="font-display text-[15vw] leading-none text-[var(--slate-600)]/80 tracking-tighter select-none cursor-default whitespace-nowrap" aria-hidden="true">
        Nexrena<span class="text-[var(--gold)]/20">®</span>
      </div>
    </div>

    <!-- ROW 3: Legal & Local -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 pt-8 border-t border-[var(--slate-800)] text-[12px] text-[var(--slate-400)]">
      <p>&copy; {new Date().getFullYear()} Nexrena LLC. All rights reserved.</p>
      <a href="mailto:hello@nexrena.com" class="font-mono text-[var(--gold)] hover:text-[var(--gold-light)] transition-colors">hello@nexrena.com</a>
      <div class="flex items-center gap-2">
        <span>Kissimmee, FL</span>
        <span class="w-1 h-1 rounded-full bg-[var(--gold)]"></span>
        <span id="local-time" class="font-mono"></span>
      </div>
    </div>
  </div>
</footer>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  let footerInterval: ReturnType<typeof setInterval> | null = null;

  function initFooterClock() {
    if (footerInterval) clearInterval(footerInterval);
    const timeEl = document.getElementById('local-time');
    if (!timeEl) return;

    const fmt = new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/New_York',
      hour: '2-digit', minute: '2-digit', hour12: true,
    });

    const tick = () => { timeEl.textContent = fmt.format(new Date()); };
    tick();
    footerInterval = setInterval(tick, 60000);
  }

  function initFooterReveal() {
    gsap.registerPlugin(ScrollTrigger);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const cols = gsap.utils.toArray('.footer-col') as HTMLElement[];
    if (!cols.length) return;

    gsap.set(cols, { opacity: 0, y: 40 });
    ScrollTrigger.batch(cols, {
      start: 'top 92%',
      onEnter: (batch) => {
        gsap.to(batch, { opacity: 1, y: 0, duration: 0.8, stagger: 0.12, ease: 'power3.out' });
      },
      once: true,
    });
  }

  document.addEventListener('astro:page-load', () => {
    initFooterClock();
    initFooterReveal();
  });
</script>
