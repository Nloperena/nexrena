---
import '@fontsource-variable/cormorant-garamond';
import '@fontsource-variable/cormorant-garamond/wght-italic.css';
import '@fontsource-variable/dm-sans';
import '@fontsource-variable/dm-sans/wght-italic.css';
import '@fontsource/dm-mono/400.css';
import '../../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import Schema from '../seo/Schema.astro';
import Analytics from '@vercel/analytics/astro';
import Loader from '../ui/Loader.astro';

interface Props {
  title?: string;
  description?: string;
  schema?: object | object[];
  ogImage?: string;
}

const {
  title = 'Nexrena — Digital Growth Agency',
  description = 'Premium B2B digital agency — web design, SEO, full-service growth.',
  schema,
  ogImage = 'https://nexrena.com/og-default.png',
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://nexrena.com';
const canonical = new URL(Astro.url.pathname, site).toString();
const imageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PDNLMRMXKW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PDNLMRMXKW');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Fonts self-hosted via @fontsource (imported in frontmatter) -->
    
    <title>{title}</title>
    <ClientRouter />
    {schema && <Schema data={schema} />}
    <slot name="head" />
  </head>
  <body class="bg-[var(--obsidian)] text-[var(--slate-200)] font-body font-light antialiased selection:bg-[var(--gold)] selection:text-[var(--obsidian)]">
    <Loader />
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div id="scroll-progress"></div>
    <div id="custom-cursor" transition:persist="cursor"></div>
    
    <Nav />
    <div id="main-content" tabindex="-1">
      <slot />
    </div>
    <Footer />
    <Analytics />

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { initAnalyticsEvents } from '@/lib/analytics-events';
      gsap.registerPlugin(ScrollTrigger);

      // ── Global GSAP cleanup on navigation ──
      document.addEventListener('astro:before-swap', () => {
        ScrollTrigger.getAll().forEach(t => t.kill());
        const mainContent = document.getElementById('main-content');
        if (mainContent) gsap.killTweensOf(mainContent.querySelectorAll('*'));
      });

      // ── Scroll Reveal (IntersectionObserver) ──
      let revealObserver: IntersectionObserver | null = null;

      function setupScrollReveal() {
        revealObserver?.disconnect();

        revealObserver = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              el.style.willChange = 'transform, opacity';
              el.classList.add('is-visible');
              // Remove will-change after animation completes to free compositor layers
              el.addEventListener('transitionend', () => {
                el.style.willChange = 'auto';
              }, { once: true });
              obs.unobserve(el);
            }
          });
        }, { rootMargin: '0px 0px -50px 0px', threshold: 0.1 });

        document.querySelectorAll('.reveal, .reveal-scale').forEach(el => {
          const htmlEl = el as HTMLElement;
          if (!htmlEl.style.getPropertyValue('--i')) {
            const parent = htmlEl.parentElement;
            if (parent) {
              const idx = Array.from(parent.querySelectorAll('.reveal, .reveal-scale')).indexOf(htmlEl);
              htmlEl.style.setProperty('--i', Math.min(idx, 10).toString());
            } else {
              htmlEl.style.setProperty('--i', '0');
            }
          }
          revealObserver!.observe(el);
        });
      }

      document.addEventListener('astro:page-load', setupScrollReveal);
      document.addEventListener('astro:page-load', initAnalyticsEvents);

      // ── Page Entrance Stagger ──
      function triggerPageEntrance() {
        const els = document.querySelectorAll('.page-enter');
        if (!els.length) return;
        els.forEach((el, i) => {
          const htmlEl = el as HTMLElement;
          if (!htmlEl.style.getPropertyValue('--stagger')) {
            htmlEl.style.setProperty('--stagger', i.toString());
          }
        });
        requestAnimationFrame(() => {
          els.forEach(el => el.classList.add('is-entered'));
        });
      }
      document.addEventListener('astro:page-load', triggerPageEntrance);

      // ── Recalculate all ScrollTrigger positions after sections initialize ──
      document.addEventListener('astro:page-load', () => {
        requestAnimationFrame(() => {
          ScrollTrigger.sort();
          ScrollTrigger.refresh();
        });
      });

      // ── Non-critical UI: cursor and scroll bar deferred to idle ──
      const idle = (cb: () => void) =>
        'requestIdleCallback' in window
          ? (window as any).requestIdleCallback(cb, { timeout: 300 })
          : setTimeout(cb, 50);

      idle(() => {
        // Scroll Progress Bar
        function handleScrollProgress() {
          const bar = document.getElementById('scroll-progress');
          if (!bar) return;
          const top = document.documentElement.scrollTop || document.body.scrollTop;
          const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          bar.style.width = `${(top / height) * 100}%`;
          bar.classList.toggle('visible', top > window.innerHeight * 0.05);
        }
        window.addEventListener('scroll', handleScrollProgress, { passive: true });

        // Custom Cursor — only on pointer-fine (non-touch) devices
        if (!window.matchMedia('(pointer: fine)').matches) return;

        const cursor = document.getElementById('custom-cursor');
        if (!cursor) return;

        cursor.style.display = 'block';
        document.documentElement.classList.add('custom-cursor-active');

        let rafPending = false;
        let pendingX = 0, pendingY = 0;

        document.addEventListener('pointermove', (e) => {
          pendingX = e.clientX;
          pendingY = e.clientY;
          if (rafPending) return;
          rafPending = true;
          requestAnimationFrame(() => {
            cursor!.style.setProperty('--cursor-x', `${pendingX}px`);
            cursor!.style.setProperty('--cursor-y', `${pendingY}px`);
            rafPending = false;
          });
        }, { passive: true });

        document.addEventListener('mousedown', () => cursor.classList.add('click'));
        document.addEventListener('mouseup', () => cursor.classList.remove('click'));

        document.addEventListener('mouseover', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('.work-card, .work-row')) {
            cursor.classList.add('cursor-view');
          } else if (target.closest('a, button, input, textarea, select, .magnetic-btn')) {
            cursor.classList.add('hover');
          }
        });
        document.addEventListener('mouseout', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('.work-card, .work-row')) {
            cursor.classList.remove('cursor-view');
          } else if (target.closest('a, button, input, textarea, select, .magnetic-btn')) {
            cursor.classList.remove('hover');
          }
        });

        window.addEventListener('resize', () => {
          const fine = window.matchMedia('(pointer: fine)').matches;
          cursor.style.display = fine ? 'block' : 'none';
          document.documentElement.classList.toggle('custom-cursor-active', fine);
        });
      });
    </script>
  </body>
</html>
