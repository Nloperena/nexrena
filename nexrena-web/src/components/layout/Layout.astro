---
import '../../styles/global.css';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Nexrena — Digital Growth Agency', 
  description = 'Premium B2B digital agency — web design, SEO, full-service growth.' 
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap" rel="stylesheet" />
    
    <title>{title}</title>
  </head>
  <body class="bg-[var(--obsidian)] text-[var(--slate-200)] font-body font-light antialiased selection:bg-[var(--gold)] selection:text-[var(--obsidian)]">
    <div id="scroll-progress"></div>
    <div id="custom-cursor"></div>
    
    <Nav />
    <slot />
    <Footer />

    <script>
      // Scroll Progress Bar
      const progressBar = document.getElementById('scroll-progress');
      window.addEventListener('scroll', () => {
        if (!progressBar) return;
        const totalScroll = document.documentElement.scrollTop || document.body.scrollTop;
        const windowHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scroll = `${totalScroll / windowHeight * 100}%`;
        progressBar.style.width = scroll;
        
        if (totalScroll > window.innerHeight * 0.05) {
          progressBar.classList.add('visible');
        } else {
          progressBar.classList.remove('visible');
        }
      });

      // Custom Cursor
      const cursor = document.getElementById('custom-cursor');
      let isMobile = false;

      function checkMobile() {
        isMobile = window.matchMedia("(max-width: 768px)").matches;
        if (isMobile && cursor) {
          cursor.style.display = 'none';
        } else if (cursor) {
          cursor.style.display = 'block';
        }
      }
      
      checkMobile();
      window.addEventListener('resize', checkMobile);

      if (cursor && !isMobile) {
        let mouseX = 0, mouseY = 0;
        let cursorX = 0, cursorY = 0;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
        });

        // Add 80ms lag for smoothness using lerp
        function animate() {
          let distX = mouseX - cursorX;
          let distY = mouseY - cursorY;
          cursorX = cursorX + (distX * 0.15);
          cursorY = cursorY + (distY * 0.15);
          
          if(cursor) {
            cursor.style.left = cursorX + 'px';
            cursor.style.top = cursorY + 'px';
          }
          requestAnimationFrame(animate);
        }
        animate();

        // Hover states on interactive elements
        const attachInteractiveEvents = () => {
          const interactiveElements = document.querySelectorAll('a, button, input, textarea, select, .magnetic-btn');
          interactiveElements.forEach(el => {
            el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
            el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
          });
        };
        
        attachInteractiveEvents();
        document.addEventListener('astro:page-load', attachInteractiveEvents);

        // Click states
        document.addEventListener('mousedown', () => cursor.classList.add('click'));
        document.addEventListener('mouseup', () => cursor.classList.remove('click'));
      }
      
      // Scroll Reveal System using IntersectionObserver
      const setupScrollReveal = () => {
        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -50px 0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal').forEach((el, i) => {
          const htmlEl = el as HTMLElement;
          if (!htmlEl.style.getPropertyValue('--i')) {
            // Apply stagger locally if within a group
            const parent = htmlEl.parentElement;
            if (parent) {
              const children = Array.from(parent.querySelectorAll('.reveal'));
              const idx = children.indexOf(htmlEl);
              htmlEl.style.setProperty('--i', Math.min(idx, 10).toString());
            } else {
              htmlEl.style.setProperty('--i', '0');
            }
          }
          observer.observe(el);
        });
      };

      setupScrollReveal();
      document.addEventListener('astro:page-load', setupScrollReveal);
    </script>
  </body>
</html>
