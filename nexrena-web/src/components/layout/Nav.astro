---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const navLinks = [
  { label: 'Work', href: '/work' },
  { label: 'Services', href: '/services' },
  { label: 'Industries', href: '/industries' },
  { label: 'Resources', href: '/resources' },
  { label: 'About', href: '/about' },
];
---

<header id="main-nav" class="site-nav" role="banner">
  <div class="site-nav__island">
    <a href="/" class="site-nav__logo" aria-label="Nexrena home">
      <span class="site-nav__logo-n">N</span>
      <span class="site-nav__logo-rest">exrena</span>
    </a>

    <nav class="site-nav__links" aria-label="Main navigation">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || currentPath.startsWith(link.href + '/');
        return (
          <a href={link.href} class={`site-nav__link ${isActive ? 'is-active' : ''}`} aria-current={isActive ? 'page' : undefined}>
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="site-nav__actions">
      <a href="/contact" class="site-nav__cta">Let's Talk</a>
      <button class="site-nav__toggle" type="button" aria-expanded="false" aria-label="Toggle menu">
        <div class="hamburger">
          <span class="line line-1"></span>
          <span class="line line-2"></span>
        </div>
      </button>
    </div>
  </div>
</header>

<div class="mobile-menu" aria-hidden="true" inert>
  <div class="mobile-menu__backdrop"></div>
  <div class="mobile-menu__content">
    <nav class="mobile-menu__nav">
      {navLinks.map((link, i) => {
        const isActive = currentPath === link.href || currentPath.startsWith(link.href + '/');
        return (
          <a href={link.href} class={`mobile-menu__link ${isActive ? 'is-active' : ''}`} style={`--delay: ${i * 0.05}s`}>
            {link.label}
          </a>
        );
      })}
      <a href="/contact" class="mobile-menu__link mobile-menu__link--cta" style={`--delay: ${navLinks.length * 0.05}s`}>
        Let's Talk
      </a>
    </nav>
  </div>
</div>

<style>
  :global(:root) {
    --nav-safe: 104px;
  }

  .site-nav {
    position: fixed;
    top: 24px;
    left: 0;
    width: 100%;
    z-index: 3100;
    pointer-events: none;
    display: flex;
    justify-content: center;
    padding: 0 16px;
  }

  .site-nav__island {
    pointer-events: auto;
    width: 100%;
    max-width: 1000px;
    height: 56px;
    background: rgba(12, 15, 18, 0.75);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border: 1px solid rgba(122, 138, 158, 0.15);
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 8px 0 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-nav__island.is-menu-open {
    background: transparent;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    border-color: transparent;
    box-shadow: none;
  }

  .site-nav__logo {
    font-family: var(--font-display);
    color: var(--warm-white);
    text-decoration: none;
    display: flex;
    align-items: baseline;
    font-size: 22px;
    letter-spacing: -0.02em;
  }

  .site-nav__logo-n {
    color: var(--gold);
    font-style: italic;
    font-size: 24px;
    line-height: 1;
  }

  .site-nav__links {
    display: none;
    align-items: center;
    gap: 32px;
  }

  .site-nav__link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--slate-400);
    text-decoration: none;
    padding: 4px 0;
    position: relative;
    transition: color 0.2s ease;
  }

  .site-nav__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .site-nav__link:hover,
  .site-nav__link:focus-visible,
  .site-nav__link.is-active {
    color: var(--warm-white);
  }

  .site-nav__link.is-active::after {
    opacity: 1;
  }

  .site-nav__actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .site-nav__cta {
    display: none;
    height: 40px;
    align-items: center;
    justify-content: center;
    padding: 0 20px;
    border-radius: 999px;
    background: var(--gold);
    color: var(--obsidian);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .site-nav__cta:hover,
  .site-nav__cta:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(201, 169, 110, 0.3);
  }

  .site-nav__toggle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(122, 138, 158, 0.2);
    background: rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .site-nav__island.is-menu-open .site-nav__toggle {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .site-nav__toggle:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .hamburger {
    width: 16px;
    height: 12px;
    position: relative;
  }

  .line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--warm-white);
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .line-1 { top: 2px; }
  .line-2 { bottom: 2px; }

  .site-nav__toggle[aria-expanded="true"] .line-1 {
    transform: translateY(3.5px) rotate(45deg);
  }
  .site-nav__toggle[aria-expanded="true"] .line-2 {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  /* Mobile Menu Styles */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 3050;
    display: flex;
    flex-direction: column;
    justify-content: center;
    pointer-events: none;
    visibility: hidden;
    transition: visibility 0.4s;
  }

  .mobile-menu[aria-hidden="false"] {
    pointer-events: auto;
    visibility: visible;
  }

  .mobile-menu__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 10, 13, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .mobile-menu[aria-hidden="false"] .mobile-menu__backdrop {
    opacity: 1;
  }

  .mobile-menu__content {
    position: relative;
    width: 100%;
    padding: 0 32px;
    z-index: 1;
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
  }

  .mobile-menu__link {
    font-family: var(--font-display);
    font-size: 32px;
    color: var(--slate-300);
    text-decoration: none;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s ease, transform 0.4s ease, color 0.2s ease;
    transition-delay: var(--delay);
  }

  .mobile-menu__link.is-active,
  .mobile-menu__link:hover {
    color: var(--gold);
  }

  .mobile-menu__link--cta {
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 14px 36px;
    border-radius: 999px;
  }

  .mobile-menu[aria-hidden="false"] .mobile-menu__link {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 1024px) {
    .site-nav__links { display: flex; }
    .site-nav__toggle { display: none; }
    .site-nav__cta { display: inline-flex; }
  }

  @media (max-height: 760px) {
    :global(:root) {
      --nav-safe: 88px;
    }
    .site-nav {
      top: 16px;
    }
  }
</style>

<script>
  function setupNav() {
    const toggleBtn = document.querySelector('.site-nav__toggle');
    const mobileMenu = document.querySelector('.mobile-menu');
    const backdrop = document.querySelector('.mobile-menu__backdrop');
    const links = document.querySelectorAll('.mobile-menu__link');
    const island = document.querySelector('.site-nav__island');
    
    if (!toggleBtn || !mobileMenu || !island) return;

    let isOpen = false;

    const openMenu = () => {
      isOpen = true;
      mobileMenu.setAttribute('aria-hidden', 'false');
      mobileMenu.removeAttribute('inert');
      toggleBtn.setAttribute('aria-expanded', 'true');
      island.classList.add('is-menu-open');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      isOpen = false;
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileMenu.setAttribute('inert', '');
      toggleBtn.setAttribute('aria-expanded', 'false');
      island.classList.remove('is-menu-open');
      document.body.style.overflow = '';
    };

    // Make sure we don't attach multiple event listeners on page load
    // by cloning the button (optional) or using an AbortController.
    // However, since Astro replaces the DOM body entirely on transition, 
    // the previous elements are detached and garbage collected.
    // So attaching a listener to the *newly* found elements is safe.
    
    toggleBtn.addEventListener('click', (e) => {
      e.preventDefault();
      isOpen ? closeMenu() : openMenu();
    });

    backdrop?.addEventListener('click', closeMenu);
    
    links.forEach(link => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
      }
    });
  }

  // Set up the nav on initial load and subsequent view transitions
  document.addEventListener('astro:page-load', setupNav);
</script>