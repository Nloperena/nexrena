---
import Layout from '../../components/layout/Layout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import PricingOverview from '../../components/sections/PricingOverview.astro';
import { waasPageCopy } from '../../data/pricing';
import { webPageSchema } from '../../lib/schema';

const site = 'https://nexrena.com';
const schema = webPageSchema({
  name: 'Pricing | Nexrena',
  description: 'Managed website plans for small businesses — Launch $149/mo, Growth $249/mo, Lead Engine $399/mo. Hosting, edits, and support included.',
  url: `${site}/pricing`,
});
---

<Layout
  title="Pricing | Nexrena — Managed Website Plans"
  description="Website-as-a-Service for small businesses. Launch $149/mo, Growth $249/mo, Lead Engine $399/mo — hosting, updates, SEO basics, and support included. No huge upfront cost."
  schema={schema}
>
  <main>
    <PageHero
      eyebrow="WEBSITE AS A SERVICE"
      title={waasPageCopy.hero.title}
      subtitle={waasPageCopy.hero.subtitle}
      variant="full"
    />
    <PricingOverview showCta={true} layout="full" />
  </main>
</Layout>
