---
import Layout from '../../components/layout/Layout.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';
import { projects } from '../../data/projects';
import { services } from '../../data/services';
import { industries } from '../../data/industries';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import { heroImages } from '../../data/hero-images';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';

export function getStaticPaths() {
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const site = 'https://nexrena.com';
const projectUrl = `${site}/work/${project.id}`;
const description = project.metaDescription || project.background || project.tagline;
const schema = [
  articleSchema({
    headline: project.name,
    description: description,
    datePublished: project.year,
    url: projectUrl,
  }),
  breadcrumbSchema([
    { name: 'Work', url: `${site}/work` },
    { name: project.name, url: projectUrl },
  ]),
];
---

<Layout 
  title={`${project.name} | Nexrena`} 
  description={description}
  schema={schema}
>
  <main>
    <div class="section-container pt-8 pb-4">
      <Breadcrumb items={[
        { name: 'Work', url: `${site}/work` },
        { name: project.name, url: projectUrl },
      ]} />
    </div>
    
    <!-- Hero Section -->
    <section class="h-[70vh] min-h-[600px] bg-[var(--obsidian)] border-b border-[var(--slate-800)] flex items-center relative overflow-hidden grain">
      <!-- Hero background -->
      <img src={heroImages.work} alt="" class="absolute inset-0 w-full h-full object-cover object-center opacity-30 pointer-events-none z-0" aria-hidden="true" loading="eager" />
      <div class="section-container w-full relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="flex flex-col justify-center reveal">
          <div class="flex flex-wrap items-center gap-4 mb-8">
            <Eyebrow>{project.category}</Eyebrow>
            <span class="w-1 h-1 rounded-full bg-[var(--slate-700)]"></span>
            <span class="font-mono text-[11px] text-[var(--slate-400)]">{project.year}</span>
          </div>
          
          <h1 class="font-display text-[64px] md:text-[96px] text-[var(--warm-white)] leading-none mb-6">
            {project.name}
          </h1>
          
          <div class="flex flex-wrap gap-2 mt-4">
            {project.stack.map(tech => (
              <span class="font-mono text-[10px] text-[var(--gold-dim)] bg-[var(--slate-800)] px-3 py-1.5 uppercase tracking-widest border border-[var(--slate-700)]">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
      
      <!-- Right 40% Hero Object Panel -->
      <div class="hidden lg:flex absolute right-0 top-0 w-[40%] h-full bg-[var(--slate-900)] border-l border-[var(--slate-800)] items-center justify-center overflow-hidden">
        <img 
          src={heroImages[`project/${project.id}` as keyof typeof heroImages] ?? heroImages.work} 
          alt={`${project.name} — ${project.tagline}. Hero object representing ${project.category}.`}
          class="absolute inset-0 w-full h-full object-cover object-center opacity-50"
          loading="eager"
        />
      </div>
    </section>

    <!-- Content Sections -->
    <section class="bg-[var(--obsidian)] py-32">
      <div class="max-w-[800px] mx-auto px-[5vw]">
        
        {project.background && (
          <div class="mb-24 reveal">
            <h2 class="font-mono text-[12px] text-[var(--gold)] uppercase tracking-widest border-b border-[var(--slate-800)] pb-4 mb-8">Client Overview</h2>
            <p class="font-body text-[18px] text-[var(--slate-300)] leading-loose">
              {project.background}
            </p>
          </div>
        )}

        <div class="mb-24 reveal">
          <h2 class="font-mono text-[12px] text-[var(--gold)] uppercase tracking-widest border-b border-[var(--slate-800)] pb-4 mb-8">01 &mdash; Challenge</h2>
          <p class="font-body text-[18px] text-[var(--slate-300)] leading-loose">
            {project.challenge}
          </p>
        </div>

        <div class="mb-24 reveal">
          <h2 class="font-mono text-[12px] text-[var(--gold)] uppercase tracking-widest border-b border-[var(--slate-800)] pb-4 mb-8">02 &mdash; Strategy</h2>
          <p class="font-body text-[18px] text-[var(--slate-300)] leading-loose mb-8">
            {project.solution}
          </p>
          
          {project.approach && (
            <p class="font-body text-[18px] text-[var(--slate-300)] leading-loose mb-8">
              {project.approach}
            </p>
          )}
        </div>

        <div class="reveal">
          <h2 class="font-mono text-[12px] text-[var(--gold)] uppercase tracking-widest border-b border-[var(--slate-800)] pb-4 mb-8">03 &mdash; Results</h2>
          <blockquote class="font-display italic text-[32px] md:text-[40px] text-[var(--warm-white)] leading-tight mb-12">
            "{project.testimonial || 'They transformed our entire digital presence in a matter of weeks.'}"
          </blockquote>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            {project.proofPoints.map((point, i) => (
              <div class="p-8 bg-[var(--slate-900)] border border-[var(--slate-800)] reveal" style={`--i: ${i + 1};`}>
                <span class="block font-display text-[40px] md:text-[48px] text-[var(--gold)] leading-none mb-4">{point.metric}</span>
                <span class="font-body text-[14px] text-[var(--slate-400)] leading-relaxed">{point.context}</span>
              </div>
            ))}
          </div>

          {project.results && (
            <p class="font-body text-[18px] text-[var(--slate-300)] leading-loose">
              {project.results}
            </p>
          )}
        </div>

      </div>
    </section>

    <!-- Related: services and industries -->
    <section class="bg-[var(--obsidian)] py-16 md:py-24 border-t border-[var(--slate-800)]">
      <div class="section-container">
        <h3 class="font-display text-[24px] text-[var(--warm-white)] mb-8">Explore our services and industries.</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <div class="flex flex-wrap gap-4">
              {services.map((s) => (
                <a href={`/services/${s.id}`} class="font-body text-[14px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">
                  {s.title.replace(/\n/g, ' ')}
                </a>
              ))}
            </div>
          </div>
          <div>
            <div class="flex flex-wrap gap-4">
              {industries.map((i) => (
                <a href={`/industries/${i.id}`} class="font-body text-[14px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">
                  {i.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Next Project -->
    <section class="bg-[var(--cream)] py-32 text-center border-t border-[var(--slate-200)] reveal section-transition-top">
      <Eyebrow class="mb-6">NEXT PROJECT</Eyebrow>
      <a href="/work" class="font-display text-[64px] text-[var(--obsidian)] hover:text-[var(--gold)] transition-colors inline-block relative group">
        Explore more work
        <span class="absolute -bottom-2 left-0 w-full h-[2px] bg-[var(--gold)] scale-x-0 origin-left transition-transform duration-300 group-hover:scale-x-100"></span>
      </a>
    </section>

  </main>
</Layout>

<style>
  .section-transition-top {
    clip-path: polygon(0 5%, 100% 0, 100% 100%, 0 100%);
    margin-top: -5%;
    padding-top: calc(5% + 6rem);
  }
</style>
