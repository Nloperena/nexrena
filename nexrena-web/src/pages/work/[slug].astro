---
import Layout from '../../components/layout/Layout.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';
import { projects } from '../../data/projects';
import { services } from '../../data/services';
import { industries } from '../../data/industries';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import CTA from '../../components/sections/CTA.astro';
import HeaderConceptBg from '../../components/ui/HeaderConceptBg.astro';
import { heroImages } from '../../data/hero-images';
import { absoluteUrl, breadcrumbSchema, caseStudySchema } from '../../lib/schema';
import { normalizeInternalHref } from '@/lib/url';

export function getStaticPaths() {
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const nextProject = projects.find(p => p.id === project.nextProjectId);
const projectUrl = absoluteUrl(`/work/${project.id}/`);
const description = project.metaDescription || project.background || project.tagline;
const schema = [
  caseStudySchema({
    name: project.name,
    description,
    datePublished: `${project.year}-01-01`,
    url: projectUrl,
  }),
  breadcrumbSchema([{ name: 'Work', url: absoluteUrl('/work/') }, { name: project.name, url: projectUrl }]),
];

const isVitoFryfilter = project.id === 'vito-fryfilter';
const canEmbed = !isVitoFryfilter && project.url && project.url !== '#';
const hasVimeo = isVitoFryfilter && project.video?.includes('vimeo');
const hasVideo = isVitoFryfilter && project.video && !hasVimeo;
const heroBackground = project.thumbnail || heroImages[`project/${project.id}` as keyof typeof heroImages] || heroImages.work;

function compactText(value?: string, max = 220) {
  if (!value) return '';
  const normalized = value.replace(/\s+/g, ' ').trim();
  if (normalized.length <= max) return normalized;
  return `${normalized.slice(0, max).trimEnd()}...`;
}

const backgroundSummary = compactText(project.background || project.tagline, 190);
const challengeSummary = compactText(project.challenge, 240);
const strategySummary = compactText(project.solution, 240);
const executionSummary = compactText(project.approach || project.solution, 220);
const outcomeSummary = compactText(project.results || project.outcome, 240);
---

<Layout title={`${project.name} | Nexrena`} description={description} schema={schema}>
  <main>

    <!-- ═══ CINEMATIC HERO ═══ -->
    <section class="work-hero relative h-screen min-h-[700px] flex items-end overflow-hidden grain">
      <img
        src={heroBackground}
        alt=""
        aria-hidden="true"
        loading="lazy"
        decoding="async"
        class="hero-image-layer absolute inset-0 w-full h-full object-cover"
      />
      <HeaderConceptBg class="opacity-85" />
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--obsidian)] via-[var(--obsidian)]/60 to-transparent pointer-events-none"></div>

      <div class="relative z-10 w-full max-w-[1320px] mx-auto px-[5vw] pb-20 md:pb-28">
        <Breadcrumb items={[{ name: 'Work', url: absoluteUrl('/work/') }, { name: project.name, url: projectUrl }]} />

        <div class="mt-8 flex flex-wrap items-center gap-4 hero-fade" style="--d:0">
          <span class="font-mono text-[11px] text-[var(--gold-dim)] uppercase tracking-[0.2em]">{project.category}</span>
          <span class="w-1 h-1 rounded-full bg-[var(--slate-600)]"></span>
          <span class="font-mono text-[11px] text-[var(--slate-400)]">{project.year}</span>
        </div>

        <h1 class="font-display text-[clamp(56px,12vw,160px)] text-[var(--warm-white)] leading-[0.9] tracking-tight mt-4 hero-title">
          {project.name}
        </h1>

        <p class="font-body text-[clamp(16px,2vw,22px)] text-[var(--slate-300)] max-w-2xl mt-6 leading-relaxed hero-fade" style="--d:2">
          {project.tagline}
        </p>

        <div class="flex flex-wrap gap-2 mt-8 hero-fade" style="--d:3">
          {project.stack.map(tech => (
            <span class="font-mono text-[10px] text-[var(--gold-dim)] bg-[var(--slate-800)]/60 backdrop-blur-sm px-3 py-1.5 uppercase tracking-widest border border-[var(--slate-700)]/50">
              {tech}
            </span>
          ))}
        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 hero-fade" style="--d:4">
        <span class="font-mono text-[10px] text-[var(--slate-500)] uppercase tracking-widest">Scroll</span>
        <div class="w-px h-10 bg-gradient-to-b from-[var(--gold)] to-transparent scroll-pulse"></div>
      </div>
    </section>

    <!-- ═══ IMPACT STRIP ═══ -->
    <section class="bg-[var(--obsidian)] border-y border-[var(--slate-800)] py-12 md:py-16">
      <div class="max-w-[1320px] mx-auto px-[5vw] grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-0 md:divide-x md:divide-[var(--slate-800)]">
        {project.proofPoints.map((point, i) => (
          <div class="stat-counter md:px-10 first:md:pl-0 last:md:pr-0" data-metric={point.metric}>
            <span class="stat-value block font-display text-[clamp(36px,5vw,64px)] text-[var(--gold)] leading-none">{point.metric}</span>
            <span class="block font-body text-[14px] text-[var(--slate-400)] mt-3 leading-relaxed">{point.context}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══ THE STORY ═══ -->
    <section class="bg-[var(--obsidian)] py-24 md:py-32">
      <div class="max-w-[900px] mx-auto px-[5vw]">
        <div class="mb-12 md:mb-16 reveal">
          <p class="font-body text-[clamp(18px,2.5vw,24px)] text-[var(--slate-300)] leading-relaxed">
            {backgroundSummary}
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 md:mb-16">
          <article class="story-compact reveal" style="--i: 0;">
            <p class="story-kicker">Challenge</p>
            <p class="story-copy">{challengeSummary}</p>
          </article>
          <article class="story-compact reveal" style="--i: 1;">
            <p class="story-kicker">Execution</p>
            <p class="story-copy">{strategySummary}</p>
          </article>
          <article class="story-compact reveal" style="--i: 2;">
            <p class="story-kicker">Outcome</p>
            <p class="story-copy">{outcomeSummary}</p>
          </article>
        </div>

        <div class="story-block mb-20 md:mb-24 reveal">
          <div class="flex items-center justify-between gap-4 mb-6 border-b border-[var(--slate-800)] pb-4">
            <h2 class="font-display text-[clamp(24px,3vw,36px)] text-[var(--warm-white)] leading-tight">Skills Demonstrated</h2>
            <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-[0.2em]">What this project proves</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
            {project.stack.map((tech) => (
              <div class="skill-chip">{tech}</div>
            ))}
          </div>
          <div class="grid grid-cols-1 gap-4">
            {project.stackNotes.map((note) => (
              <div class="skill-note">{note}</div>
            ))}
          </div>
          {project.approach && (
            <p class="font-body text-[15px] text-[var(--slate-400)] leading-relaxed mt-8">{executionSummary}</p>
          )}
        </div>

        <!-- ═══ KEY SEO MOVES ═══ -->
        <div class="story-block mb-20 md:mb-28">
          <div class="flex items-baseline gap-6 mb-8 border-b border-[var(--slate-800)] pb-6 reveal">
            <span class="font-display text-[clamp(48px,6vw,80px)] text-[var(--gold)] leading-none opacity-20">03</span>
            <h2 class="font-display text-[clamp(28px,3vw,40px)] text-[var(--warm-white)] leading-tight">Key SEO Moves</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {project.seoHighlights.map((h, i) => (
              <div class="seo-card group p-6 border border-[var(--slate-800)] hover:border-[var(--gold)]/30 transition-all duration-500 relative overflow-hidden">
                <div class="absolute top-3 right-4 font-display text-[52px] text-[var(--gold)] opacity-[0.06] leading-none pointer-events-none select-none">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <h3 class="font-display text-[19px] text-[var(--warm-white)] mb-3 leading-snug relative z-10">{h.title}</h3>
                <p class="font-body text-[14px] text-[var(--slate-400)] leading-relaxed relative z-10">{compactText(h.description, 135)}</p>
                <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-[var(--gold)]/0 via-[var(--gold)]/40 to-[var(--gold)]/0 scale-x-0 group-hover:scale-x-100 transition-transform duration-700"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ WEBSITE PREVIEW ═══ -->
    <section class="bg-[var(--slate-900)] py-24 md:py-32 border-y border-[var(--slate-800)]">
      <div class="max-w-[1320px] mx-auto px-[5vw]">
        <Eyebrow class="mb-4">THE WORK //</Eyebrow>
        <h2 class="font-display text-[clamp(32px,4vw,56px)] text-[var(--warm-white)] mb-12 leading-tight reveal">
          See it live.
        </h2>

        <div class="browser-frame rounded-lg overflow-hidden border border-[var(--slate-700)] shadow-2xl reveal">
          <div class="browser-bar flex items-center gap-2 px-4 py-3 bg-[var(--slate-800)] border-b border-[var(--slate-700)]">
            <div class="flex gap-1.5">
              <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
              <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
              <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
            </div>
            {project.url !== '#' && (
              <div class="flex-1 mx-4">
                <div class="bg-[var(--slate-900)] rounded-md px-4 py-1.5 text-center">
                  <span class="font-mono text-[11px] text-[var(--slate-400)]">{project.url.replace('https://', '')}</span>
                </div>
              </div>
            )}
          </div>

          <div class="bg-[var(--obsidian)] aspect-video relative">
            {canEmbed ? (
              <iframe
                src={project.url}
                class="w-full h-full border-0"
                loading="lazy"
                title={`${project.name} live website`}
              />
            ) : hasVimeo ? (
              <iframe
                src={project.video}
                class="w-full h-full border-0"
                loading="lazy"
                allow="autoplay; fullscreen"
                allowfullscreen
                title={`${project.name} project preview`}
              />
            ) : hasVideo ? (
              <video autoplay muted loop playsinline class="w-full h-full object-cover" poster={project.thumbnail}>
                <source src={project.video} type={project.video!.endsWith('.webm') ? 'video/webm' : 'video/mp4'} />
              </video>
            ) : project.thumbnail ? (
              <img src={project.thumbnail} alt={`${project.name} — ${project.tagline}`} class="w-full h-full object-cover" loading="lazy" />
            ) : null}
          </div>
        </div>

        {project.url !== '#' && (
          <div class="mt-8 text-center reveal">
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 font-mono text-[13px] text-[var(--gold)] hover:text-[var(--gold-light)] transition-colors uppercase tracking-widest">
              Visit live site
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </a>
          </div>
        )}
      </div>
    </section>

    <!-- ═══ THE IMPACT ═══ -->
    <section class="bg-[var(--obsidian)] py-24 md:py-32">
      <div class="max-w-[900px] mx-auto px-[5vw]">
        <div class="reveal">
          <div class="flex items-baseline gap-6 mb-8 border-b border-[var(--slate-800)] pb-6">
            <span class="font-display text-[clamp(48px,6vw,80px)] text-[var(--gold)] leading-none opacity-20">04</span>
            <h2 class="font-display text-[clamp(28px,3vw,40px)] text-[var(--warm-white)] leading-tight">Business Impact</h2>
          </div>
          <p class="font-body text-[17px] text-[var(--slate-300)] leading-relaxed mb-6">{outcomeSummary}</p>
          {project.testimonial && (
            <blockquote class="impact-quote">{compactText(project.testimonial, 120)}</blockquote>
          )}
        </div>
      </div>
    </section>

    <!-- ═══ EXPLORE ═══ -->
    <section class="bg-[var(--obsidian)] py-16 border-t border-[var(--slate-800)]">
      <div class="max-w-[1320px] mx-auto px-[5vw]">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <Eyebrow class="mb-4">Services</Eyebrow>
            <div class="flex flex-wrap gap-3">
              {services.map(s => (
                <a href={normalizeInternalHref(`/services/${s.id}`)} class="font-body text-[14px] text-[var(--slate-400)] hover:text-[var(--gold)] transition-colors">{s.title.replace(/\n/g, ' ')}</a>
              ))}
            </div>
          </div>
          <div>
            <Eyebrow class="mb-4">Industries</Eyebrow>
            <div class="flex flex-wrap gap-3">
              {industries.map(ind => (
                <a href={normalizeInternalHref(`/industries/${ind.id}`)} class="font-body text-[14px] text-[var(--slate-400)] hover:text-[var(--gold)] transition-colors">{ind.name}</a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ NEXT PROJECT ═══ -->
    <section class="next-project relative h-[50vh] min-h-[400px] flex items-center justify-center overflow-hidden border-t border-[var(--slate-800)] group cursor-pointer">
      {nextProject ? (
        <a href={normalizeInternalHref(`/work/${nextProject.id}`)} class="absolute inset-0 z-10 flex flex-col items-center justify-center text-center">
          <Eyebrow class="mb-4">NEXT PROJECT</Eyebrow>
          <span class="font-display text-[clamp(48px,8vw,120px)] text-[var(--warm-white)] leading-none group-hover:text-[var(--gold)] transition-colors duration-500">{nextProject.name}</span>
          <span class="mt-4 font-mono text-[12px] text-[var(--slate-500)] uppercase tracking-widest group-hover:text-[var(--gold-dim)] transition-colors">View case study &rarr;</span>
        </a>
      ) : (
        <a href="/work/" class="absolute inset-0 z-10 flex flex-col items-center justify-center text-center">
          <Eyebrow class="mb-4">MORE WORK</Eyebrow>
          <span class="font-display text-[clamp(48px,8vw,120px)] text-[var(--warm-white)] leading-none group-hover:text-[var(--gold)] transition-colors duration-500">Explore all work</span>
        </a>
      )}
      <div class="absolute inset-0 bg-[var(--obsidian)] group-hover:bg-[var(--slate-900)] transition-colors duration-700"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(201,169,110,0.04)_0%,transparent_60%)] opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
    </section>

    <CTA />

  </main>
</Layout>

<style>
  .work-hero {
    isolation: isolate;
    padding-top: max(96px, calc(var(--nav-safe, 72px) + 24px));
  }

  .hero-image-layer {
    z-index: 0;
    filter: saturate(0.92) contrast(1.04);
    transform: scale(1.015);
  }

  .hero-title {
    opacity: 0;
    clip-path: inset(0 0 100% 0);
    animation: titleReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }
  .hero-fade {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.4s + var(--d, 0) * 0.1s);
  }
  @keyframes titleReveal {
    to { opacity: 1; clip-path: inset(0 0 0% 0); }
  }
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  .scroll-pulse {
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.3); }
  }
  .seo-card {
    background: linear-gradient(135deg, rgba(201,169,110,0.02) 0%, transparent 60%);
  }

  .story-compact {
    border: 1px solid var(--slate-800);
    background: rgba(18, 22, 26, 0.65);
    padding: 20px;
  }

  .story-kicker {
    margin-bottom: 10px;
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold-dim);
  }

  .story-copy {
    font-family: var(--font-body, system-ui);
    font-size: 15px;
    line-height: 1.65;
    color: var(--slate-300);
  }

  .skill-chip {
    border: 1px solid var(--slate-700);
    background: rgba(201, 169, 110, 0.06);
    color: var(--warm-white);
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 10px 12px;
  }

  .skill-note {
    border-left: 1px solid rgba(201, 169, 110, 0.4);
    padding-left: 14px;
    color: var(--slate-300);
    font-size: 14px;
    line-height: 1.6;
    font-family: var(--font-body, system-ui);
  }

  .impact-quote {
    border: 1px solid var(--slate-800);
    background: rgba(201, 169, 110, 0.05);
    color: var(--warm-white);
    font-size: 16px;
    line-height: 1.6;
    font-style: italic;
    padding: 16px 18px;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-fade { animation: none !important; opacity: 1 !important; clip-path: none !important; transform: none !important; }
    .scroll-pulse { animation: none !important; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initWorkDetail() {
    gsap.registerPlugin(ScrollTrigger);
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    document.querySelectorAll('.stat-counter').forEach(el => {
      const valueEl = el.querySelector('.stat-value');
      const metric = el.getAttribute('data-metric') || '';
      if (!valueEl) return;
      const match = metric.match(/^([+\-]?)(\d+)(.*)/);
      if (!match) return;
      const [, prefix, numStr, suffix] = match;
      const target = parseInt(numStr, 10);
      const counter = { val: 0 };
      gsap.to(counter, {
        val: target, duration: 2, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        onUpdate: () => { valueEl.textContent = `${prefix}${Math.round(counter.val)}${suffix}`; },
      });
    });

    gsap.utils.toArray<HTMLElement>('.seo-card').forEach((card, i) => {
      gsap.from(card, {
        y: 40, opacity: 0, duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: card, start: 'top 88%', once: true },
        delay: i * 0.1,
      });
    });
  }

  document.addEventListener('astro:page-load', initWorkDetail);
</script>
