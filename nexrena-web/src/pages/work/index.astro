---
import Layout from '../../components/layout/Layout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import { projects } from '../../data/projects';
import { services } from '../../data/services';
import { industries } from '../../data/industries';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import { heroImages } from '../../data/hero-images';
import { itemListSchema } from '../../lib/schema';

const site = 'https://nexrena.com';
const projectItems = projects.map((p) => ({
  name: p.name,
  url: `${site}/work/${p.id}`,
}));
---

<Layout 
  title="Work | Nexrena" 
  description="Selected case studies: B2B web design, ecommerce, and digital growth projects. See how we build sites that convert."
  schema={itemListSchema(projectItems, 'Nexrena Case Studies')}
>
  <main>
    <PageHero 
      eyebrow="OUR WORK //" 
      title="Selected Projects"
      subtitle="Projects built to perform. Each one designed to capture leads, accelerate sales, and compound in value."
      image={heroImages.work}
    />
    <div class="section-container pt-16 pb-48">
      
      <!-- Table Header -->
      <div class="hidden md:grid grid-cols-12 gap-4 border-b border-[var(--slate-700)] pb-4 mb-4 font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">
        <div class="col-span-1">No.</div>
        <div class="col-span-4">Client</div>
        <div class="col-span-2">Category</div>
        <div class="col-span-3">Impact</div>
        <div class="col-span-1">Year</div>
        <div class="col-span-1 text-right">Link</div>
      </div>

      <!-- Table Rows -->
      <div class="flex flex-col relative" id="work-list">
        {projects.map((project, i) => (
          <a href={`/work/${project.id}`} class="work-row group grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-4 items-start md:items-center py-8 border-b border-[var(--slate-700)] transition-colors hover:bg-[var(--slate-800)] md:-mx-4 md:px-4" data-index={i} data-thumbnail={project.thumbnail || heroImages[`project/${project.id}` as keyof typeof heroImages] || ''}>
            <div class="md:col-span-1 font-display text-[24px] text-[var(--slate-400)] font-light hidden md:block">0{i + 1}</div>
            <div class="md:col-span-4 font-display text-[32px] md:text-[28px] text-[var(--warm-white)] group-hover:text-[var(--gold)] transition-colors leading-none mb-2 md:mb-0">{project.name}</div>
            <div class="md:col-span-2 font-body text-[14px] text-[var(--slate-400)]">{project.category}</div>
            <div class="md:col-span-3 font-mono text-[11px] text-[var(--slate-300)] opacity-70 group-hover:opacity-100 transition-opacity bg-[var(--slate-900)] px-2 py-1 inline-block w-max border border-[var(--slate-700)]">{project.proofPoints?.[0]?.metric || 'View Results'}</div>
            <div class="md:col-span-1 font-mono text-[11px] text-[var(--slate-400)]">{project.year}</div>
            <div class="md:col-span-1 md:text-right font-mono text-[11px] text-[var(--gold)] group-hover:translate-x-2 transition-transform mt-4 md:mt-0">View &rarr;</div>
          </a>
        ))}
      </div>
    </div>

    <!-- Internal links: services and industries -->
    <section class="section-container py-16 md:py-24 border-t border-[var(--slate-700)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h3 class="font-mono text-[11px] text-[var(--gold-dim)] uppercase tracking-widest mb-4">Services</h3>
          <div class="flex flex-wrap gap-4">
            {services.map((s) => (
              <a href={`/services/${s.id}`} class="font-body text-[14px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">
                {s.title.replace(/\n/g, ' ')}
              </a>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-mono text-[11px] text-[var(--gold-dim)] uppercase tracking-widest mb-4">Industries</h3>
          <div class="flex flex-wrap gap-4">
            {industries.map((i) => (
              <a href={`/industries/${i.id}`} class="font-body text-[14px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">
                {i.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Hover Preview Floating Div -->
  <div id="hover-preview" class="fixed w-[360px] h-[260px] rounded-lg bg-[var(--obsidian)] border border-[var(--slate-700)] pointer-events-none z-50 overflow-hidden hidden md:flex items-center justify-center" style="opacity: 0; right: 60px; top: 50%;">
    <img id="hover-preview-img" src="" alt="" class="w-full h-full object-cover" />
  </div>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    function initWorkListAnimations() {
      gsap.registerPlugin(ScrollTrigger);
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const rows = gsap.utils.toArray('.work-row') as HTMLElement[];
      if (!rows.length) return;

      gsap.set(rows, { opacity: 0, y: 30 });
      ScrollTrigger.batch(rows, {
        start: 'top 90%',
        onEnter: (batch) => {
          gsap.to(batch, { opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: 'power3.out' });
        },
        once: true,
      });
    }

    document.addEventListener('astro:page-load', initWorkListAnimations);

    function setupHoverPreview() {
      const rows = document.querySelectorAll('.work-row');
      const preview = document.getElementById('hover-preview');
      const previewImg = document.getElementById('hover-preview-img') as HTMLImageElement | null;
      if (!preview || !previewImg || window.innerWidth < 768) return;

      let targetY = 0;
      let currentY = 0;
      let isVisible = false;
      let rafId = 0;

      function lerp() {
        currentY += (targetY - currentY) * 0.12;
        preview!.style.top = `${currentY}px`;
        preview!.style.transform = `translateY(-50%)`;
        if (isVisible) rafId = requestAnimationFrame(lerp);
      }

      rows.forEach((row) => {
        const thumbnail = (row as HTMLElement).dataset.thumbnail;

        row.addEventListener('mouseenter', () => {
          if (!thumbnail) return;
          previewImg.src = thumbnail;
          isVisible = true;
          gsap.to(preview, { opacity: 1, scale: 1, duration: 0.4, ease: 'power3.out' });
          lerp();
        });

        row.addEventListener('mouseleave', () => {
          isVisible = false;
          cancelAnimationFrame(rafId);
          gsap.to(preview, { opacity: 0, scale: 0.95, duration: 0.3, ease: 'power2.in' });
        });

        row.addEventListener('mousemove', (e) => {
          targetY = (e as MouseEvent).clientY;
        });
      });
    }

    document.addEventListener('astro:page-load', setupHoverPreview);
  </script>
</Layout>
