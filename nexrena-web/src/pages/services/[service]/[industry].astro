---
import Layout from '@/components/layout/Layout.astro';
import Breadcrumb from '@/components/seo/Breadcrumb.astro';
import PageHero from '@/components/sections/PageHero.astro';
import Button from '@/components/ui/Button.astro';
import Eyebrow from '@/components/ui/Eyebrow.astro';
import { services } from '@/data/services';
import { industries } from '@/data/industries';
import { heroImages } from '@/data/hero-images';
import { crossContent } from '@/data/cross-content';
import { absoluteUrl, webPageSchema, breadcrumbSchema } from '@/lib/schema';
import { getCollection } from 'astro:content';
import { getFaqLinkForIndustry, getPreferredBlogCategoriesForServiceIndustry } from '@/data/seo-internal-links';

const KEEP_MATRIX_PATHS = new Set([
  'web-design/manufacturing',
  'seo-growth/manufacturing',
]);

export function getStaticPaths() {
  const paths: Array<{ params: { service: string; industry: string }; props: { service: typeof services[0]; industry: typeof industries[0] } }> = [];
  for (const service of services) {
    for (const industry of industries) {
      paths.push({
        params: { service: service.id, industry: industry.id },
        props: { service, industry },
      });
    }
  }
  return paths;
}

const { service, industry } = Astro.props;
const matrixKey = `${service.id}/${industry.id}`;
const shouldKeepMatrixPage = KEEP_MATRIX_PATHS.has(matrixKey);
if (!shouldKeepMatrixPage) {
  return Astro.redirect(`/services/${service.id}/`, 301);
}
const serviceTitle = service.title.replace(/\n/g, ' ');
const pageUrl = absoluteUrl(`/services/${service.id}/${industry.id}`);
const pageTitle = `${serviceTitle} for ${industry.name}`;

const content = crossContent[`${service.id}/${industry.id}`];
const pageDescription = content?.intro ?? `${serviceTitle} for ${industry.name.toLowerCase()}. ${industry.subhead}`;

const schema = [
  webPageSchema({ name: pageTitle, description: pageDescription, url: pageUrl }),
  breadcrumbSchema([
    { name: 'Services', url: absoluteUrl('/services') },
    { name: serviceTitle, url: absoluteUrl(`/services/${service.id}`) },
    { name: industry.name, url: pageUrl },
  ]),
];

const industryImage = heroImages[`industries/${industry.id}` as keyof typeof heroImages] ?? heroImages.industries;
const preferredCategories = new Set(getPreferredBlogCategoriesForServiceIndustry(service.id, industry.id));
const relatedPosts = (await getCollection('blog'))
  .filter((post) => preferredCategories.has(post.data.category))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
const faqLink = getFaqLinkForIndustry(industry.id);
---

<Layout title={`${pageTitle} | Nexrena`} description={pageDescription} schema={schema}>
  <main>
    <div class="section-container pt-8 pb-4">
      <Breadcrumb items={[
        { name: 'Services', url: absoluteUrl('/services') },
        { name: serviceTitle, url: absoluteUrl(`/services/${service.id}`) },
        { name: industry.name, url: pageUrl },
      ]} />
    </div>
    <PageHero
      eyebrow={`${serviceTitle.toUpperCase()} // ${industry.name.toUpperCase()}`}
      title={content?.headline ?? `${serviceTitle} for ${industry.name}.`}
      subtitle={pageDescription}
      image={industryImage}
    />

    {content && (
      <section class="bg-[var(--obsidian)] border-b border-[var(--slate-800)]">
        <div class="section-container py-16">
          <p class="font-body text-[18px] text-[var(--slate-300)] leading-relaxed max-w-3xl reveal">
            {content.intro}
          </p>
        </div>
      </section>
    )}

    <section class="bg-[var(--obsidian)] py-12 md:py-24">
      <div class="section-container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
          <div class="reveal">
            <Eyebrow class="mb-6">CHALLENGES //</Eyebrow>
            <h2 class="font-display text-[28px] text-[var(--warm-white)] mb-8">
              What {industry.name.toLowerCase()} companies face.
            </h2>
            <ul class="space-y-6">
              {(content?.challenges ?? industry.painPoints).map((point) => (
                <li class="font-body text-[16px] text-[var(--slate-400)] flex gap-4">
                  <span class="text-[var(--gold)] shrink-0">—</span>
                  {point}
                </li>
              ))}
            </ul>
          </div>
          <div class="reveal" style="--i: 1;">
            <Eyebrow class="mb-6">OUR APPROACH //</Eyebrow>
            <h2 class="font-display text-[28px] text-[var(--warm-white)] mb-8">
              How we apply {serviceTitle.toLowerCase()}.
            </h2>
            <ul class="space-y-6">
              {(content?.approach ?? industry.solutions).map((solution) => (
                <li class="font-body text-[16px] text-[var(--slate-400)] flex gap-4">
                  <span class="text-[var(--gold)] shrink-0">—</span>
                  {solution}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    {content?.outcomes && (
      <section class="bg-[var(--slate-900)] py-16 md:py-24 border-y border-[var(--slate-800)]">
        <div class="section-container">
          <Eyebrow class="mb-6">EXPECTED OUTCOMES //</Eyebrow>
          <h2 class="font-display text-[28px] text-[var(--warm-white)] mb-12 reveal">What you can expect.</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {content.outcomes.map((outcome, i) => (
              <div class="flex gap-4 reveal" style={`--i: ${i + 1};`}>
                <span class="font-mono text-[14px] text-[var(--gold)] shrink-0">0{i + 1}</span>
                <p class="font-body text-[16px] text-[var(--slate-300)] leading-relaxed">{outcome}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="bg-[var(--obsidian)] py-16 border-y border-[var(--slate-800)]">
      <div class="section-container">
        <div class="flex items-end justify-between gap-6 mb-8">
          <div>
            <h3 class="font-display text-[30px] text-[var(--warm-white)]">Related guides</h3>
            <p class="font-body text-[15px] text-[var(--slate-400)] mt-2">
              Supporting resources for {industry.name.toLowerCase()} teams evaluating {serviceTitle.toLowerCase()}.
            </p>
          </div>
          <a href={faqLink.href} class="font-mono text-[11px] text-[var(--gold)] uppercase tracking-wider hover:text-[var(--gold-light)] transition-colors">
            {faqLink.title} &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map((post) => (
            <a href={`/resources/blog/${post.slug}/`} class="block p-6 border border-[var(--slate-800)] hover:border-[var(--gold)]/40 transition-colors">
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--gold)]">
                {post.data.category.replace('-', ' ')}
              </span>
              <h4 class="font-display text-[22px] text-[var(--warm-white)] mt-3 mb-3 leading-tight">{post.data.title}</h4>
              <p class="font-body text-[14px] text-[var(--slate-400)] line-clamp-3">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[var(--cream)] py-24 md:py-32 text-[var(--obsidian)]">
      <div class="section-container">
        <div class="max-w-2xl">
          <h2 class="font-display text-[40px] md:text-[56px] leading-[1.15] font-light mb-8 reveal">
            Ready to grow?
          </h2>
          <p class="font-body text-[17px] text-[var(--slate-600)] mb-12 reveal" style="--i: 1;">
            Let's map your 90-day {serviceTitle.toLowerCase()} strategy for {industry.name.toLowerCase()}. We'll audit your current setup and build a plan that fits.
          </p>
          <Button href="/contact" variant="primary" class="reveal" style="--i: 2;">
            {industry.ctaLabel} &rarr;
          </Button>
        </div>
      </div>
    </section>
  </main>
</Layout>
