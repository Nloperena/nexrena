---
import Layout from '../../components/layout/Layout.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';
import ServiceHero from '../../components/sections/ServiceHero.astro';
import StickyScroll from '../../components/sections/StickyScroll.astro';
import FeatureGrid from '../../components/sections/FeatureGrid.astro';
import ProcessTimeline from '../../components/sections/ProcessTimeline.astro';
import Button from '../../components/ui/Button.astro';
import { services } from '../../data/services';
import { industries } from '../../data/industries';
import { heroImages } from '../../data/hero-images';
import { absoluteUrl, serviceSchema, breadcrumbSchema } from '../../lib/schema';
import { getCollection } from 'astro:content';
import { getPreferredBlogCategoriesForService } from '../../data/seo-internal-links';

export function getStaticPaths() {
  return services.map((service, i) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const serviceTitle = service.title.replace(/\n/g, ' ');
const serviceImage = heroImages[`services/${service.id}` as keyof typeof heroImages] ?? heroImages.services;
const serviceUrl = absoluteUrl(`/services/${service.id}`);
const schema = [
  serviceSchema(service),
  breadcrumbSchema([
    { name: 'Services', url: absoluteUrl('/services') },
    { name: serviceTitle, url: serviceUrl },
  ]),
];
const preferredCategories = new Set(getPreferredBlogCategoriesForService(service.id));
const relatedPosts = (await getCollection('blog'))
  .filter((post) => preferredCategories.has(post.data.category))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---

<Layout 
  title={`${serviceTitle} | Nexrena`} 
  description={service.metaDescription || `${service.body} ${service.intro}`}
  schema={schema}
>
  <main>
    <div class="section-container pt-8 pb-4">
      <Breadcrumb items={[
        { name: 'Services', url: absoluteUrl('/services') },
        { name: serviceTitle, url: serviceUrl },
      ]} />
    </div>
    <ServiceHero 
      title={service.title}
      subtitle={service.heroSubtitle || service.intro}
      number={service.number}
      tags={service.tags}
      image={serviceImage}
    />
    
    {service.problem && (
      <StickyScroll 
        statement={service.problem.statement}
        agitation={service.problem.agitation}
        statusQuoTitle={service.problem.statusQuoTitle}
        shiftTitle={service.problem.shiftTitle}
        statusQuoItems={service.problem.statusQuoItems}
        shiftItems={service.problem.shiftItems}
      />
    )}

    {service.features && (
      <FeatureGrid 
        features={service.features}
        outcomes={service.outcomes}
        heading={service.featureHeading}
        outcomesHeading={service.outcomesHeading}
      />
    )}

    {service.process && (
      <ProcessTimeline
        process={service.process}
        heading={service.processHeading}
        description={service.processDescription}
      />
    )}

    <!-- Industry focus: internal links -->
    <section class="bg-[var(--slate-900)] py-16 md:py-24 border-t border-[var(--slate-800)]">
      <div class="section-container">
        <h3 class="font-display text-[24px] text-[var(--warm-white)] mb-8">We serve these industries.</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {industries.map((industry) => (
            <div class="flex flex-col gap-2">
              <a href={`/industries/${industry.id}/`} class="font-body text-[15px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors font-medium">
                {industry.name}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[var(--obsidian)] py-16 border-t border-[var(--slate-800)]">
      <div class="section-container">
        <div class="flex items-end justify-between gap-6 mb-8">
          <div>
            <h3 class="font-display text-[30px] text-[var(--warm-white)]">Related guides</h3>
            <p class="font-body text-[15px] text-[var(--slate-400)] mt-2">
              Supporting resources for teams evaluating {serviceTitle.toLowerCase()}.
            </p>
          </div>
          <a href="/resources/faq/" class="font-mono text-[11px] text-[var(--gold)] uppercase tracking-wider hover:text-[var(--gold-light)] transition-colors">
            Browse FAQ &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map((post) => (
            <a href={`/resources/blog/${post.slug}/`} class="block p-6 border border-[var(--slate-800)] hover:border-[var(--gold)]/40 transition-colors">
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--gold)]">
                {post.data.category.replace('-', ' ')}
              </span>
              <h4 class="font-display text-[22px] text-[var(--warm-white)] mt-3 mb-3 leading-tight">{post.data.title}</h4>
              <p class="font-body text-[14px] text-[var(--slate-400)] line-clamp-3">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ & Final CTA Section -->
    <section class="bg-[var(--obsidian)] py-32 border-t border-[var(--slate-800)] relative z-20">
      <div class="section-container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
          
          <!-- FAQs -->
          <div class="reveal">
            <h3 class="font-display text-[40px] text-[var(--warm-white)] mb-12">Common questions.</h3>
            <div class="space-y-0">
              {service.faq?.map((item, i) => (
                <details class="faq-item group border-b border-[var(--slate-800)]" data-idx={i}>
                  <summary class="flex items-center justify-between py-6 cursor-pointer list-none font-body text-[18px] text-[var(--slate-200)] font-medium hover:text-[var(--gold)] transition-colors select-none">
                    {item.q}
                    <span class="faq-icon shrink-0 ml-4 w-8 h-8 rounded-full border border-[var(--slate-700)] flex items-center justify-center text-[var(--gold)] transition-transform duration-300 group-open:rotate-45">
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 1v12M1 7h12"/></svg>
                    </span>
                  </summary>
                  <div class="pb-6 font-body text-[15px] text-[var(--slate-400)] leading-relaxed max-w-2xl">
                    {item.a}
                  </div>
                </details>
              ))}
            </div>
          </div>

          <!-- CTA -->
          <div class="bg-[var(--slate-900)] p-12 lg:p-16 border border-[var(--slate-800)] flex flex-col justify-center reveal" style="--i: 1;">
            <h3 class="font-display text-[48px] text-[var(--warm-white)] leading-[1.1] mb-6">
              Is this a fit for your team?
            </h3>
            <p class="font-body text-[16px] text-[var(--slate-400)] mb-12">
              {service.cta.helper}
            </p>
            <div class="flex flex-col sm:flex-row gap-6">
              <Button href="/contact" variant="primary">
                {service.cta.label} &rarr;
              </Button>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>
