---
import Layout from '../../components/layout/Layout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Button from '../../components/ui/Button.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import CTA from '../../components/sections/CTA.astro';
import { founder } from '../../data/founder';
import { breadcrumbSchema, founderPersonSchema, webPageSchema } from '../../lib/schema';

const site = 'https://nexrena.com';
const pageUrl = `${site}/about/leadership/`;

const schema = [
  webPageSchema({
    name: 'Leadership | Nexrena',
    description:
      'Meet Nico Loperena — founder and lead architect of Nexrena. Verified senior full-stack engineer behind B2B web design, SEO, and delivery in Kissimmee & Central Florida.',
    url: pageUrl,
  }),
  breadcrumbSchema([
    { name: 'Home', url: `${site}/` },
    { name: 'About', url: `${site}/about/` },
    { name: 'Leadership', url: pageUrl },
  ]),
  founderPersonSchema(),
];
---

<Layout
  title="Leadership | Nexrena — Founder & Lead Architect"
  description="Nico Loperena founded Nexrena to deliver senior full-stack web design, SEO, and B2B growth from Kissimmee, FL. View his technical portfolio and resume."
  schema={schema}
>
  <main>
    <PageHero
      eyebrow="LEADERSHIP //"
      title="A verified senior engineer behind the agency."
      subtitle="Nexrena is led by Nicholas Loperena — full-stack operator, not a coordination layer. Technical portfolio and resume live at NicoLoperena.com."
    />

    <section class="bg-[var(--obsidian)] border-b border-[var(--slate-800)]">
      <div class="max-w-[1320px] mx-auto px-[5vw] py-32">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-start">
          <div class="lg:col-span-5 reveal">
            <a
              href={founder.portfolioUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="block aspect-[4/5] bg-[var(--slate-800)] border border-[var(--slate-700)] overflow-hidden relative group"
              aria-label="Open Nico Loperena technical portfolio"
            >
              <img
                src={founder.photoUrl}
                alt={`${founder.legalName}, founder of Nexrena`}
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
                loading="eager"
              />
              <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-[var(--obsidian)] to-transparent p-6">
                <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--gold)]">
                  Technical portfolio ↗
                </p>
              </div>
            </a>
          </div>

          <div class="lg:col-span-7 reveal" style="--i: 2;">
            <Eyebrow class="mb-6">{founder.roleLine.toUpperCase()} //</Eyebrow>
            <h2 class="font-display text-[36px] md:text-[48px] text-[var(--warm-white)] leading-[1.1] mb-8">
              {founder.legalName}
            </h2>
            <p class="font-body text-[17px] leading-loose text-[var(--slate-300)] mb-8">
              {founder.summary}
            </p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
              {founder.credentials.map((item) => (
                <li class="font-mono text-[11px] uppercase tracking-widest text-[var(--slate-400)] border border-[var(--slate-800)] px-4 py-3">
                  {item}
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-4 pt-8 border-t border-[var(--slate-800)]">
              <Button href={founder.portfolioUrl} variant="primary" target="_blank" rel="noopener noreferrer">
                NicoLoperena.com ↗
              </Button>
              <Button href={founder.resumeUrl} variant="outline" target="_blank" rel="noopener noreferrer">
                Download resume ↗
              </Button>
              <Button href="/about/" variant="outline">About Nexrena</Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[var(--slate-900)] border-b border-[var(--slate-800)]">
      <div class="max-w-[1320px] mx-auto px-[5vw] py-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <div class="reveal">
            <Eyebrow class="mb-6">FOR RECRUITERS & CTOs //</Eyebrow>
            <h2 class="font-display text-[40px] md:text-[52px] text-[var(--warm-white)] leading-[1.05] mb-6">
              Two sites. Two intents.
            </h2>
            <p class="font-body text-[17px] text-[var(--slate-400)] leading-relaxed mb-6">
              <strong class="text-[var(--warm-white)]">NicoLoperena.com</strong> is the technical portfolio — stack depth, employment history, engineering blog, and resume for hiring teams.
            </p>
            <p class="font-body text-[17px] text-[var(--slate-300)] leading-relaxed">
              <strong class="text-[var(--warm-white)]">Nexrena.com</strong> is the agency — B2B web design, SEO systems, case studies with ROI, and how to engage the studio for growth work in Kissimmee, Orlando, and remote US teams.
            </p>
          </div>

          <div class="flex flex-col gap-4 reveal" style="--i: 2;">
            <a
              href={founder.portfolioUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group border border-[var(--slate-800)] bg-[var(--obsidian)] p-8 hover:border-[var(--gold)]/40 transition-colors"
            >
              <p class="font-mono text-[10px] text-[var(--gold)] uppercase tracking-[0.2em] mb-3">Personal · Technical</p>
              <h3 class="font-display text-[28px] text-[var(--warm-white)] mb-2">NicoLoperena.com</h3>
              <p class="font-body text-[15px] text-[var(--slate-400)]">Resume, experience, GitHub, LinkedIn, and engineering blog.</p>
              <span class="mt-4 inline-block font-mono text-[11px] uppercase tracking-widest text-[var(--slate-300)] group-hover:text-[var(--gold)] transition-colors">
                Open portfolio ↗
              </span>
            </a>
            <a
              href={founder.blogUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group border border-[var(--slate-800)] bg-[var(--obsidian)] p-8 hover:border-[var(--gold)]/40 transition-colors"
            >
              <p class="font-mono text-[10px] text-[var(--gold)] uppercase tracking-[0.2em] mb-3">Thought leadership</p>
              <h3 class="font-display text-[28px] text-[var(--warm-white)] mb-2">Engineering blog</h3>
              <p class="font-body text-[15px] text-[var(--slate-400)]">Long-form notes on React, Astro, PostgreSQL, and remote delivery.</p>
              <span class="mt-4 inline-block font-mono text-[11px] uppercase tracking-widest text-[var(--slate-300)] group-hover:text-[var(--gold)] transition-colors">
                Read articles ↗
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
</Layout>
