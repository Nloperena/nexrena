---
import Layout from '../components/layout/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Marquee from '../components/sections/Marquee.astro';
import ManifestoStrip from '../components/sections/ManifestoStrip.astro';
import About from '../components/sections/About.astro';
import ServiceStack from '../components/sections/ServiceStack.astro';
import TrustSignals from '../components/sections/TrustSignals.astro';
import Work from '../components/sections/Work.astro';
import ProcessSticky from '../components/sections/ProcessSticky.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTA from '../components/sections/CTA.astro';
import { organizationSchema } from '../lib/schema';
---

<Layout schema={organizationSchema()}>
  <main>
    <Hero />
    <Marquee />
    <ManifestoStrip />
    <About />
    <ServiceStack />
    <TrustSignals />
    <Work />
    <ProcessSticky />
    <Testimonials />
    <CTA />
  </main>
</Layout>
