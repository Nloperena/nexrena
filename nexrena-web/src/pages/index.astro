---
import Layout from '../components/layout/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Showreel from '../components/sections/Showreel.astro';
import ClientsStrip from '../components/sections/ClientsStrip.astro';
import BuyerClarity from '../components/sections/BuyerClarity.astro';
import Work from '../components/sections/Work.astro';
import ServiceStack from '../components/sections/ServiceStack.astro';
import StorySequence from '../components/sections/StorySequence.astro';
import ProcessSticky from '../components/sections/ProcessSticky.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import PricingOverview from '../components/sections/PricingOverview.astro';
import CTA from '../components/sections/CTA.astro';
import { organizationSchema } from '../lib/schema';
import { heroImages } from '../data/hero-images';
---

<Layout
  title="Nexrena | Orlando & Kissimmee Web Design + SEO for B2B Teams"
  description="Orlando and Kissimmee web design, SEO, and full-service digital growth for B2B teams. Conversion-focused builds, technical SEO, and case studies with measured pipeline impact."
  ogImage={heroImages.home}
  schema={organizationSchema()}
>
  <main>
    <Hero />
    <ClientsStrip />
    <BuyerClarity />
    <Work />
    <ServiceStack />
    <ProcessSticky />
    <StorySequence />
    <Testimonials />
    <PricingOverview showCta={true} compactProjects={true} />
    <Showreel />
    <CTA />
  </main>
</Layout>
