---
import Layout from '../components/layout/Layout.astro';
import Button from '../components/ui/Button.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
---

<Layout title="Contact | Nexrena">
  <main class="min-h-screen pt-32 pb-24 flex items-center">
    <div class="section-container w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        
        <!-- LEFT: Context -->
        <div class="flex flex-col justify-center reveal">
          <Eyebrow class="mb-8">CONTACT US //</Eyebrow>
          <h1 class="font-display text-[64px] md:text-[96px] text-[var(--warm-white)] leading-[1.1] mb-16 whitespace-pre-line">
            {"Let's build\nsomething."}
          </h1>
          
          <div class="flex flex-col gap-8">
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Email</span>
              <a href="mailto:hello@nexrena.com" class="font-body text-[18px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">hello@nexrena.com</a>
            </div>
            
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Based</span>
              <span class="font-body text-[18px] text-[var(--slate-200)]">Kissimmee, FL (Orlando Metro)</span>
            </div>
            
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Hours</span>
              <span class="font-body text-[18px] text-[var(--slate-200)]">Mon–Fri, 9am–6pm ET</span>
            </div>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="bg-[var(--slate-900)] p-8 md:p-12 border border-[var(--slate-800)] reveal" style="--i: 2;">
          <form id="contact-form" class="flex flex-col gap-6 relative z-10" onsubmit="event.preventDefault(); document.getElementById('success-state').classList.remove('hidden'); document.getElementById('contact-form').classList.add('hidden');">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label for="name" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Name</label>
                <input type="text" id="name" required class="bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] transition-colors" />
              </div>
              <div class="flex flex-col gap-2">
                <label for="company" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Company</label>
                <input type="text" id="company" class="bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] transition-colors" />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="email" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Email</label>
              <input type="email" id="email" required class="bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] transition-colors" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label for="budget" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Budget Range</label>
                <select id="budget" class="bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] transition-colors appearance-none cursor-pointer">
                  <option value="">Select range...</option>
                  <option value="10k-25k">$10k - $25k</option>
                  <option value="25k-50k">$25k - $50k</option>
                  <option value="50k+">$50k+</option>
                </select>
              </div>
              <div class="flex flex-col gap-2">
                <label for="type" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Project Type</label>
                <select id="type" class="bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] transition-colors appearance-none cursor-pointer">
                  <option value="">Select type...</option>
                  <option value="web-design">Web Design & Dev</option>
                  <option value="seo">SEO & Growth</option>
                  <option value="full-service">Full-Service</option>
                </select>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">How can we help?</label>
              <textarea id="message" rows="4" required placeholder="Tell us about your project goals and any current challenges." class="bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] transition-colors resize-none"></textarea>
            </div>

            <Button type="submit" variant="primary" class="w-full mt-4">
              Send Message &mdash; Your next stage of growth starts here.
            </Button>
          </form>

          <!-- Success State -->
          <div id="success-state" class="hidden flex-col items-center justify-center text-center py-16 animate-fade-in">
            <div class="w-16 h-16 rounded-full border border-[var(--gold)] text-[var(--gold)] flex items-center justify-center mb-8">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </div>
            <h3 class="font-display italic text-[32px] text-[var(--warm-white)] mb-4">Message received.</h3>
            <p class="font-body text-[15px] text-[var(--slate-400)] max-w-sm">
              We'll be in touch within 24 hours to discuss your project.
            </p>
          </div>

        </div>

      </div>
    </div>
  </main>
</Layout>
