---
import Layout from '../components/layout/Layout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Button from '../components/ui/Button.astro';
import { heroImages } from '../data/hero-images';
import { webPageSchema } from '../lib/schema';

const site = 'https://nexrena.com';
const schema = webPageSchema({
  name: 'Contact | Nexrena',
  description: 'Contact Nexrena for web design, SEO, and digital growth. Based in Kissimmee, FL (Orlando metro). Start your 90-day growth plan.',
  url: `${site}/contact`,
});

// API URL for contact form - accessed at build time
const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://nexrena-api-5dc54effaa9f.herokuapp.com';
---

<Layout 
  title="Contact | Nexrena" 
  description="Contact Nexrena for web design, SEO, and digital growth. Based in Kissimmee, FL (Orlando metro). Start your 90-day growth plan."
  schema={schema}
>
  <main>
    <PageHero 
      eyebrow="CONTACT US //" 
      title={"Let's build something."}
      subtitle="Tell us about your project. We'll map a 90-day growth plan."
      variant="short"
      image={heroImages.contact}
    />
    <div class="section-container pt-16 pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        
        <!-- LEFT: Context -->
        <div class="flex flex-col justify-center reveal">
          
          <div class="flex flex-col gap-8">
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Email</span>
              <a href="mailto:hello@nexrena.com" class="font-body text-[18px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">hello@nexrena.com</a>
            </div>
            
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Based</span>
              <span class="font-body text-[18px] text-[var(--slate-200)]">Kissimmee, FL (Orlando Metro)</span>
            </div>
            
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Hours</span>
              <span class="font-body text-[18px] text-[var(--slate-200)]">Mon–Fri, 9am–6pm ET</span>
            </div>

            <!-- Schedule a call -->
            <div class="pt-8 border-t border-[var(--slate-800)]">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest block mb-3">Prefer to talk?</span>
              <a 
                href="https://cal.com/nexrena/discovery" 
                target="_blank" 
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-3 font-mono text-[13px] text-[var(--gold)] border border-[var(--gold)] px-6 py-3 hover:bg-[var(--gold)] hover:text-[var(--obsidian)] transition-colors"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Book a discovery call
              </a>
            </div>

            <!-- Trust signal -->
            <div class="bg-[var(--slate-900)] border border-[var(--slate-800)] p-6 mt-4">
              <p class="font-display italic text-[20px] text-[var(--slate-200)] leading-snug mb-3">
                "Literally the best single website contact in the history of the company."
              </p>
              <p class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-wider">— Forzabuilt Leadership</p>
            </div>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="bg-[var(--slate-900)] p-8 md:p-12 border border-[var(--slate-800)] reveal" style="--i: 2;">
          <form id="contact-form" class="flex flex-col gap-6 relative z-10">
            
            <!-- Honeypot — invisible to humans, traps bots -->
            <div class="absolute -left-[9999px]" aria-hidden="true">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="form-field flex flex-col gap-2">
                <label for="name" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Name</label>
                <input type="text" id="name" name="name" required class="contact-input bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] focus-visible:ring-2 focus-visible:ring-[var(--gold)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--obsidian)] transition-colors" autocomplete="name" />
                <span class="field-error font-mono text-[10px] text-red-400 hidden"></span>
              </div>
              <div class="form-field flex flex-col gap-2">
                <label for="company" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Company</label>
                <input type="text" id="company" name="company" class="contact-input bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] focus-visible:ring-2 focus-visible:ring-[var(--gold)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--obsidian)] transition-colors" autocomplete="organization" />
              </div>
            </div>

            <div class="form-field flex flex-col gap-2">
              <label for="email" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Email</label>
              <input type="email" id="email" name="email" required class="contact-input bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] focus-visible:ring-2 focus-visible:ring-[var(--gold)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--obsidian)] transition-colors" autocomplete="email" />
              <span class="field-error font-mono text-[10px] text-red-400 hidden"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="form-field flex flex-col gap-2">
                <label for="budget" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Budget Range</label>
                <select id="budget" name="budget" class="contact-input bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] focus-visible:ring-2 focus-visible:ring-[var(--gold)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--obsidian)] transition-colors appearance-none cursor-pointer" aria-label="Budget range">
                  <option value="">Select range...</option>
                  <option value="10k-25k">$10k - $25k</option>
                  <option value="25k-50k">$25k - $50k</option>
                  <option value="50k+">$50k+</option>
                </select>
              </div>
              <div class="form-field flex flex-col gap-2">
                <label for="type" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">Project Type</label>
                <select id="type" name="type" class="contact-input bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] focus-visible:ring-2 focus-visible:ring-[var(--gold)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--obsidian)] transition-colors appearance-none cursor-pointer" aria-label="Project type">
                  <option value="">Select type...</option>
                  <option value="web-design">Web Design & Dev</option>
                  <option value="seo">SEO & Growth</option>
                  <option value="full-service">Full-Service</option>
                </select>
              </div>
            </div>

            <div class="form-field flex flex-col gap-2">
              <label for="message" class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest">How can we help?</label>
              <textarea id="message" name="message" rows="4" required placeholder="Tell us about your project goals and any current challenges." class="contact-input bg-[var(--slate-800)] border border-[var(--slate-700)] text-[var(--warm-white)] font-body px-4 py-3 outline-none focus:border-[var(--gold)] focus-visible:ring-2 focus-visible:ring-[var(--gold)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--obsidian)] transition-colors resize-none" aria-label="Project message"></textarea>
              <span class="field-error font-mono text-[10px] text-red-400 hidden"></span>
            </div>

            <!-- Error state -->
            <p id="form-error" class="font-mono text-[12px] text-red-400 hidden"></p>

            <Button type="submit" variant="primary" class="w-full mt-4">
              <span id="submit-text">Send Message</span>
              <svg id="submit-spinner" class="hidden animate-spin ml-2" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.49-8.49l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M7.76 7.76L4.93 4.93"/>
              </svg>
            </Button>
          </form>

          <!-- Success State -->
          <div id="success-state" class="hidden flex-col items-center justify-center text-center py-16 animate-fade-in">
            <div class="w-16 h-16 rounded-full border border-[var(--gold)] text-[var(--gold)] flex items-center justify-center mb-8">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </div>
            <h3 class="font-display italic text-[32px] text-[var(--warm-white)] mb-4">Message received.</h3>
            <p class="font-body text-[15px] text-[var(--slate-400)] max-w-sm">
              We'll be in touch within 24 hours to discuss your project.
            </p>
          </div>

          <script define:vars={{ apiUrl }}>
            const NEXRENA_API = apiUrl;

            function initContactForm() {
              const form = document.getElementById('contact-form') as HTMLFormElement | null;
              const success = document.getElementById('success-state');
              const errorEl = document.getElementById('form-error');
              const submitText = document.getElementById('submit-text');
              const submitSpinner = document.getElementById('submit-spinner');
              if (!form || !success) return;

              // Inline validation on blur
              form.querySelectorAll('.contact-input[required]').forEach((input) => {
                input.addEventListener('blur', () => {
                  const el = input as HTMLInputElement;
                  const errorSpan = el.closest('.form-field')?.querySelector('.field-error') as HTMLElement | null;
                  if (!el.validity.valid && el.value.length > 0) {
                    el.style.borderColor = '#f87171';
                    if (errorSpan) {
                      errorSpan.textContent = el.type === 'email' ? 'Please enter a valid email' : 'This field is required';
                      errorSpan.classList.remove('hidden');
                    }
                  } else {
                    el.style.borderColor = '';
                    if (errorSpan) errorSpan.classList.add('hidden');
                  }
                });
                input.addEventListener('input', () => {
                  const el = input as HTMLInputElement;
                  if (el.validity.valid) {
                    el.style.borderColor = '';
                    const errorSpan = el.closest('.form-field')?.querySelector('.field-error') as HTMLElement | null;
                    if (errorSpan) errorSpan.classList.add('hidden');
                  }
                });
              });

              form.addEventListener('submit', async (e) => {
                e.preventDefault();
                if (errorEl) { errorEl.classList.add('hidden'); errorEl.textContent = ''; }

                const fd = Object.fromEntries(new FormData(form));

                // Honeypot check
                if (fd.website) return;

                // Show loading state
                const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
                if (submitBtn) submitBtn.disabled = true;
                if (submitText) submitText.textContent = 'Sending...';
                if (submitSpinner) submitSpinner.classList.remove('hidden');

                const payload = {
                  name: fd.name,
                  company: fd.company || undefined,
                  email: fd.email,
                  budget: fd.budget || undefined,
                  projectType: fd.type || undefined,
                  message: fd.message,
                };

                try {
                  const res = await fetch(`${NEXRENA_API}/api/leads`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                  });

                  if (res.ok) {
                    form.classList.add('hidden');
                    success.classList.remove('hidden');
                    success.style.display = 'flex';
                  } else {
                    throw new Error('Submission failed');
                  }
                } catch {
                  if (errorEl) {
                    errorEl.textContent = 'Something went wrong. Please email us directly at hello@nexrena.com';
                    errorEl.classList.remove('hidden');
                  }
                } finally {
                  if (submitBtn) submitBtn.disabled = false;
                  if (submitText) submitText.textContent = 'Send Message';
                  if (submitSpinner) submitSpinner.classList.add('hidden');
                }
              });
            }

            document.addEventListener('astro:page-load', initContactForm);
          </script>

        </div>

      </div>
    </div>
  </main>
</Layout>
