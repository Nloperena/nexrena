---
import Layout from '../components/layout/Layout.astro';
import PageHero from '../components/sections/PageHero.astro';
import PricingOverview from '../components/sections/PricingOverview.astro';
import { ProjectIntakeForm } from '../components/ProjectIntakeForm';
import { heroImages } from '../data/hero-images';
import { webPageSchema } from '../lib/schema';
import { projectIntakeCta } from '../data/cta';

const site = 'https://nexrena.com';
const schema = webPageSchema({
  name: 'Contact | Nexrena',
  description: 'Contact Nexrena for web design, SEO, WaaS, and digital growth. Based in Kissimmee, FL (Orlando metro). Transparent project and monthly pricing.',
  url: `${site}/contact`,
});
---

<Layout 
  title="Contact | Nexrena" 
  description="Contact Nexrena for web design, SEO, WaaS, and digital growth. Based in Kissimmee, FL (Orlando metro). Transparent project and monthly pricing."
  schema={schema}
>
  <main>
    <PageHero 
      eyebrow="CONTACT US //" 
      title={projectIntakeCta.portalTitle}
      subtitle={projectIntakeCta.portalSubtitle}
      variant="short"
      image={heroImages.contact}
    />

    <PricingOverview showCta={false} />

    <div class="section-container pt-16 pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <div class="flex flex-col justify-center reveal">
          <div class="flex flex-col gap-8">
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Email</span>
              <a href="mailto:NicholasL@Nexrena.com" class="font-body text-[18px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">NicholasL@Nexrena.com</a>
            </div>
            
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Based</span>
              <span class="font-body text-[18px] text-[var(--slate-200)]">Kissimmee, FL (Orlando Metro)</span>
            </div>

            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Local guide</span>
              <a href="/resources/blog/web-design-orlando/" class="font-body text-[18px] text-[var(--slate-200)] hover:text-[var(--gold)] transition-colors">
                How to choose a B2B web design agency in Orlando →
              </a>
            </div>
            
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest">Hours</span>
              <span class="font-body text-[18px] text-[var(--slate-200)]">Mon–Fri, 9am–6pm ET</span>
            </div>

            <div class="pt-8 border-t border-[var(--slate-800)]">
              <span class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest block mb-3">Prefer to talk?</span>
              <a 
                href="https://cal.com/nexrena/discovery" 
                target="_blank" 
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-3 font-mono text-[13px] text-[var(--gold)] border border-[var(--gold)] px-6 py-3 hover:bg-[var(--gold)] hover:text-[var(--obsidian)] transition-colors"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Book a discovery call
              </a>
            </div>

            <div class="bg-[var(--slate-900)] border border-[var(--slate-800)] p-6 mt-4">
              <p class="font-display italic text-[20px] text-[var(--slate-200)] leading-snug mb-3">
                "Literally the best single website contact in the history of the company."
              </p>
              <p class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-wider">— Forzabuilt Leadership</p>
            </div>
          </div>
        </div>

        <div class="bg-[var(--slate-900)] p-8 md:p-12 border border-[var(--slate-800)] reveal" style="--i: 2;">
          <div class="mb-8 pb-6 border-b border-[var(--slate-800)]">
            <p class="font-mono text-[10px] text-[var(--gold-dim)] uppercase tracking-widest mb-4">What happens next</p>
            <ul class="flex flex-col gap-2 font-body text-[14px] text-[var(--slate-300)] leading-relaxed">
              <li class="flex gap-3"><span class="font-mono text-[11px] text-[var(--gold)] shrink-0">01</span> We reply within one business day with next steps.</li>
              <li class="flex gap-3"><span class="font-mono text-[11px] text-[var(--gold)] shrink-0">02</span> Short intro call to understand your goals and current setup.</li>
              <li class="flex gap-3"><span class="font-mono text-[11px] text-[var(--gold)] shrink-0">03</span> You get a focused roadmap — or a clear "not the right fit".</li>
            </ul>
          </div>

          <ProjectIntakeForm client:load source="contact-page" />
        </div>
      </div>
    </div>
  </main>
</Layout>
