---
import Layout from '../components/layout/Layout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Button from '../components/ui/Button.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import CTA from '../components/sections/CTA.astro';
import { heroImages } from '../data/hero-images';
import { webPageSchema } from '../lib/schema';

const site = 'https://nexrena.com';
const schema = webPageSchema({
  name: 'About | Nexrena',
  description: 'A senior-operator consultancy for B2B companies serious about growth. Websites, SEO systems, and engineering that compound.',
  url: `${site}/about`,
});

const values = [
  {
    num: '01',
    title: 'Infrastructure Over Aesthetics',
    body: "Pretty sites that don't convert are expensive art. Every build is measured against commercial outcomes first: qualified leads, sales cycle velocity, and organic visibility.",
  },
  {
    num: '02',
    title: 'Written Handoff, Not Dependency',
    body: 'The goal of an engagement is a system your team can operate without us. Clean components, documented workflows, and handoff-ready tooling — no lock-in by design.',
  },
  {
    num: '03',
    title: 'Selective by Default',
    body: "We don't pitch every prospect. If the scope is not a fit, we will say so. If it is a fit, you'll get a clear 90-day growth plan before any long engagement.",
  },
];
---

<Layout 
  title="About | Nexrena" 
  description="A senior-operator consultancy for B2B companies serious about growth. Websites, SEO systems, and engineering that compound."
  schema={schema}
>
  <main>
    <PageHero 
      eyebrow="ABOUT NEXRENA //" 
      title="A senior-operator consultancy for B2B companies that are serious about growth."
      subtitle="Nexrena builds digital infrastructure — websites, SEO systems, and the engineering that makes them compound — for companies that need the work shipped, not managed."
      image={heroImages.about}
    />

    <!-- Who I Am -->
    <section class="bg-[var(--obsidian)] border-b border-[var(--slate-800)]">
      <div class="max-w-[1320px] mx-auto px-[5vw] pt-16 pb-32">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 relative z-10 items-center">
          
          <!-- LEFT: Image -->
          <div class="lg:col-span-5 relative reveal">
            <div class="aspect-[4/5] bg-[var(--slate-800)] border border-[var(--slate-700)] overflow-hidden relative group">
              <div class="absolute inset-0 bg-[var(--obsidian)]/50 group-hover:bg-transparent transition-colors duration-500 z-10 pointer-events-none"></div>
              <img 
                src="https://www.nicoloperena.com/professional-photo.webp" 
                alt="Nico Loperena, founder of Nexrena" 
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
                loading="lazy"
              />
              <div class="absolute top-0 left-0 w-8 h-[1px] bg-[var(--gold)] z-20"></div>
              <div class="absolute top-0 left-0 w-[1px] h-8 bg-[var(--gold)] z-20"></div>
              <div class="absolute bottom-0 right-0 w-8 h-[1px] bg-[var(--gold)] z-20"></div>
              <div class="absolute bottom-0 right-0 w-[1px] h-8 bg-[var(--gold)] z-20"></div>
            </div>
            <div class="absolute -right-8 bottom-16 bg-[var(--gold)] text-[var(--obsidian)] px-6 py-3 font-mono text-[11px] uppercase tracking-widest hidden md:block">
              Full-stack, Florida-based
            </div>
          </div>

          <!-- RIGHT: Bio -->
          <div class="lg:col-span-7 flex flex-col items-start reveal" style="--i: 2;">
            <Eyebrow class="mb-6">WHY NEXRENA EXISTS //</Eyebrow>
            <h2 class="font-display text-[36px] md:text-[48px] text-[var(--warm-white)] leading-[1.1] mb-8">
              Why multi-vendor B2B stacks stall.
            </h2>
            <div class="font-body text-[17px] leading-loose text-[var(--slate-300)] flex flex-col gap-6 mb-12">
              <p>
                Nexrena was founded after years of watching B2B companies burn capital on the same pattern: multiple vendors, each owning a slice, none owning the outcome.
              </p>
              <p>
                The SEO agency blames development for slow pages. Development blames design for complexity. Content recommendations never make it to production. Budget disappears into coordination overhead instead of shipped improvements.
              </p>
              <p>
                Led by Nicholas Loperena. Six years building production B2B systems across web engineering, SEO, and conversion architecture. Most recently the full-stack operator behind ForzaBuilt's rebrand, Astro rebuild, and post-launch SEO recovery — a 200+ SKU migration that shipped at 99% Lighthouse desktop and drove 0 &rarr; 28 MQLs in 4 months.
              </p>
            </div>
            <div class="flex flex-wrap gap-4 pt-8 border-t border-[var(--slate-800)] w-full">
              <Button href="/contact" variant="primary">Work with us &rarr;</Button>
              <Button href="/work" variant="outline">View projects</Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How We Work -->
    <section class="bg-[var(--slate-900)] border-b border-[var(--slate-800)]">
      <div class="max-w-[1320px] mx-auto px-[5vw] py-32">
        <div class="max-w-3xl mb-20">
          <Eyebrow class="mb-6">HOW WE WORK //</Eyebrow>
          <h2 class="font-display text-[40px] md:text-[64px] text-[var(--warm-white)] leading-[1.05] reveal">
            What we actually do differently.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-[var(--slate-800)]">
          {values.map((v, i) => (
            <div class="value-card py-10 md:py-0 md:px-10 first:md:pl-0 last:md:pr-0 reveal" style={`--i: ${i + 1};`}>
              <span class="font-display text-[64px] text-[var(--slate-800)] leading-none font-light mb-4 block">{v.num}</span>
              <h3 class="font-display text-[28px] md:text-[32px] text-[var(--warm-white)] leading-tight mb-6">{v.title}</h3>
              <p class="font-body text-[16px] text-[var(--slate-400)] leading-relaxed">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Straight Talk + Proof -->
    <section class="bg-[var(--obsidian)] border-b border-[var(--slate-800)]">
      <div class="max-w-[1320px] mx-auto px-[5vw] py-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
          <div class="reveal">
            <Eyebrow class="mb-6">STRAIGHT TALK //</Eyebrow>
            <h2 class="font-display text-[40px] md:text-[56px] text-[var(--warm-white)] leading-[1.1] mb-8">
              We're not for everyone.
            </h2>
            <p class="font-body text-[17px] text-[var(--slate-400)] leading-relaxed mb-6">
              If you want a brochure site with no measurable outcomes, we're not your partner. If you want the cheapest vendor in the market, we're not it.
            </p>
            <p class="font-body text-[17px] text-[var(--slate-300)] leading-relaxed">
              We work best with companies that are serious about growth, ready to invest in infrastructure, and want senior execution — not a coordination layer.
            </p>
          </div>

          <div class="flex flex-col justify-center reveal" style="--i: 2;">
            <div class="bg-[var(--slate-900)] border border-[var(--slate-800)] p-10 md:p-14 relative overflow-hidden">
              <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[var(--gold)] to-transparent"></div>
              <svg class="absolute top-6 right-6 opacity-10" width="48" height="48" viewBox="0 0 24 24" fill="var(--gold)"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
              <p class="font-mono text-[10px] text-[var(--gold)] uppercase tracking-[0.2em] mb-6 relative z-10">Proof</p>
              <h3 class="font-display text-[28px] text-[var(--warm-white)] mb-6 leading-tight relative z-10">
                ForzaBuilt: rebrand, Astro rebuild, and SEO recovery across a 200+ SKU migration.
              </h3>
              <p class="font-body text-[15px] text-[var(--slate-400)] leading-relaxed mb-6 relative z-10">
                Engagement scope ran from rebrand launch through post-launch SEO hardening, with implementation and validation handled inside one accountable workflow.
              </p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 relative z-10 mb-8">
                <div>
                  <p class="font-display text-[34px] text-[var(--gold)] leading-none">99%</p>
                  <p class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest mt-2">SEO Health</p>
                </div>
                <div>
                  <p class="font-display text-[34px] text-[var(--gold)] leading-none">99%</p>
                  <p class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest mt-2">Lighthouse Desktop</p>
                </div>
                <div>
                  <p class="font-display text-[34px] text-[var(--gold)] leading-none">0→28</p>
                  <p class="font-mono text-[10px] text-[var(--slate-400)] uppercase tracking-widest mt-2">MQLs / 4 months</p>
                </div>
              </div>
              <div class="relative z-10">
                <Button href="/work/forzabuilt/" variant="outline">See the ForzaBuilt case study &rarr;</Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
</Layout>
