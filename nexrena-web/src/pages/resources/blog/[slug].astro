---
import Layout from '../../../components/layout/Layout.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import { getCollection } from 'astro:content';
import { heroImages } from '../../../data/hero-images';
import { articleSchema } from '../../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const site = Astro.site?.toString() ?? 'https://nexrena.com';
const canonical = new URL(`/resources/blog/${post.slug}`, site).toString();
const schema = articleSchema({
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: post.data.publishedAt.toISOString(),
  url: canonical,
});
---

<Layout
  title={`${post.data.title} | Nexrena`}
  description={post.data.description}
  schema={schema}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta property="og:url" content={canonical} />
    <meta property="article:published_time" content={post.data.publishedAt.toISOString()} />
    <meta property="article:author" content={post.data.author} />
  </Fragment>

  <main>
    <PageHero 
      eyebrow="BLOG //" 
      title={post.data.title}
      subtitle={`${post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · ${post.data.author}`}
      variant="short"
      image={heroImages.blog}
    />
    <article class="section-container max-w-[720px] mx-auto pt-16 pb-48">
      <header class="mb-16">
        <a href="/resources/blog" class="font-mono text-[11px] text-[var(--gold)] hover:text-[var(--gold-light)] transition-colors mb-6 inline-block">
          &larr; Back to blog
        </a>
      </header>
      <div class="prose prose-invert prose-lg max-w-none font-body text-[17px] leading-relaxed text-[var(--slate-300)] [&_h2]:font-display [&_h2]:text-[28px] [&_h2]:text-[var(--warm-white)] [&_h2]:mt-12 [&_h2]:mb-6 [&_h3]:font-display [&_h3]:text-[22px] [&_h3]:text-[var(--warm-white)] [&_h3]:mt-10 [&_h3]:mb-4 [&_a]:text-[var(--gold)] [&_a]:hover:text-[var(--gold-light)] [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:space-y-2">
        <Content />
      </div>
    </article>
  </main>
</Layout>
