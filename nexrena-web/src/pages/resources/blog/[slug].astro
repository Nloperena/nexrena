---
import Layout from '../../../components/layout/Layout.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import Breadcrumb from '../../../components/seo/Breadcrumb.astro';
import RelatedPosts from '../../../components/blog/RelatedPosts.astro';
import NewsletterCTA from '../../../components/blog/NewsletterCTA.astro';
import { getCollection } from 'astro:content';
import { heroImages } from '../../../data/hero-images';
import { blogCategories } from '../../../data/blog-categories';
import { articleSchema, breadcrumbSchema } from '../../../lib/schema';
import { getBlogSupportLinks } from '../../../data/seo-internal-links';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await post.render();
const categoryInfo = blogCategories.find(c => c.id === post.data.category);
const site = Astro.site?.toString() ?? 'https://nexrena.com';
const siteOrigin = new URL(site).origin;
const canonical = new URL(`/resources/blog/${post.slug}/`, siteOrigin).toString();
const schema = [
  articleSchema({
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.publishedAt.toISOString(),
    dateModified: post.data.publishedAt.toISOString(),
    url: canonical,
  }),
  breadcrumbSchema([
    { name: 'Resources', url: new URL('/resources/', siteOrigin).toString() },
    { name: 'Blog', url: new URL('/resources/blog/', siteOrigin).toString() },
    { name: post.data.title, url: canonical },
  ]),
];
const supportLinks = getBlogSupportLinks(post.data.category);
const contextualGuides = allPosts
  .filter((entry) => entry.slug !== post.slug)
  .filter((entry) => entry.data.category === post.data.category)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 2);
---

<Layout
  title={`${post.data.title} | Nexrena`}
  description={post.data.description}
  schema={schema}
  ogType="article"
  articlePublishedTime={post.data.publishedAt.toISOString()}
  articleAuthor={post.data.author}
>
  <main>
    <div class="section-container pt-8 pb-4">
      <Breadcrumb items={[
        { name: 'Resources', url: new URL('/resources/', siteOrigin).toString() },
        { name: 'Blog', url: new URL('/resources/blog/', siteOrigin).toString() },
        { name: post.data.title, url: canonical },
      ]} />
    </div>
    <PageHero 
      eyebrow="BLOG //" 
      title={post.data.title}
      subtitle={`${post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · ${post.data.author}`}
      variant="short"
      image={heroImages.blog}
    />
    <article class="section-container max-w-[720px] mx-auto pt-16 pb-24">
      <header class="mb-16 flex items-center gap-4">
        <a href="/resources/blog/" class="font-mono text-[11px] text-[var(--gold)] hover:text-[var(--gold-light)] transition-colors inline-block">
          &larr; Back to blog
        </a>
        {categoryInfo && (
          <a href={`/resources/blog/category/${post.data.category}/`} class="font-mono text-[10px] text-[var(--slate-400)] bg-[var(--slate-800)] px-3 py-1 uppercase tracking-wider hover:text-[var(--gold)] transition-colors">
            {categoryInfo.name}
          </a>
        )}
      </header>
      <div class="mb-10 p-6 border border-[var(--slate-800)] bg-[var(--slate-900)]/35">
        <p class="font-body text-[15px] text-[var(--slate-300)] leading-relaxed">
          Need a deeper next step? Pair this guide with
          <a class="mx-1 text-[var(--gold)] hover:text-[var(--gold-light)]" href={supportLinks.service.href}>{supportLinks.service.title}</a>
          and
          <a class="mx-1 text-[var(--gold)] hover:text-[var(--gold-light)]" href={supportLinks.faq.href}>{supportLinks.faq.title}</a>.
          {contextualGuides.length > 0 && (
            <>
              Also read
              {contextualGuides.map((guide, idx) => (
                <>
                  {' '}
                  <a class="text-[var(--gold)] hover:text-[var(--gold-light)]" href={`/resources/blog/${guide.slug}/`}>{guide.data.title}</a>
                  {idx === 0 && contextualGuides.length > 1 ? ' and' : ''}
                </>
              ))}
              .
            </>
          )}
        </p>
      </div>
      <div class="prose prose-invert prose-lg max-w-none font-body text-[17px] leading-relaxed text-[var(--slate-300)] [&_h2]:font-display [&_h2]:text-[28px] [&_h2]:text-[var(--warm-white)] [&_h2]:mt-12 [&_h2]:mb-6 [&_h3]:font-display [&_h3]:text-[22px] [&_h3]:text-[var(--warm-white)] [&_h3]:mt-10 [&_h3]:mb-4 [&_a]:text-[var(--gold)] [&_a]:hover:text-[var(--gold-light)] [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:space-y-2">
        <Content />
      </div>

      <div class="mt-16">
        <NewsletterCTA />
      </div>

      <section class="mt-16 p-8 border border-[var(--slate-800)] bg-[var(--slate-900)]/40">
        <h3 class="font-display text-[28px] text-[var(--warm-white)] mb-4">Keep exploring</h3>
        <p class="font-body text-[15px] text-[var(--slate-400)] mb-6">
          Continue with one service page and one FAQ answer tied to this topic.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a href={supportLinks.service.href} class="block p-5 border border-[var(--slate-800)] hover:border-[var(--gold)]/50 transition-colors">
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--gold)]">Service</span>
            <h4 class="font-display text-[22px] text-[var(--warm-white)] mt-2 mb-2">{supportLinks.service.title}</h4>
            {supportLinks.service.description && (
              <p class="font-body text-[14px] text-[var(--slate-400)]">{supportLinks.service.description}</p>
            )}
          </a>
          <a href={supportLinks.faq.href} class="block p-5 border border-[var(--slate-800)] hover:border-[var(--gold)]/50 transition-colors">
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--gold)]">FAQ</span>
            <h4 class="font-display text-[22px] text-[var(--warm-white)] mt-2">{supportLinks.faq.title}</h4>
          </a>
        </div>
      </section>

      <RelatedPosts currentSlug={post.slug} category={post.data.category} allPosts={allPosts} />
    </article>
  </main>
</Layout>
