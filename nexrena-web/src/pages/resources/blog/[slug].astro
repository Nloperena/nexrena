---
import Layout from '../../../components/layout/Layout.astro';
import PageHero from '../../../components/sections/PageHero.astro';
import Breadcrumb from '../../../components/seo/Breadcrumb.astro';
import RelatedPosts from '../../../components/blog/RelatedPosts.astro';
import NewsletterCTA from '../../../components/blog/NewsletterCTA.astro';
import { getCollection } from 'astro:content';
import { heroImages } from '../../../data/hero-images';
import { blogCategories } from '../../../data/blog-categories';
import { articleSchema, breadcrumbSchema } from '../../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await post.render();
const categoryInfo = blogCategories.find(c => c.id === post.data.category);
const site = Astro.site?.toString() ?? 'https://nexrena.com';
const canonical = new URL(`/resources/blog/${post.slug}`, site).toString();
const schema = [
  articleSchema({
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.publishedAt.toISOString(),
    dateModified: post.data.publishedAt.toISOString(),
    url: canonical,
  }),
  breadcrumbSchema([
    { name: 'Resources', url: `${site}/resources` },
    { name: 'Blog', url: `${site}/resources/blog` },
    { name: post.data.title, url: canonical },
  ]),
];
---

<Layout
  title={`${post.data.title} | Nexrena`}
  description={post.data.description}
  schema={schema}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta property="og:url" content={canonical} />
    <meta property="article:published_time" content={post.data.publishedAt.toISOString()} />
    <meta property="article:author" content={post.data.author} />
  </Fragment>

  <main>
    <div class="section-container pt-8 pb-4">
      <Breadcrumb items={[
        { name: 'Resources', url: `${site}/resources` },
        { name: 'Blog', url: `${site}/resources/blog` },
        { name: post.data.title, url: canonical },
      ]} />
    </div>
    <PageHero 
      eyebrow="BLOG //" 
      title={post.data.title}
      subtitle={`${post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · ${post.data.author}`}
      variant="short"
      image={heroImages.blog}
    />
    <article class="section-container max-w-[720px] mx-auto pt-16 pb-24">
      <header class="mb-16 flex items-center gap-4">
        <a href="/resources/blog" class="font-mono text-[11px] text-[var(--gold)] hover:text-[var(--gold-light)] transition-colors inline-block">
          &larr; Back to blog
        </a>
        {categoryInfo && (
          <a href={`/resources/blog/category/${post.data.category}`} class="font-mono text-[10px] text-[var(--slate-400)] bg-[var(--slate-800)] px-3 py-1 uppercase tracking-wider hover:text-[var(--gold)] transition-colors">
            {categoryInfo.name}
          </a>
        )}
      </header>
      <div class="prose prose-invert prose-lg max-w-none font-body text-[17px] leading-relaxed text-[var(--slate-300)] [&_h2]:font-display [&_h2]:text-[28px] [&_h2]:text-[var(--warm-white)] [&_h2]:mt-12 [&_h2]:mb-6 [&_h3]:font-display [&_h3]:text-[22px] [&_h3]:text-[var(--warm-white)] [&_h3]:mt-10 [&_h3]:mb-4 [&_a]:text-[var(--gold)] [&_a]:hover:text-[var(--gold-light)] [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:space-y-2">
        <Content />
      </div>

      <div class="mt-16">
        <NewsletterCTA />
      </div>

      <RelatedPosts currentSlug={post.slug} category={post.data.category} allPosts={allPosts} />
    </article>
  </main>
</Layout>
