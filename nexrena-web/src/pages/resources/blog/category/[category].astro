---
import Layout from '../../../../components/layout/Layout.astro';
import PageHero from '../../../../components/sections/PageHero.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';
import { heroImages } from '../../../../data/hero-images';
import { blogCategories } from '../../../../data/blog-categories';

export function getStaticPaths() {
  return blogCategories.map(cat => ({
    params: { category: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

const posts = (await getCollection('blog'))
  .filter(p => p.data.category === category.id)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<Layout 
  title={`${category.name} Articles | Nexrena`}
  description={category.description}
>
  <main>
    <PageHero 
      eyebrow={`BLOG // ${category.name.toUpperCase()}`}
      title={category.name}
      subtitle={category.description}
      image={heroImages.blog}
      variant="short"
    />

    <section class="bg-[var(--obsidian)] py-12 md:py-24">
      <div class="section-container">

        <!-- Category Filter -->
        <div class="flex flex-wrap gap-3 mb-12">
          <a href="/resources/blog" class="font-mono text-[11px] uppercase tracking-widest px-4 py-2 border border-[var(--slate-700)] text-[var(--slate-300)] hover:border-[var(--gold)] hover:text-[var(--gold)] transition-colors">
            All
          </a>
          {blogCategories.map(cat => (
            <a 
              href={`/resources/blog/category/${cat.id}`} 
              class:list={[
                'font-mono text-[11px] uppercase tracking-widest px-4 py-2 border transition-colors',
                cat.id === category.id
                  ? 'bg-[var(--gold)] text-[var(--obsidian)] border-[var(--gold)]'
                  : 'border-[var(--slate-700)] text-[var(--slate-300)] hover:border-[var(--gold)] hover:text-[var(--gold)]',
              ]}
            >
              {cat.name}
            </a>
          ))}
        </div>

        {posts.length === 0 ? (
          <p class="font-body text-[16px] text-[var(--slate-400)]">No articles in this category yet.</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post) => (
              <BlogCard
                slug={post.slug}
                title={post.data.title}
                description={post.data.description}
                publishedAt={post.data.publishedAt}
                category={post.data.category}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>
