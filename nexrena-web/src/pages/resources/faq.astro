---
import Layout from '../../components/layout/Layout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Button from '../../components/ui/Button.astro';
import { faqItems } from '../../data/faq';
import { heroImages } from '../../data/hero-images';
import { faqPageSchema } from '../../lib/schema';
import { services } from '../../data/services';

const site = Astro.site?.toString() ?? 'https://nexrena.com';
const faqUrl = `${site}/resources/faq`;
const schema = faqPageSchema(faqItems.map((f) => ({ question: f.question, answer: f.answer })));
---

<Layout
  title="FAQ | Nexrena"
  description="Frequently asked questions about B2B website redesign, SEO, and full-service digital growth. Timelines, pricing, and how we work."
  schema={schema}
>
  <main>
    <PageHero
      eyebrow="RESOURCES //"
      title="Frequently asked questions."
      subtitle="Answers about our process, timelines, and how we work with B2B companies."
      image={heroImages.resources}
    />

    <section class="bg-[var(--obsidian)] py-12 md:py-24">
      <div class="section-container max-w-3xl">
        <div class="space-y-12 divide-y divide-[var(--slate-800)]">
          {faqItems.map((item, i) => (
            <div id={item.id} class="pt-12 first:pt-0 reveal scroll-mt-28" style={`--i: ${i + 1};`}>
              <h2 class="font-display text-[24px] md:text-[28px] text-[var(--warm-white)] mb-4">
                {item.question}
              </h2>
              <p class="font-body text-[16px] text-[var(--slate-400)] leading-relaxed">
                {item.answer}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[var(--obsidian)] py-16 border-t border-[var(--slate-800)]">
      <div class="section-container">
        <h2 class="font-display text-[30px] md:text-[40px] text-[var(--warm-white)] mb-8">Related resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="p-6 border border-[var(--slate-800)]">
            <h3 class="font-display text-[24px] text-[var(--warm-white)] mb-4">Core services</h3>
            <div class="space-y-3">
              {services.map((service) => (
                <a href={`/services/${service.id}/`} class="block font-body text-[15px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">
                  {service.title.replace(/\n/g, ' ')}
                </a>
              ))}
            </div>
          </div>
          <div class="p-6 border border-[var(--slate-800)]">
            <h3 class="font-display text-[24px] text-[var(--warm-white)] mb-4">SEO and growth guides</h3>
            <div class="space-y-3">
              <a href="/resources/blog/" class="block font-body text-[15px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">
                Visit the blog hub
              </a>
              <a href="/resources/blog/seo-audit-checklist/" class="block font-body text-[15px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">
                Read the SEO audit checklist
              </a>
              <a href="/resources/blog/website-redesign-process/" class="block font-body text-[15px] text-[var(--slate-300)] hover:text-[var(--gold)] transition-colors">
                Read the website redesign process guide
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[var(--obsidian)] py-24 md:py-32 border-t border-[var(--slate-800)]">
      <div class="section-container text-center">
        <h2 class="font-display text-[40px] md:text-[56px] text-[var(--warm-white)] leading-[1.1] mb-8 reveal">
          Still have questions?
        </h2>
        <p class="text-[var(--slate-400)] text-[17px] mb-12 max-w-xl mx-auto reveal" style="--i: 1;">
          Tell us about your project. We'll map a plan that fits.
        </p>
        <Button href="/contact" variant="primary" class="reveal" style="--i: 2;">
          Start a project &rarr;
        </Button>
      </div>
    </section>
  </main>
</Layout>
